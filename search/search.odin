				   has_legal_root_rook_capture(b, &all_moves) {
					_, victim_value, _ := trace_capture_values(b, best_move)
					if victim_value >= constants.PIECE_VALUES[constants.KNIGHT] {
						extend_short_clock_tactical_horizon_budget(&search_limits)
							short_clock_minor_capture_horizon_recovery_depth = 8
						}
					}
				if current_depth >= 6 &&
				   current_depth < 8 &&
				   last_completed_pv_len >= current_depth &&
				   !last_completed_pv_tb_terminal &&
				   search_limits.hard_time >= 90 &&
				   search_limits.hard_time <= 240 &&
				   has_non_pawn_material(b, b.side) &&
				   has_non_pawn_material(b, 1 - b.side) &&
				   aspiration_fail_low_count >= 1 &&
				   best_move_changes >= 1 &&
				   largest_score_drop >= params.aspiration_window * 2 &&
				   !moves.is_empty_move(best_move) &&
				   best_move.capture &&
				   best_move.piece % 6 == constants.QUEEN &&
				   has_legal_root_quiet_knight_move(b, &all_moves) {
					extend_short_clock_tactical_horizon_budget(&search_limits)
				}
				if current_depth == 7 &&
				   last_completed_pv_len >= current_depth &&
				   !last_completed_pv_tb_terminal &&
				   search_limits.hard_time >= 90 &&
				   search_limits.hard_time <= 140 &&
				   non_pawn_piece_count(b) <= 4 &&
				   has_non_pawn_material(b, b.side) &&
				   has_non_pawn_material(b, 1 - b.side) &&
				   best_move_changes >= 1 &&
				   !moves.is_empty_move(prev_completed_best_move) &&
				   prev_completed_best_move.piece % 6 == constants.KING &&
				   !moves.is_empty_move(best_move) &&
				   is_quiet_queen_move(b, best_move) &&
				   count_legal_root_quiet_king_candidates(b, &all_moves) >= 1 {
					extend_short_clock_tactical_horizon_budget(&search_limits)
					short_clock_quiet_queen_horizon_recovery_depth = 8
				}
				if current_depth == 7 &&
				   last_completed_pv_len >= current_depth &&
				   !last_completed_pv_tb_terminal &&
				   search_limits.hard_time >= 90 &&
				   search_limits.hard_time <= 140 &&
				   non_pawn_piece_count(b) <= 8 &&
				   has_non_pawn_material(b, b.side) &&
				   has_non_pawn_material(b, 1 - b.side) &&
				   !has_root_queen_promotion(&all_moves) &&
				   aspiration_fail_low_count >= 2 &&
				   largest_score_drop >= params.aspiration_window * 2 &&
				   !moves.is_empty_move(best_move) &&
				   !(best_move.capture || best_move.promoted != -1) &&
