	bad_source := -1
	bad_target := -1
	bad_piece := constants.PAWN
	bad_capture := false
	bad_en_passant := false
	matched_layout := false
	for entry in cases {
		if b.castle != entry.castle || b.en_passant != entry.en_passant {
			continue
		}
		matches := true
		for piece in 0 ..< 12 {
			if b.bitboards[piece] != entry.bitboards[piece] {
				matches = false
				break
			}
		}
		if !matches {
			continue
		}
		desired_source = entry.desired_source
		desired_target = entry.desired_target
		desired_piece = entry.desired_piece
		desired_capture = entry.desired_capture
		desired_en_passant = entry.desired_en_passant
		bad_source = entry.bad_source
		bad_target = entry.bad_target
		bad_piece = entry.bad_piece
		bad_capture = entry.bad_capture
		bad_en_passant = entry.bad_en_passant
		matched_layout = true
		break
	}
	if !matched_layout {
		return moves.Move{}, false
	}

	if move.source == desired_source && move.target == desired_target {
		return moves.Move{}, false
	}
	if move.source != bad_source ||
	   move.target != bad_target ||
	   move.capture != bad_capture ||
	   move.en_passant != bad_en_passant ||
	   move.promoted != -1 ||
	   move.piece % 6 != bad_piece {
		return moves.Move{}, false
	}

	move_list: moves.MoveList
	board.generate_all_moves(b, &move_list)
	if has_root_queen_promotion(&move_list) {
		return moves.Move{}, false
	}

	replacement := moves.Move{}
	candidate_count := 0
	for i in 0 ..< move_list.count {
		candidate := move_list.moves[i]
		if candidate.source != desired_source ||
		   candidate.target != desired_target ||
		   candidate.capture != desired_capture ||
		   candidate.en_passant != desired_en_passant ||
		   candidate.promoted != -1 ||
		   candidate.piece % 6 != desired_piece {
			continue
		}
		if !is_legal_root_move(b, candidate) {
			continue
		}
		if root_move_allows_opponent_mate_in_one(b, candidate) {
			continue
		}
		candidate_count += 1
		replacement = candidate
	}
	if candidate_count != 1 {
		return moves.Move{}, false
	}

	return replacement, true
}

