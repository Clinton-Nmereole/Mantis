			   !moves.is_empty_move(best_move) &&
			   best_move.capture &&
			   see_capture(b, best_move) >= 0
				if !start_next_depth && shallow_forcing_capture_next_depth {
					projected := last_depth_ms * 4
					if previous_depth_ms > 0 {
						growth := f64(last_depth_ms) / f64(previous_depth_ms)
					if growth < 1.5 { growth = 1.5 }
					if growth > 4.0 { growth = 4.0 }
					projected = int(f64(last_depth_ms) * growth)
				}
				if projected < last_depth_ms + 1 {
					projected = last_depth_ms + 1
				}
				fallback_projected := last_depth_ms * 2
				if fallback_projected < last_depth_ms + 1 {
					fallback_projected = last_depth_ms + 1
				}
				elapsed_now := elapsed_ms(search_limits)
				if elapsed_now + projected < search_limits.hard_time ||
				   elapsed_now + fallback_projected < search_limits.hard_time {
						start_next_depth = true
					}
				}
				shallow_capture_seed_passed_pawn_next_depth :=
