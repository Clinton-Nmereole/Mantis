					if !start_next_depth && shallow_low_material_king_capture_next_depth {
						extend_short_clock_next_depth_margin_budget(&search_limits)
						start_next_depth = true
					}
					shallow_rook_promotion_pawn_capture_next_depth :=
					   current_depth >= 5 &&
					   current_depth < 8 &&
					   !search_limits.is_movetime &&
					   !search_limits.is_infinite &&
					   search_limits.hard_time >= 40 &&
					   search_limits.hard_time <= 720 &&
					   non_pawn_piece_count(b) <= 8 &&
					   has_non_pawn_material(b, b.side) &&
					   has_non_pawn_material(b, 1 - b.side) &&
					   !has_root_queen_promotion(&all_moves) &&
