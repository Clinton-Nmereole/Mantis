is_quiet_knight_move :: proc(move: moves.Move) -> bool {
	return !moves.is_empty_move(move) &&
	       !move.capture &&
	       move.promoted == -1 &&
	       move.piece % 6 == constants.KNIGHT
}

is_root_quiet_knight_rim_move :: proc(move: moves.Move) -> bool {
	if !is_quiet_knight_move(move) {
		return false
	}

	file := move.target % 8
	return file == 0 || file == 7
}

is_quiet_bishop_move :: proc(move: moves.Move) -> bool {
	return !moves.is_empty_move(move) &&
	       !move.capture &&
	       move.promoted == -1 &&
	       move.piece % 6 == constants.BISHOP
}

is_quiet_rook_move :: proc(move: moves.Move) -> bool {
	return !moves.is_empty_move(move) &&
	       !move.capture &&
	       move.promoted == -1 &&
	       move.piece % 6 == constants.ROOK
}

has_legal_root_quiet_knight_move :: proc(b: ^board.Board, move_list: ^moves.MoveList) -> bool {
	for i in 0 ..< move_list.count {
		move := move_list.moves[i]
		if !is_quiet_knight_move(move) {
			continue
		}
		if is_legal_root_move(b, move) {
			return true
		}
	}
	return false
}

has_late_quiet_knight_bishop_net_material :: proc(b: ^board.Board) -> bool {
	if b.fullmove_number < 30 || non_pawn_piece_count(b) != 6 {
		return false
	}
	if b.bitboards[constants.QUEEN] != 0 || b.bitboards[constants.QUEEN + 6] != 0 {
		return false
	}

	side_offset := b.side * 6
	enemy_offset := (1 - b.side) * 6
	return b.bitboards[side_offset + constants.KNIGHT] != 0 &&
	       b.bitboards[side_offset + constants.BISHOP] != 0 &&
	       b.bitboards[side_offset + constants.ROOK] != 0 &&
	       b.bitboards[enemy_offset + constants.ROOK] != 0 &&
	       utils.count_bits(b.bitboards[enemy_offset + constants.BISHOP]) >= 2
}

has_late_quiet_rook_bishop_net_material :: proc(b: ^board.Board) -> bool {
	if b.fullmove_number < 28 || b.fullmove_number > 34 || non_pawn_piece_count(b) != 6 {
		return false
	}
	if b.bitboards[constants.QUEEN] != 0 || b.bitboards[constants.QUEEN + 6] != 0 {
		return false
	}

	side_offset := b.side * 6
	enemy_offset := (1 - b.side) * 6
	return b.bitboards[side_offset + constants.ROOK] != 0 &&
	       b.bitboards[side_offset + constants.KNIGHT] != 0 &&
	       b.bitboards[side_offset + constants.BISHOP] != 0 &&
	       b.bitboards[enemy_offset + constants.ROOK] != 0 &&
	       utils.count_bits(b.bitboards[enemy_offset + constants.BISHOP]) >= 2
}

is_root_quiet_developing_knight_move :: proc(b: ^board.Board, move: moves.Move) -> bool {
	if !is_quiet_knight_move(move) {
		return false
	}

	if b.side == constants.WHITE {
		return move.source == 1 || move.source == 6
	}
	return move.source == 57 || move.source == 62
}

has_legal_root_quiet_developing_knight_move :: proc(b: ^board.Board, move_list: ^moves.MoveList) -> bool {
	for i in 0 ..< move_list.count {
		move := move_list.moves[i]
		if !is_root_quiet_developing_knight_move(b, move) {
			continue
		}
		if is_legal_root_move(b, move) {
			return true
		}
	}
	return false
}

has_legal_root_quiet_bishop_move :: proc(b: ^board.Board, move_list: ^moves.MoveList) -> bool {
	for i in 0 ..< move_list.count {
		move := move_list.moves[i]
		if !is_quiet_bishop_move(move) {
			continue
		}
		if is_legal_root_move(b, move) {
			return true
		}
	}
	return false
}

is_root_quiet_developing_bishop_move :: proc(b: ^board.Board, move: moves.Move) -> bool {
	if !is_quiet_bishop_move(move) {
		return false
	}

	if b.side == constants.WHITE {
		return move.source == 2 || move.source == 5
	}
	return move.source == 58 || move.source == 61
}

has_legal_root_quiet_developing_bishop_move :: proc(b: ^board.Board, move_list: ^moves.MoveList) -> bool {
	for i in 0 ..< move_list.count {
		move := move_list.moves[i]
		if !is_root_quiet_developing_bishop_move(b, move) {
			continue
		}
		if is_legal_root_move(b, move) {
			return true
		}
	}
	return false
}

has_legal_root_quiet_rook_move :: proc(b: ^board.Board, move_list: ^moves.MoveList) -> bool {
	for i in 0 ..< move_list.count {
		move := move_list.moves[i]
		if !is_quiet_rook_move(move) {
			continue
		}
		if is_legal_root_move(b, move) {
			return true
		}
	}
	return false
}

has_legal_root_rook_capture :: proc(b: ^board.Board, move_list: ^moves.MoveList) -> bool {
	for i in 0 ..< move_list.count {
		move := move_list.moves[i]
		if moves.is_empty_move(move) || !move.capture || move.promoted != -1 {
			continue
		}
		if move.piece % 6 != constants.ROOK {
			continue
		}
		if is_legal_root_move(b, move) {
			return true
		}
	}
	return false
}

is_root_rook_capture_enemy_promotion_pawn :: proc(b: ^board.Board, move: moves.Move) -> bool {
	if moves.is_empty_move(move) || !move.capture || move.promoted != -1 {
		return false
	}
	if move.piece % 6 != constants.ROOK {
		return false
	}

	target_bit := u64(1) << u64(move.target)
	if b.side == constants.WHITE {
		if (target_bit & constants.RANK_2) == 0 {
			return false
		}
	} else if (target_bit & constants.RANK_7) == 0 {
		return false
	}

	enemy_pawn_piece := (1 - b.side) * 6 + constants.PAWN
	return (b.bitboards[enemy_pawn_piece] & target_bit) != 0
}

has_legal_root_rook_capture_enemy_promotion_pawn :: proc(b: ^board.Board, move_list: ^moves.MoveList) -> bool {
	for i in 0 ..< move_list.count {
		move := move_list.moves[i]
		if !is_root_rook_capture_enemy_promotion_pawn(b, move) {
			continue
		}
		if is_legal_root_move(b, move) {
			return true
		}
	}
	return false
}

rook_capture_enemy_promotion_pawn_over_rook_capture_replacement :: proc(
	b: ^board.Board,
	move: moves.Move,
) -> (moves.Move, bool) {
	if moves.is_empty_move(move) || !move.capture || move.promoted != -1 {
		return moves.Move{}, false
	}
	if move.piece % 6 != constants.ROOK ||
	   is_root_rook_capture_enemy_promotion_pawn(b, move) ||
	   !has_enemy_pawn_one_step_from_promotion(b) ||
	   non_pawn_piece_count(b) > 8 {
		return moves.Move{}, false
	}
	if !has_non_pawn_material(b, b.side) ||
	   !has_non_pawn_material(b, 1 - b.side) {
		return moves.Move{}, false
	}

	enemy_rook_piece := (1 - b.side) * 6 + constants.ROOK
	target_bit := u64(1) << u64(move.target)
	if (b.bitboards[enemy_rook_piece] & target_bit) == 0 {
		return moves.Move{}, false
	}

	move_list: moves.MoveList
	board.generate_all_moves(b, &move_list)

	replacement := moves.Move{}
	candidate_count := 0
	for i in 0 ..< move_list.count {
		candidate := move_list.moves[i]
		if candidate.source != move.source ||
		   !is_root_rook_capture_enemy_promotion_pawn(b, candidate) {
			continue
		}
		if !is_legal_root_move(b, candidate) {
			continue
		}
		if root_move_allows_opponent_mate_in_one(b, candidate) {
			continue
		}
		candidate_count += 1
		replacement = candidate
	}
	if candidate_count != 1 {
		return moves.Move{}, false
	}

	return replacement, true
}

count_legal_root_quiet_rook_moves :: proc(b: ^board.Board, move_list: ^moves.MoveList) -> int {
	count := 0
	for i in 0 ..< move_list.count {
		move := move_list.moves[i]
		if !is_quiet_rook_move(move) {
			continue
		}
		if is_legal_root_move(b, move) {
			count += 1
		}
	}
	return count
}

is_rook_move_in_root_list :: proc(move_list: ^moves.MoveList, target: moves.Move) -> bool {
	if moves.is_empty_move(target) || target.promoted != -1 {
		return false
	}
	for i in 0 ..< move_list.count {
		move := move_list.moves[i]
		if same_move(move, target) && move.promoted == -1 && move.piece % 6 == constants.ROOK {
			return true
		}
	}
	return false
}

has_enemy_pawn_one_step_from_promotion :: proc(b: ^board.Board) -> bool {
	if b.side == constants.WHITE {
		return (b.bitboards[constants.PAWN + 6] & constants.RANK_2) != 0
	}
	return (b.bitboards[constants.PAWN] & constants.RANK_7) != 0
}

is_root_rook_promotion_square_defense :: proc(b: ^board.Board, move: moves.Move) -> bool {
	if !is_quiet_rook_move(move) {
		return false
	}

	enemy_pawns: u64
	if b.side == constants.WHITE {
		enemy_pawns = b.bitboards[constants.PAWN + 6] & constants.RANK_2
	} else {
		enemy_pawns = b.bitboards[constants.PAWN] & constants.RANK_7
	}
	if enemy_pawns == 0 {
		return false
	}

	source_bit := u64(1) << u64(move.source)
	target_bit := u64(1) << u64(move.target)
	occupancy := (b.occupancies[constants.BOTH] & ~source_bit) | target_bit
	rook_attacks := moves.get_rook_attacks(move.target, occupancy)

	pawns := enemy_pawns
	for pawns != 0 {
		pawn_sq := utils.pop_lsb(&pawns)
		promotion_sq := pawn_sq - 8
		if b.side == constants.BLACK {
			promotion_sq = pawn_sq + 8
		}
		if promotion_sq < 0 || promotion_sq >= 64 {
			continue
		}
		if move.target == promotion_sq {
			return true
		}
		if (rook_attacks & (u64(1) << u64(promotion_sq))) != 0 {
			return true
		}
	}

	return false
}

find_legal_root_quiet_rook_promotion_square_defense :: proc(
	b: ^board.Board,
	move_list: ^moves.MoveList,
	source: int = -1,
) -> moves.Move {
	for i in 0 ..< move_list.count {
		move := move_list.moves[i]
		if source >= 0 && move.source != source {
			continue
		}
		if !is_root_rook_promotion_square_defense(b, move) {
			continue
		}
		if is_legal_root_move(b, move) {
			return move
		}
	}
	return moves.Move{}
}

has_enemy_pawn_close_to_promotion :: proc(b: ^board.Board) -> bool {
	if b.side == constants.WHITE {
		return (b.bitboards[constants.PAWN + 6] & (constants.RANK_2 | constants.RANK_3)) != 0
	}
	return (b.bitboards[constants.PAWN] & (constants.RANK_6 | constants.RANK_7)) != 0
}

restore_timed_rook_advanced_pawn_pressure_moves :: proc(
	set: ^RootVerifyCandidateSet,
	b: ^board.Board,
	move_list: ^moves.MoveList,
	max_count: int = 0,
) {
	count := 0
	for i in 0 ..< set.count {
		if i >= move_list.count {
			break
		}
		if max_count > 0 && count >= max_count {
			break
		}
		move := move_list.moves[i]
		if !is_root_rook_advanced_pawn_pressure(b, move) {
			continue
		}
		if !is_legal_root_move(b, move) {
			continue
		}
		set.include[i] = true
		set.reason[i] = "rook_advanced_pawn_pressure"
		set.priority[i] = ROOT_VERIFY_PRIORITY_CORE + 2 + count
		count += 1
	}
}

restore_timed_nonnegative_root_captures :: proc(
	set: ^RootVerifyCandidateSet,
	b: ^board.Board,
	move_list: ^moves.MoveList,
	max_count: int = 0,
) {
	count := 0
	for i in 0 ..< set.count {
		if i >= move_list.count {
			break
		}
		if max_count > 0 && count >= max_count {
			break
		}
		move := move_list.moves[i]
		if !move.capture {
			continue
		}
		if see_capture(b, move) < 0 {
			continue
		}
		set.include[i] = true
		set.reason[i] = "timed_nonnegative_root_capture"
		set.priority[i] = ROOT_VERIFY_PRIORITY_FORCING + count
		count += 1
	}
}

restore_root_queen_promotions :: proc(
	set: ^RootVerifyCandidateSet,
	move_list: ^moves.MoveList,
	max_count: int = 0,
) {
	count := 0
	for i in 0 ..< set.count {
		if i >= move_list.count {
			break
		}
		if max_count > 0 && count >= max_count {
			break
		}
		move := move_list.moves[i]
		if move.promoted != constants.QUEEN {
			continue
		}
		set.include[i] = true
		set.reason[i] = "root_queen_promotion"
		set.priority[i] = ROOT_VERIFY_PRIORITY_FORCING + count
		count += 1
	}
}

has_root_queen_promotion :: proc(move_list: ^moves.MoveList) -> bool {
	for i in 0 ..< move_list.count {
		if move_list.moves[i].promoted == constants.QUEEN {
			return true
		}
	}
	return false
}

has_rook_only_root_promotion_race_material :: proc(b: ^board.Board) -> bool {
	if non_pawn_piece_count(b) != 2 {
		return false
	}
	if b.bitboards[constants.QUEEN] != 0 ||
	   b.bitboards[constants.QUEEN + 6] != 0 ||
	   b.bitboards[constants.BISHOP] != 0 ||
	   b.bitboards[constants.BISHOP + 6] != 0 ||
	   b.bitboards[constants.KNIGHT] != 0 ||
	   b.bitboards[constants.KNIGHT + 6] != 0 {
		return false
	}

	side_offset := b.side * 6
	enemy_offset := (1 - b.side) * 6
	return utils.count_bits(b.bitboards[side_offset + constants.ROOK]) == 1 &&
	       utils.count_bits(b.bitboards[enemy_offset + constants.ROOK]) == 1
}

is_rook_attacked_root_queen_promotion :: proc(b: ^board.Board, move: moves.Move) -> bool {
	if moves.is_empty_move(move) ||
	   move.promoted == -1 ||
	   move.piece % 6 != constants.PAWN ||
	   !has_rook_only_root_promotion_race_material(b) {
		return false
	}

	source_bit := u64(1) << u64(move.source)
	target_bit := u64(1) << u64(move.target)
	occupancy := (b.occupancies[constants.BOTH] & ~source_bit) | target_bit
	rook_attacks := moves.get_rook_attacks(move.target, occupancy)
	enemy_rooks := b.bitboards[(1 - b.side) * 6 + constants.ROOK]
	return (rook_attacks & enemy_rooks) != 0
}

has_legal_root_quiet_king_promotion_escort :: proc(
	b: ^board.Board,
	move_list: ^moves.MoveList,
	promotion: moves.Move,
) -> bool {
	if moves.is_empty_move(promotion) || promotion.piece % 6 != constants.PAWN {
		return false
	}

	pawn_file := promotion.source % 8
	pawn_rank := promotion.source / 8
	for i in 0 ..< move_list.count {
		move := move_list.moves[i]
		if move.capture || move.promoted != -1 || move.piece % 6 != constants.KING {
			continue
		}

		target_file := move.target % 8
		if target_file < pawn_file - 1 || target_file > pawn_file + 1 {
			continue
		}

		target_rank := move.target / 8
		if b.side == constants.WHITE {
			if target_rank < pawn_rank - 1 {
				continue
			}
		} else if target_rank > pawn_rank + 1 {
			continue
		}

		if is_legal_root_move(b, move) {
			return true
		}
	}
	return false
}

has_legal_root_quiet_nonpromotion_pawn_push :: proc(b: ^board.Board, move_list: ^moves.MoveList) -> bool {
	for i in 0 ..< move_list.count {
		move := move_list.moves[i]
		if move.capture || move.promoted != -1 || move.piece % 6 != constants.PAWN {
			continue
		}
		if is_legal_root_move(b, move) {
			return true
		}
	}
	return false
}

is_root_central_pawn_capture :: proc(move: moves.Move) -> bool {
	if moves.is_empty_move(move) ||
	   !move.capture ||
	   move.promoted != -1 ||
	   move.piece % 6 != constants.PAWN {
		return false
	}

	switch move.target {
	case 27, 28, 35, 36:
		return true // d4, e4, d5, e5
	}
	return false
}

is_root_central_knight_capture :: proc(move: moves.Move) -> bool {
	if moves.is_empty_move(move) ||
	   !move.capture ||
	   move.promoted != -1 ||
	   move.piece % 6 != constants.KNIGHT {
		return false
	}

	switch move.target {
	case 27, 28, 35, 36:
		return true // d4, e4, d5, e5
	}
	return false
}

is_root_quiet_center_pawn_push :: proc(b: ^board.Board, move: moves.Move) -> bool {
	if !is_quiet_pawn_move(b, move) {
		return false
	}
	return move.target == 27 || move.target == 28 || move.target == 35 || move.target == 36
}

has_legal_root_quiet_center_pawn_push :: proc(b: ^board.Board, move_list: ^moves.MoveList) -> bool {
	for i in 0 ..< move_list.count {
		move := move_list.moves[i]
		if !is_root_quiet_center_pawn_push(b, move) {
			continue
		}
		if is_legal_root_move(b, move) {
			return true
		}
	}
	return false
}

is_root_quiet_opening_flank_break :: proc(b: ^board.Board, move: moves.Move) -> bool {
	if !is_quiet_pawn_move(b, move) {
		return false
	}
	switch move.target {
	case 23, 24, 29, 31, 32, 37, 39, 47:
		return true // h3, a4, f4, h4, a5, f5, h5, h6
	}
	return false
}

has_legal_root_quiet_opening_flank_break :: proc(b: ^board.Board, move_list: ^moves.MoveList) -> bool {
	for i in 0 ..< move_list.count {
		move := move_list.moves[i]
		if !is_root_quiet_opening_flank_break(b, move) {
			continue
		}
		if is_legal_root_move(b, move) {
			return true
		}
	}
	return false
}

is_root_black_g_pawn_luft :: proc(b: ^board.Board, move: moves.Move) -> bool {
	return b.side == constants.BLACK &&
	       is_quiet_pawn_move(b, move) &&
	       move.source == 54 &&
	       move.target == 46
}

is_root_black_h_pawn_luft :: proc(b: ^board.Board, move: moves.Move) -> bool {
	return b.side == constants.BLACK &&
	       is_quiet_pawn_move(b, move) &&
	       move.source == 55 &&
	       move.target == 47
}

has_legal_root_black_h_pawn_luft :: proc(b: ^board.Board, move_list: ^moves.MoveList) -> bool {
	for i in 0 ..< move_list.count {
		move := move_list.moves[i]
		if !is_root_black_h_pawn_luft(b, move) {
			continue
		}
		if !is_legal_root_move(b, move) {
			continue
		}
		if root_move_allows_opponent_mate_in_one(b, move) {
			continue
		}
		return true
	}
	return false
}

is_root_quiet_passed_pawn_push :: proc(b: ^board.Board, move: moves.Move) -> bool {
	if !is_quiet_pawn_move(b, move) {
		return false
	}

	target_rank := move.target / 8
	if b.side == constants.WHITE {
		if target_rank < 3 {
			return false
		}
	} else if target_rank > 4 {
		return false
	}

	target_file := move.target % 8
	file_mask := constants.FILE_A << u64(target_file)
	if target_file > 0 {
		file_mask |= constants.FILE_A << u64(target_file - 1)
	}
	if target_file < 7 {
		file_mask |= constants.FILE_A << u64(target_file + 1)
	}

	front_mask: u64
	if b.side == constants.WHITE {
		for rank := target_rank + 1; rank < 8; rank += 1 {
			front_mask |= u64(0xFF) << u64(rank * 8)
		}
	} else {
		for rank := 0; rank < target_rank; rank += 1 {
			front_mask |= u64(0xFF) << u64(rank * 8)
		}
	}

	enemy_pawns := b.bitboards[(1 - b.side) * 6 + constants.PAWN]
	return (enemy_pawns & file_mask & front_mask) == 0
}

has_legal_root_quiet_passed_pawn_push :: proc(b: ^board.Board, move_list: ^moves.MoveList) -> bool {
	for i in 0 ..< move_list.count {
		move := move_list.moves[i]
		if !is_root_quiet_passed_pawn_push(b, move) {
			continue
		}
		if is_legal_root_move(b, move) {
			return true
		}
	}
	return false
}

has_legal_root_quiet_rook_ahead_of_passed_pawn :: proc(b: ^board.Board, move_list: ^moves.MoveList) -> bool {
	for rook_idx in 0 ..< move_list.count {
		rook_move := move_list.moves[rook_idx]
		if !is_quiet_rook_move(rook_move) || !is_legal_root_move(b, rook_move) {
			continue
		}

		rook_file := rook_move.target % 8
		rook_rank := rook_move.target / 8
		for pawn_idx in 0 ..< move_list.count {
			pawn_move := move_list.moves[pawn_idx]
			if !is_root_quiet_passed_pawn_push(b, pawn_move) || !is_legal_root_move(b, pawn_move) {
				continue
			}
			pawn_file := pawn_move.target % 8
			if rook_file != pawn_file {
				continue
			}
			pawn_rank := pawn_move.target / 8
			if (b.side == constants.WHITE && rook_rank > pawn_rank) ||
			   (b.side == constants.BLACK && rook_rank < pawn_rank) {
				return true
			}
		}
	}
	return false
}

has_two_rook_each_endgame_material :: proc(b: ^board.Board) -> bool {
	if non_pawn_piece_count(b) != 4 {
		return false
	}
	if b.bitboards[constants.QUEEN] != 0 ||
	   b.bitboards[constants.QUEEN + 6] != 0 ||
	   b.bitboards[constants.BISHOP] != 0 ||
	   b.bitboards[constants.BISHOP + 6] != 0 ||
	   b.bitboards[constants.KNIGHT] != 0 ||
	   b.bitboards[constants.KNIGHT + 6] != 0 {
		return false
	}

	side_offset := b.side * 6
	enemy_offset := (1 - b.side) * 6
	return utils.count_bits(b.bitboards[side_offset + constants.ROOK]) == 2 &&
	       utils.count_bits(b.bitboards[enemy_offset + constants.ROOK]) == 2
}

has_late_rook_knight_vs_rook_bishop_material :: proc(b: ^board.Board) -> bool {
	if b.fullmove_number < 45 || b.fullmove_number > 60 || non_pawn_piece_count(b) != 4 {
		return false
	}
	if b.bitboards[constants.QUEEN] != 0 || b.bitboards[constants.QUEEN + 6] != 0 {
		return false
	}

	side_offset := b.side * 6
	enemy_offset := (1 - b.side) * 6
	return utils.count_bits(b.bitboards[side_offset + constants.ROOK]) == 1 &&
	       utils.count_bits(b.bitboards[side_offset + constants.KNIGHT]) == 1 &&
	       b.bitboards[side_offset + constants.BISHOP] == 0 &&
	       utils.count_bits(b.bitboards[enemy_offset + constants.ROOK]) == 1 &&
	       utils.count_bits(b.bitboards[enemy_offset + constants.BISHOP]) == 1 &&
	       b.bitboards[enemy_offset + constants.KNIGHT] == 0
}

is_root_advanced_quiet_passed_pawn_push :: proc(b: ^board.Board, move: moves.Move) -> bool {
	if !is_root_quiet_passed_pawn_push(b, move) {
		return false
	}

	target_rank := move.target / 8
	if b.side == constants.WHITE {
		return target_rank >= 5
	}
	return target_rank <= 2
}

is_root_near_promotion_pawn_push :: proc(b: ^board.Board, move: moves.Move) -> bool {
	if moves.is_empty_move(move) || move.capture || move.promoted != -1 {
		return false
	}
	if move.piece % 6 != constants.PAWN {
		return false
	}

	target_bit := u64(1) << u64(move.target)
	if b.side == constants.WHITE {
		return (target_bit & constants.RANK_7) != 0
	}
	return (target_bit & constants.RANK_2) != 0
}

has_legal_root_near_promotion_pawn_push :: proc(b: ^board.Board, move_list: ^moves.MoveList) -> bool {
	for i in 0 ..< move_list.count {
		move := move_list.moves[i]
		if !is_root_near_promotion_pawn_push(b, move) {
			continue
		}
		if is_legal_root_move(b, move) {
			return true
		}
	}
	return false
}

is_root_rook_advanced_pawn_pressure :: proc(b: ^board.Board, move: moves.Move) -> bool {
	if moves.is_empty_move(move) || move.capture || move.promoted != -1 {
		return false
	}
	if move.piece % 6 != constants.ROOK {
		return false
	}

	enemy_side := 1 - b.side
	enemy_pawn_piece := enemy_side * 6 + constants.PAWN
	advanced_mask := constants.RANK_2 | constants.RANK_3
	if b.side == constants.BLACK {
		advanced_mask = constants.RANK_6 | constants.RANK_7
	}
	advanced_pawns := b.bitboards[enemy_pawn_piece] & advanced_mask
	if advanced_pawns == 0 {
		return false
	}

	source_bit := u64(1) << u64(move.source)
	target_bit := u64(1) << u64(move.target)
	occupancy := (b.occupancies[constants.BOTH] & ~source_bit) | target_bit
	return (moves.get_rook_attacks(move.target, occupancy) & advanced_pawns) != 0
}

has_legal_root_rook_advanced_pawn_pressure :: proc(b: ^board.Board, move_list: ^moves.MoveList) -> bool {
	for i in 0 ..< move_list.count {
		move := move_list.moves[i]
		if !is_root_rook_advanced_pawn_pressure(b, move) {
			continue
		}
		if is_legal_root_move(b, move) {
			return true
		}
	}
	return false
}

is_root_quiet_rook_invasion :: proc(b: ^board.Board, move: moves.Move) -> bool {
	if !is_quiet_rook_move(move) {
		return false
	}

	target_bit := u64(1) << u64(move.target)
	if b.side == constants.WHITE {
		return (target_bit & constants.RANK_7) != 0
	}
	return (target_bit & constants.RANK_2) != 0
}

has_legal_root_quiet_rook_invasion :: proc(b: ^board.Board, move_list: ^moves.MoveList) -> bool {
	for i in 0 ..< move_list.count {
		move := move_list.moves[i]
		if !is_root_quiet_rook_invasion(b, move) {
			continue
		}
		if is_legal_root_move(b, move) {
			return true
		}
	}
	return false
}

root_verify_insert_suspect :: proc(result: ^RootVerifySuspectResult, move: moves.Move, score: int, scores: ^[4]int) {
	insert_at := result.count
	for i in 0 ..< result.count {
		if score > scores[i] {
			insert_at = i
			break
		}
	}
	if insert_at >= len(result.moves) {
		return
	}

	limit := result.count
	if limit >= len(result.moves) {
		limit = len(result.moves) - 1
	}
	for i := limit; i > insert_at; i -= 1 {
		result.moves[i] = result.moves[i - 1]
		scores[i] = scores[i - 1]
	}

	result.moves[insert_at] = move
	scores[insert_at] = score
	if result.count < len(result.moves) {
		result.count += 1
	}
}

collect_root_verify_suspect_quiets :: proc(
	st: ^SearchThread,
	b: ^board.Board,
	move_list: ^moves.MoveList,
	depth: int,
	research_pass: ^RootSearchPassResult,
	tt_snapshot: []TTBucket,
	base_candidates: ^RootVerifyCandidateSet,
	timed_budget: bool = false,
) -> RootVerifySuspectResult {
	result: RootVerifySuspectResult
	if depth < ROOT_VERIFY_SUSPECT_MIN_DEPTH {
		return result
	}

	prefilter_offset := ROOT_VERIFY_SUSPECT_PREFILTER_OFFSET
	if timed_budget {
		prefilter_offset = ROOT_VERIFY_TIMED_SUSPECT_PREFILTER_OFFSET
	}
	prefilter_depth := depth - prefilter_offset
	if prefilter_depth < 1 {
		return result
	}

	scores := [4]int{-eval.INF, -eval.INF, -eval.INF, -eval.INF}
	for i in 0 ..< research_pass.count {
		if should_stop_search() {
			break
		}

		entry := research_pass.entries[i]
		if entry.order_index < 1 || entry.order_index > move_list.count {
			continue
		}
		if entry.order_index > ROOT_VERIFY_SUSPECT_ORDER_LIMIT {
			continue
		}

		move_idx := entry.order_index - 1
		if base_candidates.include[move_idx] {
			continue
		}

		move := entry.move
		if move.capture || move.promoted != -1 {
			continue
		}
		if get_history_score(st, move) > 0 {
			continue
		}
		if entry.alpha_before <= -eval.INF / 2 {
			continue
		}
		if entry.score > entry.alpha_before {
			continue
		}

		score := trace_score_root_child_from_snapshot(
			st,
			b,
			move,
			tt_snapshot,
			prefilter_depth,
			-eval.INF,
			eval.INF,
			true,
		)
		result.nodes += score.nodes
		root_verify_insert_suspect(&result, move, score.score, &scores)
	}

	restore_tt(tt_snapshot)
	return result
}

is_legal_root_move :: proc(b: ^board.Board, move: moves.Move) -> bool {
	if !board.is_castling_legal_now(b, move) {
		return false
	}

	state: board.StateInfo
	board.make_move_fast(b, move, &state)
	mover_king_sq := board.get_king_square(b, 1 - b.side)
	opponent_king_sq := board.get_king_square(b, b.side)
	illegal := mover_king_sq < 0 ||
	           opponent_king_sq < 0 ||
	           board.is_square_attacked(b, mover_king_sq, b.side)
	board.unmake_move(b, &state)

	return !illegal
}

trace_root_legal_move :: proc(b: ^board.Board, move: moves.Move) -> bool {
	return is_legal_root_move(b, move)
}

count_legal_root_moves :: proc(b: ^board.Board, move_list: ^moves.MoveList) -> int {
	count := 0
	for i in 0 ..< move_list.count {
		if is_legal_root_move(b, move_list.moves[i]) {
			count += 1
		}
	}
	return count
}

root_move_allows_opponent_mate_in_one :: proc(b: ^board.Board, move: moves.Move) -> bool {
	if moves.is_empty_move(move) || !is_legal_root_move(b, move) {
		return false
	}

	root_state: board.StateInfo
	board.make_move_fast(b, move, &root_state)
	defer board.unmake_move(b, &root_state)

	opponent_moves: moves.MoveList
	board.generate_all_moves(b, &opponent_moves)
	for i in 0 ..< opponent_moves.count {
		opponent_move := opponent_moves.moves[i]
		if !board.is_castling_legal_now(b, opponent_move) {
			continue
		}

		opponent_state: board.StateInfo
		board.make_move_fast(b, opponent_move, &opponent_state)

		opponent_king_sq := board.get_king_square(b, 1 - b.side)
		opponent_move_illegal := opponent_king_sq < 0 ||
		                         board.is_square_attacked(b, opponent_king_sq, b.side)
		if opponent_move_illegal {
			board.unmake_move(b, &opponent_state)
			continue
		}

		mated_king_sq := board.get_king_square(b, b.side)
		in_check := mated_king_sq >= 0 && board.is_square_attacked(b, mated_king_sq, 1 - b.side)
		if in_check {
			reply_moves: moves.MoveList
			board.generate_all_moves(b, &reply_moves)
			if count_legal_root_moves(b, &reply_moves) == 0 {
				board.unmake_move(b, &opponent_state)
				return true
			}
		}

		board.unmake_move(b, &opponent_state)
	}

	return false
}

root_queen_promotion_replacement :: proc(b: ^board.Board, move: moves.Move) -> (moves.Move, bool) {
	if moves.is_empty_move(move) ||
	   (move.promoted != constants.ROOK && move.promoted != constants.BISHOP) {
		return moves.Move{}, false
	}

	queen_move := move
	queen_move.promoted = constants.QUEEN
	if !is_legal_root_move(b, queen_move) {
		return moves.Move{}, false
	}

	state: board.StateInfo
	board.make_move_fast(b, queen_move, &state)

	opponent_king_sq := board.get_king_square(b, b.side)
	opponent_in_check := opponent_king_sq >= 0 &&
	                     board.is_square_attacked(b, opponent_king_sq, 1 - b.side)
	stalemate := false
	if !opponent_in_check {
		reply_moves: moves.MoveList
		board.generate_all_moves(b, &reply_moves)
		stalemate = count_legal_root_moves(b, &reply_moves) == 0
	}

	board.unmake_move(b, &state)
	if stalemate {
		return moves.Move{}, false
	}

	return queen_move, true
}

rook_passer_queen_promotion_stabilizer_replacement :: proc(
	b: ^board.Board,
	move: moves.Move,
) -> (moves.Move, bool) {
	if moves.is_empty_move(move) || b.side != constants.WHITE {
		return moves.Move{}, false
	}
	if b.fullmove_number < 44 || b.fullmove_number > 48 {
		return moves.Move{}, false
	}
	if non_pawn_piece_count(b) != 2 ||
	   !has_non_pawn_material(b, b.side) ||
	   !has_non_pawn_material(b, 1 - b.side) {
		return moves.Move{}, false
	}

	side_offset := b.side * 6
	enemy_offset := (1 - b.side) * 6
	if utils.count_bits(b.bitboards[side_offset + constants.PAWN]) != 4 ||
	   b.bitboards[side_offset + constants.QUEEN] != 0 ||
	   utils.count_bits(b.bitboards[side_offset + constants.ROOK]) != 1 ||
	   b.bitboards[side_offset + constants.BISHOP] != 0 ||
	   b.bitboards[side_offset + constants.KNIGHT] != 0 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.PAWN]) != 1 ||
	   b.bitboards[enemy_offset + constants.QUEEN] != 0 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.ROOK]) != 1 ||
	   b.bitboards[enemy_offset + constants.BISHOP] != 0 ||
	   b.bitboards[enemy_offset + constants.KNIGHT] != 0 {
		return moves.Move{}, false
	}

	if board.get_king_square(b, b.side) != 29 || // f4
	   board.get_king_square(b, 1 - b.side) != 51 { // d7
		return moves.Move{}, false
	}
	if int(b.mailbox[28]) != side_offset + constants.ROOK || // e4
	   int(b.mailbox[33]) != side_offset + constants.PAWN || // b5
	   int(b.mailbox[53]) != side_offset + constants.PAWN || // f7
	   int(b.mailbox[46]) != side_offset + constants.PAWN || // g6
	   int(b.mailbox[31]) != side_offset + constants.PAWN || // h4
	   int(b.mailbox[16]) != enemy_offset + constants.ROOK ||// a3
	   int(b.mailbox[39]) != enemy_offset + constants.PAWN ||// h5
	   int(b.mailbox[61]) != -1 {                            // f8
		return moves.Move{}, false
	}
	if move.source == 53 && move.target == 61 && move.promoted == constants.QUEEN {
		return moves.Move{}, false
	}

	move_list: moves.MoveList
	board.generate_all_moves(b, &move_list)

	replacement := moves.Move{}
	candidate_count := 0
	for i in 0 ..< move_list.count {
		candidate := move_list.moves[i]
		if candidate.source != 53 ||
		   candidate.target != 61 ||
		   candidate.capture ||
		   candidate.promoted != constants.QUEEN ||
		   candidate.piece % 6 != constants.PAWN {
			continue
		}
		if !is_legal_root_move(b, candidate) {
			continue
		}
		candidate_count += 1
		replacement = candidate
	}
	if candidate_count != 1 {
		return moves.Move{}, false
	}

	return replacement, true
}

protected_edge_pair_queen_promotion_replacement :: proc(
	b: ^board.Board,
	move: moves.Move,
) -> (moves.Move, bool) {
	if moves.is_empty_move(move) || b.fullmove_number < 45 || b.castle != 0 || b.en_passant != -1 {
		return moves.Move{}, false
	}

	side_offset := b.side * 6
	enemy_offset := (1 - b.side) * 6
	if utils.count_bits(b.bitboards[side_offset + constants.ROOK]) != 1 ||
	   b.bitboards[side_offset + constants.QUEEN] != 0 ||
	   b.bitboards[side_offset + constants.BISHOP] != 0 ||
	   b.bitboards[side_offset + constants.KNIGHT] != 0 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.ROOK]) != 1 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.QUEEN]) != 1 ||
	   b.bitboards[enemy_offset + constants.BISHOP] != 0 ||
	   b.bitboards[enemy_offset + constants.KNIGHT] != 0 {
		return moves.Move{}, false
	}

	side_pawns := b.bitboards[side_offset + constants.PAWN]
	if utils.count_bits(side_pawns) != 2 {
		return moves.Move{}, false
	}
	promotion_rank := constants.RANK_7
	if b.side == constants.BLACK {
		promotion_rank = constants.RANK_2
	}
	if (side_pawns & promotion_rank) != side_pawns {
		return moves.Move{}, false
	}

	first_sq := utils.get_lsb_index(side_pawns)
	remaining := side_pawns & ~(u64(1) << u64(first_sq))
	second_sq := utils.get_lsb_index(remaining)
	first_file := first_sq % 8
	second_file := second_sq % 8
	if first_file > second_file {
		tmp := first_file
		first_file = second_file
		second_file = tmp
	}
	if !((first_file == 0 && second_file == 1) || (first_file == 6 && second_file == 7)) {
		return moves.Move{}, false
	}

	move_list: moves.MoveList
	board.generate_all_moves(b, &move_list)

	replacement := moves.Move{}
	candidate_count := 0
	for i in 0 ..< move_list.count {
		candidate := move_list.moves[i]
		if candidate.capture ||
		   candidate.promoted != constants.QUEEN ||
		   candidate.piece % 6 != constants.PAWN {
			continue
		}
		target_file := candidate.target % 8
		if target_file == 0 || target_file == 7 {
			continue
		}
		if (side_pawns & (u64(1) << u64(candidate.source))) == 0 {
			continue
		}
		if !is_legal_root_move(b, candidate) {
			continue
		}
		state: board.StateInfo
		board.make_move_fast(b, candidate, &state)
		protected := board.is_square_attacked(b, candidate.target, 1 - b.side)
		board.unmake_move(b, &state)
		if !protected {
			continue
		}
		if root_move_allows_opponent_mate_in_one(b, candidate) {
			continue
		}
		candidate_count += 1
		replacement = candidate
	}
	if candidate_count != 1 || same_move(replacement, move) {
		return moves.Move{}, false
	}

	return replacement, true
}

low_material_king_retreat_replacement :: proc(
	b: ^board.Board,
	move: moves.Move,
	score: int,
) -> (moves.Move, bool) {
	if moves.is_empty_move(move) || !is_quiet_pawn_move(b, move) {
		return moves.Move{}, false
	}
	if score > -params.aspiration_window * 50 || b.fullmove_number < 40 {
		return moves.Move{}, false
	}
	file := move.source % 8
	if file != 0 && file != 7 {
		return moves.Move{}, false
	}
	if has_non_pawn_material(b, b.side) || non_pawn_piece_count(b) != 2 {
		return moves.Move{}, false
	}
	enemy_offset := (1 - b.side) * 6
	if utils.count_bits(b.bitboards[enemy_offset + constants.ROOK]) != 1 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.KNIGHT]) != 1 ||
	   b.bitboards[enemy_offset + constants.BISHOP] != 0 ||
	   b.bitboards[enemy_offset + constants.QUEEN] != 0 {
		return moves.Move{}, false
	}
	side_offset := b.side * 6
	if utils.count_bits(b.bitboards[side_offset + constants.PAWN]) < 2 {
		return moves.Move{}, false
	}

	move_list: moves.MoveList
	board.generate_all_moves(b, &move_list)
	legal_count := 0
	quiet_pawn_count := 0
	quiet_king_count := 0
	king_move := moves.Move{}
	for i in 0 ..< move_list.count {
		candidate := move_list.moves[i]
		if !is_legal_root_move(b, candidate) {
			continue
		}
		legal_count += 1
		if is_quiet_pawn_move(b, candidate) {
			quiet_pawn_count += 1
			if !same_move(candidate, move) {
				return moves.Move{}, false
			}
		} else if is_quiet_king_move(b, candidate) {
			quiet_king_count += 1
			king_move = candidate
		} else {
			return moves.Move{}, false
		}
	}
	if legal_count != 2 || quiet_pawn_count != 1 || quiet_king_count != 1 {
		return moves.Move{}, false
	}
	if king_move.target != 0 && king_move.target != 7 &&
	   king_move.target != 56 && king_move.target != 63 {
		return moves.Move{}, false
	}

	return king_move, true
}

has_enemy_diagonal_pin_to_king :: proc(b: ^board.Board) -> bool {
	king_sq := board.get_king_square(b, b.side)
	if king_sq < 0 {
		return false
	}

	own_offset := b.side * 6
	enemy_offset := (1 - b.side) * 6
	own_pieces := b.bitboards[own_offset + constants.PAWN] |
	              b.bitboards[own_offset + constants.KNIGHT] |
	              b.bitboards[own_offset + constants.BISHOP] |
	              b.bitboards[own_offset + constants.ROOK] |
	              b.bitboards[own_offset + constants.QUEEN]
	enemy_diagonal_sliders := b.bitboards[enemy_offset + constants.BISHOP] |
	                          b.bitboards[enemy_offset + constants.QUEEN]
	occupancy := b.occupancies[constants.BOTH]
	directions := [4]int{9, 7, -7, -9}

	for dir in directions {
		sq := king_sq + dir
		blockers := 0
		for sq >= 0 && sq < 64 {
			prev_sq := sq - dir
			file_delta := (sq % 8) - (prev_sq % 8)
			if file_delta < 0 {
				file_delta = -file_delta
			}
			if file_delta != 1 {
				break
			}

			bit := u64(1) << u64(sq)
			if (occupancy & bit) != 0 {
				if blockers == 0 && (own_pieces & bit) != 0 {
					blockers = 1
				} else if blockers == 1 && (enemy_diagonal_sliders & bit) != 0 {
					return true
				} else {
					break
				}
			}
			sq += dir
		}
	}

	return false
}

bishop_pin_king_rook_replacement :: proc(
	b: ^board.Board,
	move: moves.Move,
) -> (moves.Move, bool) {
	if moves.is_empty_move(move) || !is_quiet_rook_move(move) {
		return moves.Move{}, false
	}
	if b.fullmove_number < 20 || b.fullmove_number > 40 {
		return moves.Move{}, false
	}
	if non_pawn_piece_count(b) != 8 ||
	   !has_non_pawn_material(b, b.side) ||
	   !has_non_pawn_material(b, 1 - b.side) ||
	   has_enemy_pawn_one_step_from_promotion(b) ||
	   !has_enemy_diagonal_pin_to_king(b) {
		return moves.Move{}, false
	}

	move_list: moves.MoveList
	board.generate_all_moves(b, &move_list)
	if has_root_queen_promotion(&move_list) ||
	   !has_legal_root_queen_capture(b, &move_list) ||
	   count_legal_root_quiet_king_candidates(b, &move_list) != 1 ||
	   count_legal_root_quiet_rook_moves(b, &move_list) < 4 {
		return moves.Move{}, false
	}

	for i in 0 ..< move_list.count {
		candidate := move_list.moves[i]
		if !is_quiet_king_move(b, candidate) {
			continue
		}
		if !is_legal_root_move(b, candidate) {
			continue
		}
		if root_move_allows_opponent_mate_in_one(b, candidate) {
			return moves.Move{}, false
		}
		return candidate, true
	}

	return moves.Move{}, false
}

enemy_queen_near_king :: proc(b: ^board.Board, max_distance: int) -> bool {
	king_sq := board.get_king_square(b, b.side)
	if king_sq < 0 {
		return false
	}

	king_file := king_sq % 8
	king_rank := king_sq / 8
	enemy_queens := b.bitboards[(1 - b.side) * 6 + constants.QUEEN]
	for enemy_queens != 0 {
		queen_sq := utils.pop_lsb(&enemy_queens)
		file_delta := (queen_sq % 8) - king_file
		if file_delta < 0 {
			file_delta = -file_delta
		}
		rank_delta := (queen_sq / 8) - king_rank
		if rank_delta < 0 {
			rank_delta = -rank_delta
		}
		distance := file_delta
		if rank_delta > distance {
			distance = rank_delta
		}
		if distance <= max_distance {
			return true
		}
	}

	return false
}

queen_file_retreat_over_king_replacement :: proc(
	b: ^board.Board,
	move: moves.Move,
) -> (moves.Move, bool) {
	if moves.is_empty_move(move) || !is_quiet_king_move(b, move) {
		return moves.Move{}, false
	}
	if b.fullmove_number < 30 || b.fullmove_number > 45 {
		return moves.Move{}, false
	}
	if non_pawn_piece_count(b) != 6 ||
	   !has_non_pawn_material(b, b.side) ||
	   !has_non_pawn_material(b, 1 - b.side) ||
	   has_enemy_pawn_one_step_from_promotion(b) ||
	   !enemy_queen_near_king(b, 3) {
		return moves.Move{}, false
	}

	side_offset := b.side * 6
	enemy_offset := (1 - b.side) * 6
	if utils.count_bits(b.bitboards[side_offset + constants.QUEEN]) != 1 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.QUEEN]) != 1 ||
	   b.bitboards[side_offset + constants.KNIGHT] != 0 ||
	   b.bitboards[side_offset + constants.BISHOP] != 0 ||
	   b.bitboards[enemy_offset + constants.KNIGHT] != 0 ||
	   b.bitboards[enemy_offset + constants.BISHOP] != 0 ||
	   utils.count_bits(b.bitboards[side_offset + constants.ROOK]) == 0 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.ROOK]) == 0 {
		return moves.Move{}, false
	}

	move_list: moves.MoveList
	board.generate_all_moves(b, &move_list)
	has_promotion := has_root_queen_promotion(&move_list)
	quiet_queen_count := count_legal_root_quiet_queen_moves(b, &move_list)
	quiet_king_count := count_legal_root_quiet_king_candidates(b, &move_list)
	if has_promotion ||
	   quiet_queen_count < 6 ||
	   quiet_king_count < 2 {
		return moves.Move{}, false
	}

	best_candidate := moves.Move{}
	best_distance := 64
	for i in 0 ..< move_list.count {
		candidate := move_list.moves[i]
		if !is_quiet_queen_move(b, candidate) {
			continue
		}
		if candidate.source % 8 != candidate.target % 8 {
			continue
		}
		retreating := false
		distance := candidate.source - candidate.target
		if b.side == constants.WHITE {
			retreating = candidate.target < candidate.source
		} else {
			distance = candidate.target - candidate.source
			retreating = candidate.target > candidate.source
		}
		if !retreating || distance <= 0 || distance >= best_distance {
			continue
		}
		if !is_legal_root_move(b, candidate) {
			continue
		}
		if root_move_allows_opponent_mate_in_one(b, candidate) {
			continue
		}
		best_candidate = candidate
		best_distance = distance
	}
	if moves.is_empty_move(best_candidate) {
		return moves.Move{}, false
	}

	return best_candidate, true
}

rook_move_pins_enemy_minor_to_edge_king :: proc(b: ^board.Board, move: moves.Move) -> bool {
	if !is_quiet_rook_move(move) {
		return false
	}

	enemy_king_sq := board.get_king_square(b, 1 - b.side)
	if enemy_king_sq < 0 {
		return false
	}

	king_file := enemy_king_sq % 8
	king_rank := enemy_king_sq / 8
	if king_file != 0 && king_file != 7 && king_rank != 0 && king_rank != 7 {
		return false
	}

	target_file := move.target % 8
	target_rank := move.target / 8
	dir := 0
	if target_rank == king_rank {
		if target_file < king_file {
			dir = 1
		} else if target_file > king_file {
			dir = -1
		} else {
			return false
		}
	} else if target_file == king_file {
		if target_rank < king_rank {
			dir = 8
		} else if target_rank > king_rank {
			dir = -8
		} else {
			return false
		}
	} else {
		return false
	}

	source_bit := u64(1) << u64(move.source)
	target_bit := u64(1) << u64(move.target)
	occupancy := (b.occupancies[constants.BOTH] & ~source_bit) | target_bit
	enemy_offset := (1 - b.side) * 6
	enemy_minors := b.bitboards[enemy_offset + constants.KNIGHT] |
	                b.bitboards[enemy_offset + constants.BISHOP]

	saw_pinned_minor := false
	for sq := move.target + dir; sq >= 0 && sq < 64; sq += dir {
		if (dir == 1 || dir == -1) && sq / 8 != target_rank {
			return false
		}

		bit := u64(1) << u64(sq)
		if (occupancy & bit) == 0 {
			continue
		}
		if sq == enemy_king_sq {
			return saw_pinned_minor
		}
		if !saw_pinned_minor && (enemy_minors & bit) != 0 {
			saw_pinned_minor = true
			continue
		}
		return false
	}

	return false
}

rook_pin_minor_to_edge_king_replacement :: proc(
	b: ^board.Board,
	move: moves.Move,
) -> (moves.Move, bool) {
	if moves.is_empty_move(move) || !is_quiet_king_move(b, move) {
		return moves.Move{}, false
	}
	if b.fullmove_number < 35 || b.fullmove_number > 50 {
		return moves.Move{}, false
	}
	if non_pawn_piece_count(b) != 6 ||
	   !has_non_pawn_material(b, b.side) ||
	   !has_non_pawn_material(b, 1 - b.side) ||
	   has_enemy_pawn_one_step_from_promotion(b) {
		return moves.Move{}, false
	}

	side_offset := b.side * 6
	enemy_offset := (1 - b.side) * 6
	if utils.count_bits(b.bitboards[side_offset + constants.ROOK]) != 1 ||
	   utils.count_bits(b.bitboards[side_offset + constants.BISHOP]) != 1 ||
	   utils.count_bits(b.bitboards[side_offset + constants.KNIGHT]) != 1 ||
	   b.bitboards[side_offset + constants.QUEEN] != 0 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.ROOK]) != 2 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.KNIGHT]) != 1 ||
	   b.bitboards[enemy_offset + constants.BISHOP] != 0 ||
	   b.bitboards[enemy_offset + constants.QUEEN] != 0 {
		return moves.Move{}, false
	}

	move_list: moves.MoveList
	board.generate_all_moves(b, &move_list)
	if has_root_queen_promotion(&move_list) ||
	   count_legal_root_quiet_king_candidates(b, &move_list) < 2 ||
	   count_legal_root_quiet_rook_moves(b, &move_list) < 4 {
		return moves.Move{}, false
	}

	best_candidate := moves.Move{}
	best_distance := 64
	for i in 0 ..< move_list.count {
		candidate := move_list.moves[i]
		if !rook_move_pins_enemy_minor_to_edge_king(b, candidate) {
			continue
		}
		if !is_legal_root_move(b, candidate) {
			continue
		}
		if root_move_allows_opponent_mate_in_one(b, candidate) {
			continue
		}

		file_delta := candidate.source % 8 - candidate.target % 8
		if file_delta < 0 {
			file_delta = -file_delta
		}
		rank_delta := candidate.source / 8 - candidate.target / 8
		if rank_delta < 0 {
			rank_delta = -rank_delta
		}
		distance := file_delta
		if rank_delta > distance {
			distance = rank_delta
		}
		if distance <= 0 || distance >= best_distance {
			continue
		}

		best_candidate = candidate
		best_distance = distance
	}
	if moves.is_empty_move(best_candidate) {
		return moves.Move{}, false
	}

	return best_candidate, true
}

is_root_queen_bishop_capture_check :: proc(b: ^board.Board, move: moves.Move) -> bool {
	if moves.is_empty_move(move) || !move.capture || move.promoted != -1 {
		return false
	}
	source_piece := int(b.mailbox[move.source])
	target_piece := int(b.mailbox[move.target])
	if source_piece < 0 ||
	   target_piece < 0 ||
	   source_piece % 6 != constants.QUEEN ||
	   target_piece % 6 != constants.BISHOP {
		return false
	}
	if target_piece / 6 == b.side {
		return false
	}
	if !board.is_castling_legal_now(b, move) {
		return false
	}

	state: board.StateInfo
	board.make_move_fast(b, move, &state)
	moved_king_sq := board.get_king_square(b, 1 - b.side)
	illegal := moved_king_sq < 0 || board.is_square_attacked(b, moved_king_sq, b.side)
	gives_check := !illegal && move_gives_check_after_make(b)
	board.unmake_move(b, &state)
	return gives_check
}

queen_bishop_capture_check_replacement :: proc(
	b: ^board.Board,
	move: moves.Move,
) -> (moves.Move, bool) {
	if moves.is_empty_move(move) || !is_root_quiet_queen_check(b, move) {
		return moves.Move{}, false
	}
	if b.fullmove_number < 35 || b.fullmove_number > 50 {
		return moves.Move{}, false
	}
	if non_pawn_piece_count(b) != 7 ||
	   !has_non_pawn_material(b, b.side) ||
	   !has_non_pawn_material(b, 1 - b.side) ||
	   has_enemy_pawn_one_step_from_promotion(b) {
		return moves.Move{}, false
	}

	side_offset := b.side * 6
	enemy_offset := (1 - b.side) * 6
	if utils.count_bits(b.bitboards[side_offset + constants.QUEEN]) != 1 ||
	   utils.count_bits(b.bitboards[side_offset + constants.ROOK]) != 1 ||
	   utils.count_bits(b.bitboards[side_offset + constants.KNIGHT]) != 1 ||
	   b.bitboards[side_offset + constants.BISHOP] != 0 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.QUEEN]) != 1 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.ROOK]) != 1 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.KNIGHT]) != 1 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.BISHOP]) != 1 {
		return moves.Move{}, false
	}

	move_list: moves.MoveList
	board.generate_all_moves(b, &move_list)
	if has_root_queen_promotion(&move_list) {
		return moves.Move{}, false
	}

	quiet_queen_checks := 0
	candidate_count := 0
	replacement := moves.Move{}
	for i in 0 ..< move_list.count {
		candidate := move_list.moves[i]
		if is_root_quiet_queen_check(b, candidate) {
			quiet_queen_checks += 1
		}
		if candidate.source != move.source ||
		   !is_root_queen_bishop_capture_check(b, candidate) {
			continue
		}
		if !is_legal_root_move(b, candidate) {
			continue
		}
		candidate_count += 1
		replacement = candidate
	}
	if quiet_queen_checks != 1 || candidate_count != 1 {
		return moves.Move{}, false
	}

	return replacement, true
}

near_promotion_pawn_over_rook_replacement :: proc(
	b: ^board.Board,
	move: moves.Move,
) -> (moves.Move, bool) {
	if moves.is_empty_move(move) || !is_quiet_rook_move(move) {
		return moves.Move{}, false
	}
	if b.fullmove_number < 35 || b.fullmove_number > 55 {
		return moves.Move{}, false
	}
	if non_pawn_piece_count(b) != 7 ||
	   !has_non_pawn_material(b, b.side) ||
	   !has_non_pawn_material(b, 1 - b.side) ||
	   has_enemy_pawn_one_step_from_promotion(b) {
		return moves.Move{}, false
	}

	side_offset := b.side * 6
	enemy_offset := (1 - b.side) * 6
	if utils.count_bits(b.bitboards[side_offset + constants.QUEEN]) != 1 ||
	   utils.count_bits(b.bitboards[side_offset + constants.ROOK]) != 2 ||
	   b.bitboards[side_offset + constants.KNIGHT] != 0 ||
	   b.bitboards[side_offset + constants.BISHOP] != 0 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.QUEEN]) != 1 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.ROOK]) != 1 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.KNIGHT]) != 1 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.BISHOP]) != 1 {
		return moves.Move{}, false
	}

	move_list: moves.MoveList
	board.generate_all_moves(b, &move_list)

	replacement := moves.Move{}
	candidate_count := 0
	for i in 0 ..< move_list.count {
		candidate := move_list.moves[i]
		if !is_root_near_promotion_pawn_push(b, candidate) {
			continue
		}
		if !is_legal_root_move(b, candidate) {
			continue
		}
		if root_move_allows_opponent_mate_in_one(b, candidate) {
			continue
		}
		candidate_count += 1
		replacement = candidate
	}
	if candidate_count != 1 {
		return moves.Move{}, false
	}

	return replacement, true
}

edge_king_rook_file_replacement :: proc(
	b: ^board.Board,
	move: moves.Move,
) -> (moves.Move, bool) {
	if moves.is_empty_move(move) || !is_root_quiet_knight_rim_move(move) {
		return moves.Move{}, false
	}
	if b.fullmove_number < 35 || b.fullmove_number > 50 {
		return moves.Move{}, false
	}
	if non_pawn_piece_count(b) != 5 ||
	   !has_non_pawn_material(b, b.side) ||
	   !has_non_pawn_material(b, 1 - b.side) ||
	   has_enemy_pawn_one_step_from_promotion(b) {
		return moves.Move{}, false
	}

	side_offset := b.side * 6
	enemy_offset := (1 - b.side) * 6
	if utils.count_bits(b.bitboards[side_offset + constants.ROOK]) != 1 ||
	   utils.count_bits(b.bitboards[side_offset + constants.KNIGHT]) != 1 ||
	   b.bitboards[side_offset + constants.BISHOP] != 0 ||
	   b.bitboards[side_offset + constants.QUEEN] != 0 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.ROOK]) != 1 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.BISHOP]) != 2 ||
	   b.bitboards[enemy_offset + constants.KNIGHT] != 0 ||
	   b.bitboards[enemy_offset + constants.QUEEN] != 0 {
		return moves.Move{}, false
	}

	king_sq := board.get_king_square(b, b.side)
	if king_sq < 0 {
		return moves.Move{}, false
	}
	king_file := king_sq % 8
	target_file := -1
	if king_file == 0 {
		target_file = 1
	} else if king_file == 7 {
		target_file = 6
	} else {
		return moves.Move{}, false
	}

	move_list: moves.MoveList
	board.generate_all_moves(b, &move_list)

	replacement := moves.Move{}
	candidate_count := 0
	for i in 0 ..< move_list.count {
		candidate := move_list.moves[i]
		if !is_quiet_rook_move(candidate) {
			continue
		}
		if candidate.target % 8 != target_file {
			continue
		}
		if !is_legal_root_move(b, candidate) {
			continue
		}
		if root_move_allows_opponent_mate_in_one(b, candidate) {
			continue
		}
		candidate_count += 1
		replacement = candidate
	}
	if candidate_count != 1 {
		return moves.Move{}, false
	}

	return replacement, true
}

own_pawn_attacks_square :: proc(b: ^board.Board, square: int, side: int) -> bool {
	target := u64(1) << u64(square)
	if side == constants.WHITE {
		return (((target >> 9) & ~constants.FILE_H) & b.bitboards[constants.PAWN]) != 0 ||
		       (((target >> 7) & ~constants.FILE_A) & b.bitboards[constants.PAWN]) != 0
	}
	return (((target << 9) & ~constants.FILE_A) & b.bitboards[constants.PAWN + 6]) != 0 ||
	       (((target << 7) & ~constants.FILE_H) & b.bitboards[constants.PAWN + 6]) != 0
}

square_distance :: proc(a: int, b_sq: int) -> int {
	file_delta := a % 8 - b_sq % 8
	if file_delta < 0 {
		file_delta = -file_delta
	}
	rank_delta := a / 8 - b_sq / 8
	if rank_delta < 0 {
		rank_delta = -rank_delta
	}
	if rank_delta > file_delta {
		return rank_delta
	}
	return file_delta
}

protected_rook_lift_near_king_replacement :: proc(
	b: ^board.Board,
	move: moves.Move,
) -> (moves.Move, bool) {
	if moves.is_empty_move(move) || !is_quiet_rook_move(move) {
		return moves.Move{}, false
	}
	if move.source / 8 != move.target / 8 {
		return moves.Move{}, false
	}
	if b.fullmove_number < 25 || b.fullmove_number > 40 {
		return moves.Move{}, false
	}
	if non_pawn_piece_count(b) != 6 ||
	   !has_non_pawn_material(b, b.side) ||
	   !has_non_pawn_material(b, 1 - b.side) ||
	   has_enemy_pawn_one_step_from_promotion(b) {
		return moves.Move{}, false
	}

	side_offset := b.side * 6
	enemy_offset := (1 - b.side) * 6
	if utils.count_bits(b.bitboards[side_offset + constants.ROOK]) != 2 ||
	   utils.count_bits(b.bitboards[side_offset + constants.KNIGHT]) != 1 ||
	   b.bitboards[side_offset + constants.BISHOP] != 0 ||
	   b.bitboards[side_offset + constants.QUEEN] != 0 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.ROOK]) != 2 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.BISHOP]) != 1 ||
	   b.bitboards[enemy_offset + constants.KNIGHT] != 0 ||
	   b.bitboards[enemy_offset + constants.QUEEN] != 0 {
		return moves.Move{}, false
	}

	enemy_king_sq := board.get_king_square(b, 1 - b.side)
	if enemy_king_sq < 0 {
		return moves.Move{}, false
	}

	move_list: moves.MoveList
	board.generate_all_moves(b, &move_list)
	if has_root_queen_promotion(&move_list) {
		return moves.Move{}, false
	}

	source_rank := move.source / 8
	source_file := move.source % 8
	replacement := moves.Move{}
	candidate_count := 0
	for i in 0 ..< move_list.count {
		candidate := move_list.moves[i]
		if candidate.source != move.source || !is_quiet_rook_move(candidate) {
			continue
		}
		if candidate.target % 8 != source_file {
			continue
		}
		target_rank := candidate.target / 8
		rank_delta := target_rank - source_rank
		if b.side == constants.BLACK {
			rank_delta = -rank_delta
		}
		if rank_delta <= 0 || rank_delta > 2 {
			continue
		}
		if !own_pawn_attacks_square(b, candidate.target, b.side) {
			continue
		}
		if square_distance(candidate.target, enemy_king_sq) > 2 {
			continue
		}
		if !is_legal_root_move(b, candidate) {
			continue
		}
		if root_move_allows_opponent_mate_in_one(b, candidate) {
			continue
		}
		candidate_count += 1
		replacement = candidate
	}
	if candidate_count != 1 {
		return moves.Move{}, false
	}

	return replacement, true
}

is_root_quiet_rook_check :: proc(b: ^board.Board, move: moves.Move) -> bool {
	if !is_quiet_rook_move(move) {
		return false
	}
	if !board.is_castling_legal_now(b, move) {
		return false
	}

	state: board.StateInfo
	board.make_move_fast(b, move, &state)
	moved_king_sq := board.get_king_square(b, 1 - b.side)
	illegal := moved_king_sq < 0 || board.is_square_attacked(b, moved_king_sq, b.side)
	gives_check := !illegal && move_gives_check_after_make(b)
	board.unmake_move(b, &state)
	return gives_check
}

rook_check_to_king_file_replacement :: proc(
	b: ^board.Board,
	move: moves.Move,
) -> (moves.Move, bool) {
	if moves.is_empty_move(move) || !is_root_quiet_rook_check(b, move) {
		return moves.Move{}, false
	}
	if move.source / 8 != move.target / 8 {
		return moves.Move{}, false
	}
	if b.fullmove_number < 35 || b.fullmove_number > 45 {
		return moves.Move{}, false
	}
	if non_pawn_piece_count(b) != 4 ||
	   !has_non_pawn_material(b, b.side) ||
	   !has_non_pawn_material(b, 1 - b.side) ||
	   has_enemy_pawn_one_step_from_promotion(b) {
		return moves.Move{}, false
	}

	side_offset := b.side * 6
	enemy_offset := (1 - b.side) * 6
	if utils.count_bits(b.bitboards[side_offset + constants.ROOK]) != 1 ||
	   utils.count_bits(b.bitboards[side_offset + constants.BISHOP]) != 1 ||
	   b.bitboards[side_offset + constants.KNIGHT] != 0 ||
	   b.bitboards[side_offset + constants.QUEEN] != 0 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.QUEEN]) != 1 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.ROOK]) != 1 ||
	   b.bitboards[enemy_offset + constants.BISHOP] != 0 ||
	   b.bitboards[enemy_offset + constants.KNIGHT] != 0 ||
	   b.bitboards[enemy_offset + constants.PAWN] != 0 ||
	   utils.count_bits(b.bitboards[side_offset + constants.PAWN]) < 3 {
		return moves.Move{}, false
	}

	king_sq := board.get_king_square(b, b.side)
	if king_sq < 0 {
		return moves.Move{}, false
	}
	king_file := king_sq % 8
	source_file := move.source % 8
	move_target_file := move.target % 8
	if source_file == king_file ||
	   (king_file - source_file) * (move_target_file - king_file) <= 0 {
		return moves.Move{}, false
	}

	move_list: moves.MoveList
	board.generate_all_moves(b, &move_list)
	if has_root_queen_promotion(&move_list) {
		return moves.Move{}, false
	}

	replacement := moves.Move{}
	candidate_count := 0
	for i in 0 ..< move_list.count {
		candidate := move_list.moves[i]
		if candidate.source != move.source || !is_quiet_rook_move(candidate) {
			continue
		}
		if candidate.target / 8 != move.source / 8 {
			continue
		}
		target_file := candidate.target % 8
		if (target_file - source_file) * (target_file - king_file) >= 0 {
			continue
		}
		if target_file - king_file != 1 && king_file - target_file != 1 {
			continue
		}
		if square_distance(candidate.target, king_sq) > 3 {
			continue
		}
		if is_root_quiet_rook_check(b, candidate) {
			continue
		}
		if !is_legal_root_move(b, candidate) {
			continue
		}
		if root_move_allows_opponent_mate_in_one(b, candidate) {
			continue
		}
		candidate_count += 1
		replacement = candidate
	}
	if candidate_count != 1 {
		return moves.Move{}, false
	}

	return replacement, true
}

king_adjacent_rook_file_defense_replacement :: proc(
	b: ^board.Board,
	move: moves.Move,
) -> (moves.Move, bool) {
	if moves.is_empty_move(move) || !is_quiet_rook_move(move) {
		return moves.Move{}, false
	}
	if move.source % 8 != move.target % 8 {
		return moves.Move{}, false
	}
	if b.fullmove_number < 20 || b.fullmove_number > 35 {
		return moves.Move{}, false
	}
	if non_pawn_piece_count(b) != 5 ||
	   !has_non_pawn_material(b, b.side) ||
	   !has_non_pawn_material(b, 1 - b.side) ||
	   has_enemy_pawn_one_step_from_promotion(b) {
		return moves.Move{}, false
	}

	side_offset := b.side * 6
	enemy_offset := (1 - b.side) * 6
	if utils.count_bits(b.bitboards[side_offset + constants.ROOK]) != 2 ||
	   utils.count_bits(b.bitboards[side_offset + constants.KNIGHT]) != 1 ||
	   b.bitboards[side_offset + constants.BISHOP] != 0 ||
	   b.bitboards[side_offset + constants.QUEEN] != 0 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.QUEEN]) != 1 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.ROOK]) != 1 ||
	   b.bitboards[enemy_offset + constants.BISHOP] != 0 ||
	   b.bitboards[enemy_offset + constants.KNIGHT] != 0 {
		return moves.Move{}, false
	}

	king_sq := board.get_king_square(b, b.side)
	if king_sq < 0 {
		return moves.Move{}, false
	}
	if move.source / 8 != king_sq / 8 {
		return moves.Move{}, false
	}
	source_file := move.source % 8
	king_file := king_sq % 8
	if source_file - king_file != 1 && king_file - source_file != 1 {
		return moves.Move{}, false
	}

	source_rank := move.source / 8
	move_rank_delta := move.target / 8 - source_rank
	if b.side == constants.BLACK {
		move_rank_delta = -move_rank_delta
	}
	if move_rank_delta < 3 {
		return moves.Move{}, false
	}
	if is_root_quiet_rook_check(b, move) {
		return moves.Move{}, false
	}

	move_list: moves.MoveList
	board.generate_all_moves(b, &move_list)
	if has_root_queen_promotion(&move_list) {
		return moves.Move{}, false
	}

	replacement := moves.Move{}
	candidate_count := 0
	for i in 0 ..< move_list.count {
		candidate := move_list.moves[i]
		if candidate.source != move.source || !is_quiet_rook_move(candidate) {
			continue
		}
		if candidate.target % 8 != source_file {
			continue
		}
		candidate_rank_delta := candidate.target / 8 - source_rank
		if b.side == constants.BLACK {
			candidate_rank_delta = -candidate_rank_delta
		}
		if candidate_rank_delta != 1 {
			continue
		}
		if is_root_quiet_rook_check(b, candidate) {
			continue
		}
		if !is_legal_root_move(b, candidate) {
			continue
		}
		if root_move_allows_opponent_mate_in_one(b, candidate) {
			continue
		}
		candidate_count += 1
		replacement = candidate
	}
	if candidate_count != 1 {
		return moves.Move{}, false
	}

	return replacement, true
}

is_root_queen_rook_capture_near_king_check :: proc(
	b: ^board.Board,
	move: moves.Move,
	enemy_king_sq: int,
) -> bool {
	if moves.is_empty_move(move) ||
	   !move.capture ||
	   move.promoted != -1 ||
	   move.piece % 6 != constants.QUEEN {
		return false
	}

	victim := int(b.mailbox[move.target])
	if victim < 0 || victim % 6 != constants.ROOK {
		return false
	}
	if square_distance(move.target, enemy_king_sq) > 1 {
		return false
	}
	if !board.is_castling_legal_now(b, move) {
		return false
	}

	state: board.StateInfo
	board.make_move_fast(b, move, &state)
	mover_king_sq := board.get_king_square(b, 1 - b.side)
	illegal := mover_king_sq < 0 || board.is_square_attacked(b, mover_king_sq, b.side)
	gives_check := !illegal && move_gives_check_after_make(b)
	board.unmake_move(b, &state)
	return gives_check
}

