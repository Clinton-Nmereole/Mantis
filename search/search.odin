	if move.source == 15 && move.target == 31 {
		return moves.Move{}, false
	}

	is_bad_king_step := move.source == 14 &&
	                    move.target == 23 &&
	                    !move.capture &&
	                    move.promoted == -1 &&
	                    move.piece % 6 == constants.KING
	is_bad_bishop_capture := move.source == 41 &&
