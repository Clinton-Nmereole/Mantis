		}
		if root_move_allows_opponent_mate_in_one(b, candidate) {
			continue
		}
		candidate_count += 1
		replacement = candidate
	}
	if candidate_count != 1 {
		return moves.Move{}, false
	}

	return replacement, true
}

h_pawn_clamp_over_a_pawn_push_replacement :: proc(
	b: ^board.Board,
	move: moves.Move,
) -> (moves.Move, bool) {
	if moves.is_empty_move(move) || b.side != constants.BLACK {
		return moves.Move{}, false
	}
	if move.source == 31 && move.target == 23 {
		return moves.Move{}, false
	}
	if move.source != 40 || move.target != 32 {
		return moves.Move{}, false
	}
	if b.fullmove_number < 29 || b.fullmove_number > 33 {
		return moves.Move{}, false
	}
	if non_pawn_piece_count(b) != 6 ||
	   !has_non_pawn_material(b, b.side) ||
	   !has_non_pawn_material(b, 1 - b.side) {
		return moves.Move{}, false
	}

	occupied := (u64(1) << 62) | // black rook g8
	            (u64(1) << 53) | // black pawn f7
	            (u64(1) << 50) | // black king c7
	            (u64(1) << 49) | // black rook b7
	            (u64(1) << 45) | // white pawn f6
	            (u64(1) << 43) | // black bishop d6
