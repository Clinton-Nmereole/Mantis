	   int(b.mailbox[22]) != side_offset + constants.QUEEN ||  // g3
	   int(b.mailbox[2]) != side_offset + constants.ROOK ||    // c1
	   int(b.mailbox[24]) != side_offset + constants.PAWN ||   // a4
	   int(b.mailbox[17]) != side_offset + constants.PAWN ||   // b3
	   int(b.mailbox[21]) != side_offset + constants.PAWN ||   // f3
	   int(b.mailbox[15]) != side_offset + constants.PAWN ||   // h2
	   int(b.mailbox[60]) != enemy_offset + constants.KING ||  // e8
	   int(b.mailbox[35]) != enemy_offset + constants.QUEEN || // d5
	   int(b.mailbox[31]) != enemy_offset + constants.ROOK ||  // h4
	   int(b.mailbox[32]) != enemy_offset + constants.PAWN ||  // a5
	   int(b.mailbox[49]) != enemy_offset + constants.PAWN ||  // b7
	   int(b.mailbox[36]) != enemy_offset + constants.PAWN ||  // e5
	   int(b.mailbox[4]) != -1 ||                              // e1
	   int(b.mailbox[46]) != -1 {                              // g6
		return moves.Move{}, false
	}

	if move.source == 2 && move.target == 4 {
		return moves.Move{}, false
	}
	bad_queen_drift := move.source == 22 &&
	                   move.target == 46 &&
	                   !move.capture &&
	                   move.promoted == -1 &&
	                   move.piece % 6 == constants.QUEEN
	bad_queen_capture := move.source == 22 &&
