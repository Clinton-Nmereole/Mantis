	bad_rook_lift := move.source == 20 &&
	                 move.target == 28 &&
	                 !move.capture &&
	                 move.promoted == -1 &&
	                 move.piece % 6 == constants.ROOK
	bad_rook_pawn_capture := move.source == 20 &&
