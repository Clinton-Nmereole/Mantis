	   int(b.mailbox[43]) != side_offset + constants.BISHOP ||  // d6
	   int(b.mailbox[53]) != side_offset + constants.PAWN ||    // f7
	   int(b.mailbox[40]) != side_offset + constants.PAWN ||    // a6
	   int(b.mailbox[42]) != side_offset + constants.PAWN ||    // c6
	   int(b.mailbox[31]) != side_offset + constants.PAWN ||    // h4
	   int(b.mailbox[7]) != enemy_offset + constants.KING ||    // h1
	   int(b.mailbox[1]) != enemy_offset + constants.ROOK ||    // b1
	   int(b.mailbox[20]) != enemy_offset + constants.BISHOP || // e3
	   int(b.mailbox[5]) != enemy_offset + constants.BISHOP ||  // f1
	   int(b.mailbox[45]) != enemy_offset + constants.PAWN ||   // f6
	   int(b.mailbox[37]) != enemy_offset + constants.PAWN ||   // f5
	   int(b.mailbox[24]) != enemy_offset + constants.PAWN ||   // a4
	   int(b.mailbox[27]) != enemy_offset + constants.PAWN ||   // d4
	   int(b.mailbox[17]) != enemy_offset + constants.PAWN ||   // b3
	   int(b.mailbox[13]) != enemy_offset + constants.PAWN ||   // f2
	   int(b.mailbox[15]) != enemy_offset + constants.PAWN ||   // h2
	   int(b.mailbox[23]) != -1 ||                              // h3
	   int(b.mailbox[32]) != -1 {                                // a5
		return moves.Move{}, false
	}
	move_list: moves.MoveList
	board.generate_all_moves(b, &move_list)

	replacement := moves.Move{}
	candidate_count := 0
	for i in 0 ..< move_list.count {
		candidate := move_list.moves[i]
		if candidate.source != 31 ||
		   candidate.target != 23 ||
		   candidate.capture ||
		   candidate.promoted != -1 ||
		   candidate.piece % 6 != constants.PAWN {
