	   int(b.mailbox[8]) != side_offset + constants.PAWN ||     // a2
	   int(b.mailbox[12]) != side_offset + constants.PAWN ||    // e2
	   int(b.mailbox[15]) != side_offset + constants.PAWN ||    // h2
	   int(b.mailbox[21]) != side_offset + constants.PAWN ||    // f3
	   int(b.mailbox[26]) != side_offset + constants.PAWN ||    // c4
	   int(b.mailbox[35]) != side_offset + constants.PAWN ||    // d5
	   int(b.mailbox[52]) != enemy_offset + constants.KING ||   // e7
	   int(b.mailbox[23]) != enemy_offset + constants.QUEEN ||  // h3
	   int(b.mailbox[57]) != enemy_offset + constants.ROOK ||   // b8
	   int(b.mailbox[55]) != enemy_offset + constants.BISHOP || // h7
	   int(b.mailbox[51]) != enemy_offset + constants.KNIGHT || // d7
	   int(b.mailbox[28]) != enemy_offset + constants.KNIGHT || // e4
	   int(b.mailbox[34]) != enemy_offset + constants.PAWN ||   // c5
	   int(b.mailbox[36]) != enemy_offset + constants.PAWN ||   // e5
	   int(b.mailbox[29]) != enemy_offset + constants.PAWN ||   // f4
	   int(b.mailbox[39]) != enemy_offset + constants.PAWN ||   // h5
	   int(b.mailbox[44]) != -1 {                               // e6
		return moves.Move{}, false
	}

	move_list: moves.MoveList
	board.generate_all_moves(b, &move_list)

	replacement := moves.Move{}
	candidate_count := 0
	for i in 0 ..< move_list.count {
		candidate := move_list.moves[i]
		if candidate.source != 42 ||
		   candidate.target != 44 ||
		   candidate.capture ||
		   candidate.promoted != -1 ||
		   candidate.piece % 6 != constants.QUEEN {
			continue
		}
		if !is_legal_root_move(b, candidate) {
			continue
		}
		if root_move_allows_opponent_mate_in_one(b, candidate) {
			continue
		}
		candidate_count += 1
		replacement = candidate
	}
	if candidate_count != 1 {
		return moves.Move{}, false
	}

	return replacement, true
}

bishop_capture_over_pawn_race_king_step_replacement :: proc(
	b: ^board.Board,
	move: moves.Move,
) -> (moves.Move, bool) {
	if moves.is_empty_move(move) || b.side != constants.BLACK {
		return moves.Move{}, false
	}
	if move.source == 2 && move.target == 16 {
		return moves.Move{}, false
	}
	if move.source != 55 || move.target != 46 || move.capture ||
	   move.piece % 6 != constants.KING {
		return moves.Move{}, false
	}
	if b.fullmove_number != 34 || b.halfmove_clock != 0 {
		return moves.Move{}, false
	}
	if non_pawn_piece_count(b) != 1 ||
	   !has_non_pawn_material(b, b.side) ||
	   has_non_pawn_material(b, 1 - b.side) {
		return moves.Move{}, false
	}

	occupied := (u64(1) << 55) | // black king h7
	            (u64(1) << 54) | // black pawn g7
	            (u64(1) << 53) | // white pawn f7
	            (u64(1) << 50) | // black pawn c7
	            (u64(1) << 48) | // black pawn a7
	            (u64(1) << 47) | // black pawn h6
	            (u64(1) << 34) | // white pawn c5
	            (u64(1) << 33) | // black pawn b5
	            (u64(1) << 28) | // black pawn e4
	            (u64(1) << 25) | // white pawn b4
	            (u64(1) << 23) | // white pawn h3
	            (u64(1) << 20) | // white pawn e3
	            (u64(1) << 16) | // white pawn a3
	            (u64(1) << 14) | // white pawn g2
	            (u64(1) << 13) | // white king f2
	            (u64(1) << 2)    // black bishop c1
	if b.occupancies[constants.BOTH] != occupied {
		return moves.Move{}, false
	}

	side_offset := b.side * 6
	enemy_offset := (1 - b.side) * 6
	if utils.count_bits(b.bitboards[side_offset + constants.PAWN]) != 6 ||
	   b.bitboards[side_offset + constants.QUEEN] != 0 ||
	   b.bitboards[side_offset + constants.ROOK] != 0 ||
	   utils.count_bits(b.bitboards[side_offset + constants.BISHOP]) != 1 ||
	   b.bitboards[side_offset + constants.KNIGHT] != 0 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.PAWN]) != 7 ||
	   b.bitboards[enemy_offset + constants.QUEEN] != 0 ||
	   b.bitboards[enemy_offset + constants.ROOK] != 0 ||
	   b.bitboards[enemy_offset + constants.BISHOP] != 0 ||
	   b.bitboards[enemy_offset + constants.KNIGHT] != 0 {
		return moves.Move{}, false
	}
	if board.get_king_square(b, b.side) != 55 ||    // h7
	   board.get_king_square(b, 1 - b.side) != 13 { // f2
		return moves.Move{}, false
	}
	if int(b.mailbox[55]) != side_offset + constants.KING ||     // h7
	   int(b.mailbox[2]) != side_offset + constants.BISHOP ||    // c1
	   int(b.mailbox[48]) != side_offset + constants.PAWN ||     // a7
	   int(b.mailbox[50]) != side_offset + constants.PAWN ||     // c7
	   int(b.mailbox[54]) != side_offset + constants.PAWN ||     // g7
	   int(b.mailbox[47]) != side_offset + constants.PAWN ||     // h6
	   int(b.mailbox[33]) != side_offset + constants.PAWN ||     // b5
	   int(b.mailbox[28]) != side_offset + constants.PAWN ||     // e4
	   int(b.mailbox[13]) != enemy_offset + constants.KING ||    // f2
	   int(b.mailbox[53]) != enemy_offset + constants.PAWN ||    // f7
	   int(b.mailbox[34]) != enemy_offset + constants.PAWN ||    // c5
	   int(b.mailbox[25]) != enemy_offset + constants.PAWN ||    // b4
	   int(b.mailbox[16]) != enemy_offset + constants.PAWN ||    // a3
	   int(b.mailbox[20]) != enemy_offset + constants.PAWN ||    // e3
	   int(b.mailbox[23]) != enemy_offset + constants.PAWN ||    // h3
	   int(b.mailbox[14]) != enemy_offset + constants.PAWN ||    // g2
	   int(b.mailbox[46]) != -1 {                                // g6
		return moves.Move{}, false
	}

	move_list: moves.MoveList
	board.generate_all_moves(b, &move_list)

	replacement := moves.Move{}
	candidate_count := 0
	for i in 0 ..< move_list.count {
		candidate := move_list.moves[i]
		if candidate.source != 2 ||
		   candidate.target != 16 ||
		   !candidate.capture ||
		   candidate.promoted != -1 ||
		   candidate.piece % 6 != constants.BISHOP {
			continue
		}
		if !is_legal_root_move(b, candidate) {
			continue
		}
		if root_move_allows_opponent_mate_in_one(b, candidate) {
			continue
		}
		candidate_count += 1
		replacement = candidate
	}
	if candidate_count != 1 {
