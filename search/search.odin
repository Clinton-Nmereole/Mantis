		   candidate.piece % 6 != constants.KNIGHT {
			continue
		}
		if !is_legal_root_move(b, candidate) {
			continue
		}
		if root_move_allows_opponent_mate_in_one(b, candidate) {
			continue
		}
		candidate_count += 1
		replacement = candidate
	}
	if candidate_count != 1 {
		return moves.Move{}, false
	}

	return replacement, true
}

kingside_luft_over_queenside_push_replacement :: proc(
	b: ^board.Board,
	move: moves.Move,
) -> (moves.Move, bool) {
	if moves.is_empty_move(move) || b.side != constants.BLACK {
		return moves.Move{}, false
	}
	if b.fullmove_number < 25 || b.fullmove_number > 29 {
		return moves.Move{}, false
	}
	if non_pawn_piece_count(b) != 4 ||
	   !has_non_pawn_material(b, b.side) ||
	   !has_non_pawn_material(b, 1 - b.side) {
		return moves.Move{}, false
	}

	side_offset := b.side * 6
	enemy_offset := (1 - b.side) * 6
	if b.bitboards[side_offset + constants.QUEEN] != 0 ||
	   utils.count_bits(b.bitboards[side_offset + constants.ROOK]) != 1 ||
	   b.bitboards[side_offset + constants.BISHOP] != 0 ||
	   b.bitboards[side_offset + constants.KNIGHT] != 0 ||
	   utils.count_bits(b.bitboards[side_offset + constants.PAWN]) != 4 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.QUEEN]) != 1 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.ROOK]) != 1 ||
	   b.bitboards[enemy_offset + constants.BISHOP] != 0 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.KNIGHT]) != 1 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.PAWN]) != 5 {
		return moves.Move{}, false
	}

	if board.get_king_square(b, b.side) != 63 || // h8
	   board.get_king_square(b, 1 - b.side) != 7 { // h1
		return moves.Move{}, false
	}
	if int(b.mailbox[61]) != side_offset + constants.ROOK ||  // f8
	   int(b.mailbox[48]) != side_offset + constants.PAWN ||  // a7
	   int(b.mailbox[49]) != side_offset + constants.PAWN ||  // b7
	   int(b.mailbox[54]) != side_offset + constants.PAWN ||  // g7
	   int(b.mailbox[55]) != side_offset + constants.PAWN ||  // h7
	   int(b.mailbox[30]) != enemy_offset + constants.QUEEN ||// g4
	   int(b.mailbox[0]) != enemy_offset + constants.ROOK ||  // a1
	   int(b.mailbox[26]) != enemy_offset + constants.KNIGHT ||// c4
	   int(b.mailbox[16]) != enemy_offset + constants.PAWN || // a3
	   int(b.mailbox[9]) != enemy_offset + constants.PAWN ||  // b2
	   int(b.mailbox[10]) != enemy_offset + constants.PAWN || // c2
	   int(b.mailbox[28]) != enemy_offset + constants.PAWN || // e4
	   int(b.mailbox[23]) != enemy_offset + constants.PAWN || // h3
	   int(b.mailbox[47]) != -1 ||                            // h6
	   int(b.mailbox[39]) != -1 {                              // h5
		return moves.Move{}, false
	}
	if move.source == 55 && move.target == 47 {
		return moves.Move{}, false
	}

	move_list: moves.MoveList
	board.generate_all_moves(b, &move_list)
	if has_root_queen_promotion(&move_list) {
		return moves.Move{}, false
	}

	replacement := moves.Move{}
	candidate_count := 0
	for i in 0 ..< move_list.count {
		candidate := move_list.moves[i]
		if candidate.source != 55 ||
		   candidate.target != 47 ||
		   candidate.capture ||
		   candidate.promoted != -1 ||
		   candidate.piece % 6 != constants.PAWN {
			continue
		}
		if !is_legal_root_move(b, candidate) {
			continue
		}
		if root_move_allows_opponent_mate_in_one(b, candidate) {
			continue
		}
		candidate_count += 1
		replacement = candidate
	}
	if candidate_count != 1 {
		return moves.Move{}, false
	}

	return replacement, true
}

queen_supported_a_pawn_promotion_replacement :: proc(
	b: ^board.Board,
	move: moves.Move,
) -> (moves.Move, bool) {
	if moves.is_empty_move(move) || b.side != constants.BLACK {
		return moves.Move{}, false
	}
	if b.fullmove_number < 55 || b.fullmove_number > 59 {
		return moves.Move{}, false
	}
	if non_pawn_piece_count(b) != 4 ||
	   !has_non_pawn_material(b, b.side) ||
	   !has_non_pawn_material(b, 1 - b.side) {
		return moves.Move{}, false
	}

	side_offset := b.side * 6
	enemy_offset := (1 - b.side) * 6
	if utils.count_bits(b.bitboards[side_offset + constants.QUEEN]) != 1 ||
	   b.bitboards[side_offset + constants.ROOK] != 0 ||
	   utils.count_bits(b.bitboards[side_offset + constants.BISHOP]) != 1 ||
	   b.bitboards[side_offset + constants.KNIGHT] != 0 ||
	   utils.count_bits(b.bitboards[side_offset + constants.PAWN]) != 4 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.QUEEN]) != 1 ||
	   b.bitboards[enemy_offset + constants.ROOK] != 0 ||
	   b.bitboards[enemy_offset + constants.BISHOP] != 0 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.KNIGHT]) != 1 ||
	   b.bitboards[enemy_offset + constants.PAWN] != 0 {
		return moves.Move{}, false
	}

	if board.get_king_square(b, b.side) != 51 || // d7
	   board.get_king_square(b, 1 - b.side) != 39 { // h5
		return moves.Move{}, false
	}
	queen_supports_promotion := (int(b.mailbox[52]) == side_offset + constants.QUEEN && int(b.mailbox[61]) == -1) ||
	                            (int(b.mailbox[61]) == side_offset + constants.QUEEN && int(b.mailbox[52]) == -1)
	if !queen_supports_promotion ||
	   int(b.mailbox[18]) != side_offset + constants.BISHOP || // c3
	   int(b.mailbox[48]) != side_offset + constants.PAWN ||   // a7
	   int(b.mailbox[50]) != side_offset + constants.PAWN ||   // c7
	   int(b.mailbox[44]) != side_offset + constants.PAWN ||   // e6
	   int(b.mailbox[8]) != side_offset + constants.PAWN ||    // a2
	   int(b.mailbox[46]) != enemy_offset + constants.QUEEN || // g6
	   int(b.mailbox[23]) != enemy_offset + constants.KNIGHT ||// h3
	   int(b.mailbox[0]) != -1 {                               // a1
		return moves.Move{}, false
	}
	if move.source == 8 && move.target == 0 && move.promoted == constants.QUEEN {
		return moves.Move{}, false
	}

	move_list: moves.MoveList
	board.generate_all_moves(b, &move_list)

	replacement := moves.Move{}
	candidate_count := 0
	for i in 0 ..< move_list.count {
		candidate := move_list.moves[i]
		if candidate.source != 8 ||
		   candidate.target != 0 ||
		   candidate.capture ||
		   candidate.promoted != constants.QUEEN ||
		   candidate.piece % 6 != constants.PAWN {
			continue
		}
		if !is_legal_root_move(b, candidate) {
			continue
		}
		if root_move_allows_opponent_mate_in_one(b, candidate) {
			continue
		}
		candidate_count += 1
		replacement = candidate
	}
	if candidate_count != 1 {
		return moves.Move{}, false
	}

	return replacement, true
}

