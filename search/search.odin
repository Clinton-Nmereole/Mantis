					}
					two_rook_passed_pawn_race_next_depth :=
					   short_clock_passed_pawn_race_recovery_depth > current_depth &&
					   current_depth >= 5 &&
					   current_depth < short_clock_passed_pawn_race_recovery_depth &&
					   !search_limits.is_movetime &&
