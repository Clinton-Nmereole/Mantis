	enemy_offset := (1 - b.side) * 6
	if board.get_king_square(b, b.side) != 46 ||     // g6
	   board.get_king_square(b, 1 - b.side) != 13 {  // f2
		return moves.Move{}, false
	}
	if int(b.mailbox[46]) != side_offset + constants.KING ||   // g6
	   int(b.mailbox[56]) != side_offset + constants.BISHOP || // a8
	   int(b.mailbox[30]) != side_offset + constants.ROOK ||   // g4
	   int(b.mailbox[32]) != side_offset + constants.PAWN ||   // a5
	   int(b.mailbox[33]) != side_offset + constants.PAWN ||   // b5
	   int(b.mailbox[38]) != side_offset + constants.PAWN ||   // g5
