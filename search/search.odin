enemy_advanced_pawns_near_own_king :: proc(b: ^board.Board, min_count: int) -> bool {
	king_sq := board.get_king_square(b, b.side)
	if king_sq < 0 {
		return false
	}

	king_file := king_sq % 8
	file_mask := constants.FILE_A << u64(king_file)
	if king_file > 0 {
		file_mask |= constants.FILE_A << u64(king_file - 1)
	}
	if king_file < 7 {
		file_mask |= constants.FILE_A << u64(king_file + 1)
	}

	advanced_mask := constants.RANK_2 | constants.RANK_3
	if b.side == constants.BLACK {
		advanced_mask = constants.RANK_6 | constants.RANK_7
	}
	enemy_pawns := b.bitboards[(1 - b.side) * 6 + constants.PAWN]
	return utils.count_bits(enemy_pawns & advanced_mask & file_mask) >= min_count
}

promotion_pressure_rook_backrank_replacement :: proc(
	b: ^board.Board,
	move: moves.Move,
) -> (moves.Move, bool) {
	if moves.is_empty_move(move) || !is_quiet_rook_move(move) {
		return moves.Move{}, false
	}
	if b.fullmove_number < 35 || b.fullmove_number > 55 {
		return moves.Move{}, false
	}
	if non_pawn_piece_count(b) != 3 ||
	   !has_non_pawn_material(b, b.side) ||
	   !has_non_pawn_material(b, 1 - b.side) ||
	   !enemy_advanced_pawns_near_own_king(b, 2) {
		return moves.Move{}, false
	}

	side_offset := b.side * 6
	enemy_offset := (1 - b.side) * 6
	if utils.count_bits(b.bitboards[side_offset + constants.ROOK]) != 1 ||
	   b.bitboards[side_offset + constants.QUEEN] != 0 ||
	   b.bitboards[side_offset + constants.BISHOP] != 0 ||
	   b.bitboards[side_offset + constants.KNIGHT] != 0 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.QUEEN]) != 1 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.ROOK]) != 1 ||
	   b.bitboards[enemy_offset + constants.BISHOP] != 0 ||
	   b.bitboards[enemy_offset + constants.KNIGHT] != 0 {
		return moves.Move{}, false
	}

	back_rank := 0
	if b.side == constants.BLACK {
		back_rank = 7
	}
	if move.target / 8 == back_rank {
		return moves.Move{}, false
	}

	source_file := move.source % 8
	move_list: moves.MoveList
	board.generate_all_moves(b, &move_list)
	if has_root_queen_promotion(&move_list) {
		return moves.Move{}, false
	}

	replacement := moves.Move{}
	candidate_count := 0
	for i in 0 ..< move_list.count {
		candidate := move_list.moves[i]
		if candidate.source != move.source || !is_quiet_rook_move(candidate) {
			continue
		}
		if candidate.target % 8 != source_file || candidate.target / 8 != back_rank {
			continue
		}
		if !is_legal_root_move(b, candidate) {
			continue
		}
		if root_move_allows_opponent_mate_in_one(b, candidate) {
			continue
		}
		candidate_count += 1
		replacement = candidate
	}
	if candidate_count != 1 {
		return moves.Move{}, false
	}

	return replacement, true
}

backrank_bishop_battery_replacement :: proc(
	b: ^board.Board,
	move: moves.Move,
) -> (moves.Move, bool) {
	if moves.is_empty_move(move) || b.side != constants.BLACK {
		return moves.Move{}, false
	}
	if b.fullmove_number < 30 || b.fullmove_number > 40 {
		return moves.Move{}, false
	}
	if non_pawn_piece_count(b) != 9 ||
	   !has_non_pawn_material(b, b.side) ||
	   !has_non_pawn_material(b, 1 - b.side) {
		return moves.Move{}, false
	}

	side_offset := b.side * 6
	enemy_offset := (1 - b.side) * 6
	if utils.count_bits(b.bitboards[side_offset + constants.QUEEN]) != 1 ||
	   utils.count_bits(b.bitboards[side_offset + constants.BISHOP]) != 1 ||
	   utils.count_bits(b.bitboards[side_offset + constants.KNIGHT]) != 2 ||
	   b.bitboards[side_offset + constants.ROOK] != 0 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.QUEEN]) != 1 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.ROOK]) != 2 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.BISHOP]) != 1 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.KNIGHT]) != 1 {
		return moves.Move{}, false
	}

	if board.get_king_square(b, b.side) != 52 { // e7
		return moves.Move{}, false
	}
	if int(b.mailbox[47]) != side_offset + constants.BISHOP || // h6
	   int(b.mailbox[61]) != -1 ||                            // f8
	   int(b.mailbox[62]) != enemy_offset + constants.ROOK ||  // g8
	   int(b.mailbox[63]) != enemy_offset + constants.BISHOP ||// h8
	   int(b.mailbox[42]) != enemy_offset + constants.QUEEN || // c6
	   int(b.mailbox[50]) != enemy_offset + constants.KNIGHT { // c7
		return moves.Move{}, false
	}
	if move.source == 47 && move.target == 61 {
		return moves.Move{}, false
	}

	move_list: moves.MoveList
	board.generate_all_moves(b, &move_list)
	if has_root_queen_promotion(&move_list) {
		return moves.Move{}, false
	}

	replacement := moves.Move{}
	candidate_count := 0
	for i in 0 ..< move_list.count {
		candidate := move_list.moves[i]
		if candidate.source != 47 ||
		   candidate.target != 61 ||
		   candidate.capture ||
		   candidate.promoted != -1 ||
		   candidate.piece % 6 != constants.BISHOP {
			continue
		}
		if !is_legal_root_move(b, candidate) {
			continue
		}
		if root_move_allows_opponent_mate_in_one(b, candidate) {
			continue
		}
		candidate_count += 1
		replacement = candidate
	}
	if candidate_count != 1 {
		return moves.Move{}, false
	}

	return replacement, true
}

