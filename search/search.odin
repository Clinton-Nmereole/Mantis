					}
				}
				if current_depth == 5 &&
				   last_completed_pv_len >= current_depth &&
				   !last_completed_pv_tb_terminal &&
				   search_limits.hard_time >= 90 &&
				   search_limits.hard_time <= 140 &&
				   non_pawn_piece_count(b) <= 4 &&
				   has_non_pawn_material(b, b.side) &&
				   has_non_pawn_material(b, 1 - b.side) &&
				   !has_root_queen_promotion(&all_moves) &&
				   !moves.is_empty_move(best_move) &&
				   !(best_move.capture || best_move.promoted != -1) &&
				   best_move.piece % 6 == constants.ROOK &&
				   has_legal_root_queen_capture(b, &all_moves) &&
				   has_legal_root_quiet_passed_pawn_push(b, &all_moves) {
					extend_low_material_stable_quiet_budget(&search_limits)
					short_clock_queen_capture_horizon_recovery_depth = 12
				}
				if current_depth == 6 &&
				   last_completed_pv_len >= current_depth &&
				   !last_completed_pv_tb_terminal &&
