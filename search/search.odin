	desired_source := -1
	desired_target := -1
	desired_piece := constants.PAWN
	bad_source := -1
	bad_target := -1
	bad_piece := constants.PAWN
	matched_layout := false
	for entry in cases {
		matches := true
		for piece in 0 ..< 12 {
