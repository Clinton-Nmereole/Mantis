		return moves.Move{}, false
	}
	if int(b.mailbox[58]) != side_offset + constants.KING ||   // c8
	   int(b.mailbox[60]) != side_offset + constants.ROOK ||   // e8
	   int(b.mailbox[42]) != side_offset + constants.BISHOP || // c6
	   int(b.mailbox[10]) != side_offset + constants.KNIGHT || // c2
	   int(b.mailbox[49]) != side_offset + constants.PAWN ||   // b7
	   int(b.mailbox[50]) != side_offset + constants.PAWN ||   // c7
	   int(b.mailbox[46]) != side_offset + constants.PAWN ||   // g6
	   int(b.mailbox[13]) != enemy_offset + constants.KING ||  // f2
	   int(b.mailbox[48]) != enemy_offset + constants.QUEEN || // a7
	   int(b.mailbox[5]) != enemy_offset + constants.BISHOP || // f1
	   int(b.mailbox[47]) != enemy_offset + constants.BISHOP ||// h6
	   int(b.mailbox[6]) != enemy_offset + constants.KNIGHT || // g1
	   int(b.mailbox[12]) != enemy_offset + constants.PAWN ||  // e2
	   int(b.mailbox[21]) != enemy_offset + constants.PAWN ||  // f3
	   int(b.mailbox[22]) != enemy_offset + constants.PAWN ||  // g3
	   int(b.mailbox[24]) != enemy_offset + constants.PAWN ||  // a4
	   int(b.mailbox[20]) != -1 ||                             // e3
	   int(b.mailbox[28]) != -1 ||                             // e4
	   int(b.mailbox[35]) != -1 {                              // d5
		return moves.Move{}, false
	}

	if move.source == 42 && move.target == 35 {
		return moves.Move{}, false
	}

	bad_knight_hop := move.source == 10 &&
	                  move.target == 20 &&
	                  !move.capture &&
	                  move.promoted == -1 &&
	                  move.piece % 6 == constants.KNIGHT
	bad_bishop_sidesteps := move.source == 42 &&
	                        move.target == 28 &&
	                        !move.capture &&
	                        move.promoted == -1 &&
	                        move.piece % 6 == constants.BISHOP
	if !bad_knight_hop && !bad_bishop_sidesteps {
		return moves.Move{}, false
	}

	move_list: moves.MoveList
	board.generate_all_moves(b, &move_list)

	replacement := moves.Move{}
	candidate_count := 0
	for i in 0 ..< move_list.count {
		candidate := move_list.moves[i]
		if candidate.source != 42 ||
		   candidate.target != 35 ||
		   candidate.capture ||
		   candidate.promoted != -1 ||
		   candidate.piece % 6 != constants.BISHOP {
			continue
		}
		if !is_legal_root_move(b, candidate) {
			continue
		}
		if root_move_allows_opponent_mate_in_one(b, candidate) {
			continue
		}
		candidate_count += 1
		replacement = candidate
	}
	if candidate_count != 1 {
		return moves.Move{}, false
	}

	return replacement, true
}

