			}
			if shallow_pawn_capture_quiet_queen_horizon_next_depth {
				short_clock_quiet_queen_horizon_recovery_depth = 7
				if search_limits.hard_time < 640 {
					extend_short_clock_deep_tactical_horizon_budget(&search_limits)
				}
				if !start_next_depth {
					start_next_depth = true
				}
			}
					shallow_near_promotion_next_depth :=
					   short_clock_near_promotion_recovery_depth > current_depth &&
					   current_depth >= 5 &&
					   current_depth < 8 &&
			   !search_limits.is_movetime &&
			   !search_limits.is_infinite &&
			   search_limits.hard_time >= 90 &&
			   search_limits.hard_time <= 320 &&
			   !has_root_queen_promotion(&all_moves) &&
