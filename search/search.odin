			bad_source = 15, bad_target = 31, bad_piece = constants.PAWN,
			bitboards = [12]u64{
				0x000000000010ef00, 0x0000000000000042, 0x0000000000080004,
				0x0000000000000081, 0x0000000000000008, 0x0000000000000010,
				0x00be014000000000, 0x4200000000000000, 0x2400000000000000,
				0x8100000000000000, 0x0800000000000000, 0x1000000000000000,
			},
		},
		{
			desired_source = 12, desired_target = 28, desired_piece = constants.PAWN,
			bad_source = 6, bad_target = 21, bad_piece = constants.KNIGHT,
			bitboards = [12]u64{
				0x0000000080027d00, 0x0000000000000042, 0x0000000000000024,
				0x0000000000000081, 0x0000000000000008, 0x0000000000000010,
				0x00f5000a00000000, 0x4200000000000000, 0x2400000000000000,
				0x8100000000000000, 0x0800000000000000, 0x1000000000000000,
			},
		},
		{
