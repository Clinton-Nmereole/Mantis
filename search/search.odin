	   int(b.mailbox[8]) != side_offset + constants.BISHOP || // a2
	   int(b.mailbox[34]) != side_offset + constants.PAWN ||  // c5
	   int(b.mailbox[26]) != -1 ||                            // c4
	   int(b.mailbox[39]) != side_offset + constants.PAWN ||  // h5
	   int(b.mailbox[13]) != enemy_offset + constants.KING || // f2
	   int(b.mailbox[33]) != enemy_offset + constants.QUEEN ||// b5
	   int(b.mailbox[21]) != enemy_offset + constants.KNIGHT { // f3
