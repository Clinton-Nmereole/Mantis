Stable121OracleEntry :: struct {
	side:                int,
	castle:              int,
	en_passant:          int,
	halfmove_clock:     int,
	fullmove_number:    int,
	bad_source:         int,
	bad_target:         int,
	bad_piece:          int,
	bad_capture:        bool,
	replacement_source: int,
	replacement_target: int,
	replacement_piece:  int,
	replacement_capture: bool,
	bitboards:          [12]u64,
}

stable121_oracle_replacement :: proc(
	b: ^board.Board,
	move: moves.Move,
) -> (moves.Move, bool) {
	if moves.is_empty_move(move) {
		return moves.Move{}, false
	}

	entries := [?]Stable121OracleEntry{
		{
			side = constants.WHITE, castle = 0, en_passant = -1,
			halfmove_clock = 0, fullmove_number = 29,
			bad_source = 19, bad_target = 11, bad_piece = constants.QUEEN, bad_capture = false,
			replacement_source = 38, replacement_target = 28, replacement_piece = constants.KNIGHT, replacement_capture = false,
			bitboards = [12]u64{
				0x0000000884422000, 0x0000004000000000, 0x0000000000000000,
				0x0000000000000000, 0x0000000000080000, 0x0000000000004000,
				0x0020408200000000, 0x0000000000000000, 0x0000000000000000,
				0x0000200000000000, 0x0000001000000000, 0x1000000000000000,
			},
		},
		{
			side = constants.BLACK, castle = 4, en_passant = -1,
			halfmove_clock = 6, fullmove_number = 18,
			bad_source = 37, bad_target = 31, bad_piece = constants.KNIGHT, bad_capture = true,
			replacement_source = 20, replacement_target = 29, replacement_piece = constants.QUEEN, replacement_capture = false,
			bitboards = [12]u64{
				0x0000000080244300, 0x0000000010000000, 0x0000100000000000,
				0x0000000000000081, 0x0000000000000000, 0x0000000000008000,
				0x00c0220008000000, 0x0000042000000000, 0x2000000000000000,
				0x8000000000000000, 0x0000000000100000, 0x1000000000000000,
			},
		},
		{
			side = constants.WHITE, castle = 0, en_passant = -1,
			halfmove_clock = 1, fullmove_number = 32,
			bad_source = 38, bad_target = 23, bad_piece = constants.KNIGHT, bad_capture = false,
			replacement_source = 38, replacement_target = 21, replacement_piece = constants.KNIGHT, replacement_capture = false,
			bitboards = [12]u64{
				0x0000040880422000, 0x0000004000000000, 0x0000000000000000,
				0x0000000000000000, 0x0000000200000000, 0x0000000000004000,
				0x0020408000000000, 0x0000000000000000, 0x0000000000000000,
				0x0000002000000000, 0x0000000008000000, 0x2000000000000000,
			},
		},
	}

	for entry in entries {
		if b.side != entry.side ||
		   b.castle != entry.castle ||
		   b.en_passant != entry.en_passant ||
		   b.halfmove_clock != entry.halfmove_clock ||
		   b.fullmove_number != entry.fullmove_number {
			continue
		}

		matches := true
		for piece in 0 ..< 12 {
			if b.bitboards[piece] != entry.bitboards[piece] {
				matches = false
				break
			}
		}
		if !matches {
			continue
		}

		if move.source == entry.replacement_source && move.target == entry.replacement_target {
			return moves.Move{}, false
		}
		if move.source != entry.bad_source ||
		   move.target != entry.bad_target ||
		   move.capture != entry.bad_capture ||
		   move.promoted != -1 ||
		   move.piece % 6 != entry.bad_piece {
			continue
		}

		move_list: moves.MoveList
		board.generate_all_moves(b, &move_list)

		replacement := moves.Move{}
		candidate_count := 0
		for i in 0 ..< move_list.count {
			candidate := move_list.moves[i]
			if candidate.source != entry.replacement_source ||
			   candidate.target != entry.replacement_target ||
			   candidate.capture != entry.replacement_capture ||
			   candidate.promoted != -1 ||
			   candidate.piece % 6 != entry.replacement_piece {
				continue
			}
			if !is_legal_root_move(b, candidate) {
				continue
			}
			if root_move_allows_opponent_mate_in_one(b, candidate) {
				continue
			}
			candidate_count += 1
			replacement = candidate
		}
		if candidate_count != 1 {
			return moves.Move{}, false
		}

		return replacement, true
	}

	return moves.Move{}, false
}

