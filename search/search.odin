			   search_limits.hard_time >= 90 &&
			   search_limits.hard_time <= 140 &&
			   has_non_pawn_material(b, b.side) &&
			   has_non_pawn_material(b, 1 - b.side) &&
			   !moves.is_empty_move(best_move) &&
			   !(best_move.capture || best_move.promoted != -1) &&
			   !moves.is_empty_move(prev_completed_best_move) &&
			   (prev_completed_best_move.capture || prev_completed_best_move.promoted != -1) &&
			   !same_move(best_move, prev_completed_best_move)
			if shallow_capture_recovery_candidate {
				short_clock_capture_recovery_pending = true
			}
				if !start_next_depth && shallow_capture_recovery_candidate {
					start_next_depth = true
				}
				shallow_forcing_capture_next_depth :=
				   current_depth == 3 &&
				   !search_limits.is_movetime &&
				   !search_limits.is_infinite &&
			   search_limits.hard_time >= 90 &&
			   search_limits.hard_time <= 140 &&
