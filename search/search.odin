			short_clock_capture_recovery_pending = false
		}
		if short_clock_near_promotion_recovery_depth > 0 &&
		   current_depth >= short_clock_near_promotion_recovery_depth {
			short_clock_near_promotion_recovery_depth = 0
		}
		if short_clock_quiet_queen_horizon_recovery_depth > 0 &&
		   current_depth >= short_clock_quiet_queen_horizon_recovery_depth {
			short_clock_quiet_queen_horizon_recovery_depth = 0
		}
		if short_clock_quiet_rook_horizon_recovery_depth > 0 &&
		   current_depth >= short_clock_quiet_rook_horizon_recovery_depth {
			short_clock_quiet_rook_horizon_recovery_depth = 0
		}
		if short_clock_quiet_knight_horizon_recovery_depth > 0 &&
		   current_depth >= short_clock_quiet_knight_horizon_recovery_depth {
			short_clock_quiet_knight_horizon_recovery_depth = 0
		}
		if short_clock_minor_capture_horizon_recovery_depth > 0 &&
		   current_depth >= short_clock_minor_capture_horizon_recovery_depth {
			short_clock_minor_capture_horizon_recovery_depth = 0
		}
		if short_clock_rook_capture_king_rook_recovery_depth > 0 &&
		   current_depth >= short_clock_rook_capture_king_rook_recovery_depth {
			short_clock_rook_capture_king_rook_recovery_depth = 0
		}
			if short_clock_queen_capture_horizon_recovery_depth > 0 &&
			   current_depth >= short_clock_queen_capture_horizon_recovery_depth {
				short_clock_queen_capture_horizon_recovery_depth = 0
			}
			if short_clock_root_queen_promotion_recovery_depth > 0 &&
