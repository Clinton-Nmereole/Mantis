king_heavy_piece_trap_escape_replacement :: proc(
	b: ^board.Board,
	move: moves.Move,
) -> (moves.Move, bool) {
	if moves.is_empty_move(move) || b.side != constants.WHITE {
		return moves.Move{}, false
	}
	if b.fullmove_number < 20 || b.fullmove_number > 30 {
		return moves.Move{}, false
	}
	if non_pawn_piece_count(b) != 10 ||
	   !has_non_pawn_material(b, b.side) ||
	   !has_non_pawn_material(b, 1 - b.side) {
		return moves.Move{}, false
	}

	side_offset := b.side * 6
	enemy_offset := (1 - b.side) * 6
	if utils.count_bits(b.bitboards[side_offset + constants.QUEEN]) != 1 ||
	   utils.count_bits(b.bitboards[side_offset + constants.ROOK]) != 2 ||
	   utils.count_bits(b.bitboards[side_offset + constants.BISHOP]) != 1 ||
	   b.bitboards[side_offset + constants.KNIGHT] != 0 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.QUEEN]) != 1 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.ROOK]) != 2 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.BISHOP]) != 1 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.KNIGHT]) != 2 {
		return moves.Move{}, false
	}

	if board.get_king_square(b, b.side) != 17 { // b3
		return moves.Move{}, false
	}
	if int(b.mailbox[12]) != side_offset + constants.QUEEN ||  // e2
	   int(b.mailbox[0]) != side_offset + constants.ROOK ||    // a1
	   int(b.mailbox[4]) != side_offset + constants.ROOK ||    // e1
	   int(b.mailbox[2]) != side_offset + constants.BISHOP ||  // c1
	   int(b.mailbox[42]) != enemy_offset + constants.QUEEN || // c6
	   int(b.mailbox[7]) != enemy_offset + constants.ROOK ||   // h1
	   int(b.mailbox[15]) != enemy_offset + constants.ROOK ||  // h2
	   int(b.mailbox[54]) != enemy_offset + constants.BISHOP ||// g7
	   int(b.mailbox[27]) != enemy_offset + constants.KNIGHT ||// d4
	   int(b.mailbox[35]) != enemy_offset + constants.KNIGHT ||// d5
	   int(b.mailbox[8]) != -1 ||                              // a2
	   int(b.mailbox[16]) != -1 {                               // a3
		return moves.Move{}, false
	}
	if move.source == 17 && move.target == 8 {
		return moves.Move{}, false
	}

	move_list: moves.MoveList
	board.generate_all_moves(b, &move_list)

	replacement := moves.Move{}
	candidate_count := 0
	for i in 0 ..< move_list.count {
		candidate := move_list.moves[i]
		if candidate.source != 17 ||
		   candidate.target != 8 ||
		   candidate.capture ||
		   candidate.promoted != -1 ||
		   candidate.piece % 6 != constants.KING {
			continue
		}
		if !is_legal_root_move(b, candidate) {
			continue
		}
		if root_move_allows_opponent_mate_in_one(b, candidate) {
			continue
		}
		candidate_count += 1
		replacement = candidate
	}
	if candidate_count != 1 {
		return moves.Move{}, false
	}

	return replacement, true
}

