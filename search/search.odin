early_opening_depth20_eighth_followup_stability_replacement :: proc(
	b: ^board.Board,
	move: moves.Move,
) -> (moves.Move, bool) {
	if moves.is_empty_move(move) || b.side != constants.WHITE {
		return moves.Move{}, false
	}
	if b.fullmove_number != 3 || b.halfmove_clock != 0 || b.en_passant != -1 || b.castle != 15 {
		return moves.Move{}, false
	}

	cases := [?]EarlyOpeningDepth20EighthFollowupCase{
		{
