	   int(b.mailbox[9]) != side_offset + constants.PAWN ||   // b2
	   int(b.mailbox[12]) != side_offset + constants.PAWN ||  // e2
	   int(b.mailbox[13]) != side_offset + constants.PAWN ||  // f2
	   int(b.mailbox[15]) != side_offset + constants.PAWN ||  // h2
	   int(b.mailbox[22]) != side_offset + constants.PAWN ||  // g3
	   int(b.mailbox[36]) != side_offset + constants.PAWN ||  // e5
	   int(b.mailbox[56]) != enemy_offset + constants.ROOK || // a8
	   int(b.mailbox[63]) != enemy_offset + constants.ROOK || // h8
	   int(b.mailbox[52]) != enemy_offset + constants.QUEEN ||// e7
	   int(b.mailbox[51]) != enemy_offset + constants.KNIGHT ||// d7
	   int(b.mailbox[62]) != enemy_offset + constants.KNIGHT ||// g8
	   int(b.mailbox[40]) != enemy_offset + constants.PAWN || // a6
	   int(b.mailbox[33]) != enemy_offset + constants.PAWN || // b5
	   int(b.mailbox[53]) != enemy_offset + constants.PAWN || // f7
	   int(b.mailbox[38]) != enemy_offset + constants.PAWN || // g5
	   int(b.mailbox[39]) != enemy_offset + constants.PAWN || // h5
	   int(b.mailbox[17]) != -1 {                             // b3
		return moves.Move{}, false
	}
	if move.source == 24 && move.target == 17 {
		return moves.Move{}, false
	}

	move_list: moves.MoveList
	board.generate_all_moves(b, &move_list)
	if has_root_queen_promotion(&move_list) {
		return moves.Move{}, false
	}

	replacement := moves.Move{}
	candidate_count := 0
	for i in 0 ..< move_list.count {
