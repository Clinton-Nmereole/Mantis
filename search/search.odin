			if !start_next_depth && shallow_queen_capture_quiet_knight_next_depth {
				start_next_depth = true
			}
			shallow_pawn_capture_quiet_queen_horizon_next_depth := false
			if current_depth == 6 &&
			   !search_limits.is_movetime &&
			   !search_limits.is_infinite &&
			   search_limits.hard_time >= 90 &&
			   search_limits.hard_time <= 2200 &&
			   last_completed_pv_len >= current_depth &&
			   !last_completed_pv_tb_terminal &&
			   non_pawn_piece_count(b) >= 7 &&
			   non_pawn_piece_count(b) <= 12 &&
			   has_non_pawn_material(b, b.side) &&
			   has_non_pawn_material(b, 1 - b.side) &&
			   !has_root_queen_promotion(&all_moves) &&
			   best_move_changes >= 1 &&
			   largest_score_drop >= params.aspiration_window * 2 &&
			   !moves.is_empty_move(best_move) &&
			   best_move.capture &&
			   best_move.promoted == -1 &&
			   best_move.piece % 6 == constants.PAWN &&
			   count_legal_root_quiet_queen_moves(b, &all_moves) >= 6 {
				victim_piece, _, _ := trace_capture_values(b, best_move)
				shallow_pawn_capture_quiet_queen_horizon_next_depth =
