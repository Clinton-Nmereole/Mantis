	enemy_offset := (1 - b.side) * 6
	if board.get_king_square(b, b.side) != 7 ||      // h1
	   board.get_king_square(b, 1 - b.side) != 62 {  // g8
		return moves.Move{}, false
	}
	if int(b.mailbox[7]) != side_offset + constants.KING ||    // h1
	   int(b.mailbox[3]) != side_offset + constants.ROOK ||    // d1
	   int(b.mailbox[8]) != side_offset + constants.PAWN ||    // a2
