					rook_capture_king_rook_next_depth = victim_piece == constants.PAWN
				}
				if !start_next_depth && rook_capture_king_rook_next_depth {
					start_next_depth = true
				}
				shallow_capture_recovery_candidate :=
				   current_depth == 3 &&
				   !search_limits.is_movetime &&
