bishop_g2_over_king_drift_stability_replacement :: proc(
	b: ^board.Board,
	move: moves.Move,
) -> (moves.Move, bool) {
	if moves.is_empty_move(move) || b.side != constants.WHITE {
		return moves.Move{}, false
	}
	if b.fullmove_number != 56 || b.halfmove_clock != 0 {
		return moves.Move{}, false
	}
	if b.castle != 0 || b.en_passant != -1 {
		return moves.Move{}, false
	}

	expected_bitboards := [12]u64{
		0x0000000000040000, 0x0000000800000000, 0x0000000010000000,
		0x0000000000000000, 0x0000000000000000, 0x0000000000100000,
		0x0000000000004000, 0x0000000000000000, 0x0000000000000000,
		0x0000000000000400, 0x0000000000000000, 0x0020000000000000,
	}
	for piece in 0 ..< 12 {
		if b.bitboards[piece] != expected_bitboards[piece] {
			return moves.Move{}, false
		}
	}

	side_offset := b.side * 6
	enemy_offset := (1 - b.side) * 6
	if board.get_king_square(b, b.side) != 20 ||    // e3
	   board.get_king_square(b, 1 - b.side) != 53 { // f7
		return moves.Move{}, false
	}
	if int(b.mailbox[20]) != side_offset + constants.KING ||   // e3
	   int(b.mailbox[28]) != side_offset + constants.BISHOP || // e4
	   int(b.mailbox[35]) != side_offset + constants.KNIGHT || // d5
	   int(b.mailbox[18]) != side_offset + constants.PAWN ||   // c3
	   int(b.mailbox[53]) != enemy_offset + constants.KING ||  // f7
	   int(b.mailbox[10]) != enemy_offset + constants.ROOK ||  // c2
	   int(b.mailbox[14]) != enemy_offset + constants.PAWN ||  // g2
	   int(b.mailbox[19]) != -1 ||                             // d3
	   int(b.mailbox[21]) != -1 ||                             // f3
	   int(b.mailbox[27]) != -1 {                              // d4
		return moves.Move{}, false
	}

	if move.source == 28 && move.target == 14 {
		return moves.Move{}, false
	}
	bad_king_drift := move.source == 20 &&
	                  (move.target == 19 || move.target == 21 || move.target == 27) &&
	                  !move.capture &&
	                  move.promoted == -1 &&
	                  move.piece % 6 == constants.KING
	if !bad_king_drift {
		return moves.Move{}, false
	}

	move_list: moves.MoveList
	board.generate_all_moves(b, &move_list)

	replacement := moves.Move{}
	candidate_count := 0
	for i in 0 ..< move_list.count {
		candidate := move_list.moves[i]
		if candidate.source != 28 ||
		   candidate.target != 14 ||
		   !candidate.capture ||
		   candidate.promoted != -1 ||
		   candidate.piece % 6 != constants.BISHOP {
			continue
		}
		if !is_legal_root_move(b, candidate) {
			continue
		}
		if root_move_allows_opponent_mate_in_one(b, candidate) {
			continue
		}
		candidate_count += 1
		replacement = candidate
	}
	if candidate_count != 1 {
		return moves.Move{}, false
	}

	return replacement, true
}

