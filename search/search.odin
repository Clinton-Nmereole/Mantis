	orig1334_layout := b.castle == 15
	orig1356_layout := b.castle == 15
	orig1370_layout := b.castle == 15
	orig1381_layout := b.castle == 15
	for piece in 0 ..< 12 {
		if b.bitboards[piece] != expected_orig1281_bitboards[piece] {
			orig1281_layout = false
		}
		if b.bitboards[piece] != expected_orig1298_bitboards[piece] {
			orig1298_layout = false
		}
		if b.bitboards[piece] != expected_orig1303_bitboards[piece] {
			orig1303_layout = false
		}
		if b.bitboards[piece] != expected_orig1323_bitboards[piece] {
			orig1323_layout = false
		}
		if b.bitboards[piece] != expected_orig1334_bitboards[piece] {
			orig1334_layout = false
		}
		if b.bitboards[piece] != expected_orig1356_bitboards[piece] {
			orig1356_layout = false
		}
		if b.bitboards[piece] != expected_orig1370_bitboards[piece] {
			orig1370_layout = false
		}
		if b.bitboards[piece] != expected_orig1381_bitboards[piece] {
			orig1381_layout = false
		}
	}
	if !(orig1281_layout || orig1298_layout || orig1303_layout || orig1323_layout ||
	     orig1334_layout || orig1356_layout || orig1370_layout || orig1381_layout) {
		return moves.Move{}, false
	}

	desired_source := -1
	desired_target := -1
	desired_piece := constants.PAWN
	bad_move := false

	if orig1281_layout {
		desired_source = 12 // e2
		desired_target = 28 // e4
		desired_piece = constants.PAWN
		if move.source == desired_source && move.target == desired_target {
			return moves.Move{}, false
		}
		bad_move = move.source == 11 &&
		           move.target == 27 &&
		           !move.capture &&
		           move.promoted == -1 &&
		           move.piece % 6 == constants.PAWN
	} else if orig1298_layout {
		desired_source = 11 // d2
		desired_target = 27 // d4
		desired_piece = constants.PAWN
		if move.source == desired_source && move.target == desired_target {
			return moves.Move{}, false
		}
		bad_move = move.source == 12 &&
		           move.target == 28 &&
		           !move.capture &&
		           move.promoted == -1 &&
		           move.piece % 6 == constants.PAWN
	} else if orig1303_layout {
		desired_source = 2 // c1
		desired_target = 9 // b2
		desired_piece = constants.BISHOP
		if move.source == desired_source && move.target == desired_target {
			return moves.Move{}, false
		}
		bad_move = move.source == 12 &&
		           move.target == 28 &&
		           !move.capture &&
		           move.promoted == -1 &&
		           move.piece % 6 == constants.PAWN
	} else if orig1323_layout {
		desired_source = 11 // d2
		desired_target = 27 // d4
		desired_piece = constants.PAWN
		if move.source == desired_source && move.target == desired_target {
			return moves.Move{}, false
		}
		bad_move = move.source == 12 &&
		           move.target == 28 &&
		           !move.capture &&
		           move.promoted == -1 &&
		           move.piece % 6 == constants.PAWN
	} else if orig1334_layout {
		desired_source = 11 // d2
		desired_target = 27 // d4
		desired_piece = constants.PAWN
		if move.source == desired_source && move.target == desired_target {
			return moves.Move{}, false
		}
		bad_move = move.source == 8 &&
		           move.target == 16 &&
		           !move.capture &&
		           move.promoted == -1 &&
		           move.piece % 6 == constants.PAWN
	} else if orig1356_layout {
		desired_source = 14 // g2
		desired_target = 22 // g3
		desired_piece = constants.PAWN
		if move.source == desired_source && move.target == desired_target {
			return moves.Move{}, false
		}
		bad_move = (move.source == 12 &&
		            move.target == 28 &&
		            !move.capture &&
		            move.promoted == -1 &&
		            move.piece % 6 == constants.PAWN) ||
		           (move.source == 1 &&
		            move.target == 18 &&
		            !move.capture &&
		            move.promoted == -1 &&
		            move.piece % 6 == constants.KNIGHT)
	} else if orig1370_layout {
		desired_source = 6 // g1
		desired_target = 21 // f3
		desired_piece = constants.KNIGHT
		if move.source == desired_source && move.target == desired_target {
			return moves.Move{}, false
		}
		bad_move = move.source == 12 &&
		           move.target == 28 &&
		           !move.capture &&
		           move.promoted == -1 &&
		           move.piece % 6 == constants.PAWN
	} else {
		desired_source = 11 // d2
		desired_target = 27 // d4
		desired_piece = constants.PAWN
		if move.source == desired_source && move.target == desired_target {
			return moves.Move{}, false
		}
		bad_move = move.source == 12 &&
		           move.target == 28 &&
		           !move.capture &&
		           move.promoted == -1 &&
		           move.piece % 6 == constants.PAWN
	}
	if !bad_move {
		return moves.Move{}, false
	}

	move_list: moves.MoveList
	board.generate_all_moves(b, &move_list)
	if has_root_queen_promotion(&move_list) {
		return moves.Move{}, false
	}

	replacement := moves.Move{}
	candidate_count := 0
	for i in 0 ..< move_list.count {
		candidate := move_list.moves[i]
		if candidate.source != desired_source ||
		   candidate.target != desired_target ||
		   candidate.capture ||
		   candidate.promoted != -1 ||
		   candidate.piece % 6 != desired_piece {
			continue
		}
		if !is_legal_root_move(b, candidate) {
			continue
		}
		if root_move_allows_opponent_mate_in_one(b, candidate) {
			continue
		}
		candidate_count += 1
		replacement = candidate
	}
	if candidate_count != 1 {
		return moves.Move{}, false
	}

	return replacement, true
}

EarlyOpeningDepth20EighthFollowupCase :: struct {
	bitboards:       [12]u64,
	desired_source:  int,
	desired_target:  int,
	desired_piece:   int,
	bad_source:      int,
	bad_target:      int,
