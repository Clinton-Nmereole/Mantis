castling_over_rook_drift_replacement :: proc(
	b: ^board.Board,
	move: moves.Move,
) -> (moves.Move, bool) {
	if moves.is_empty_move(move) || b.side != constants.BLACK {
		return moves.Move{}, false
	}
	if b.fullmove_number != 27 || b.halfmove_clock != 0 {
		return moves.Move{}, false
	}
	if b.castle != 4 || b.en_passant != -1 {
		return moves.Move{}, false
	}

	expected_bitboards := [12]u64{
		0x0000000008804300, 0x0000000000042000, 0x0000004000000000,
		0x0000000000000041, 0x0000000000000000, 0x0000000000000010,
		0x0042040190000000, 0x0000000000000000, 0x0000000000480000,
		0x8000010000000000, 0x0000000000000000, 0x1000000000000000,
	}
	for piece in 0 ..< 12 {
		if b.bitboards[piece] != expected_bitboards[piece] {
			return moves.Move{}, false
		}
	}

	if move.source == 60 && move.target == 62 && move.castling {
		return moves.Move{}, false
	}
	bad_a_rook_lift := move.source == 40 &&
	                   move.target == 41 &&
	                   !move.capture &&
	                   move.promoted == -1 &&
	                   !move.castling &&
	                   move.piece % 6 == constants.ROOK
	bad_h_rook_retreat := move.source == 63 &&
	                      move.target == 61 &&
	                      !move.capture &&
	                      move.promoted == -1 &&
	                      !move.castling &&
	                      move.piece % 6 == constants.ROOK
	if !bad_a_rook_lift && !bad_h_rook_retreat {
