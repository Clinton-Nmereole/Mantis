			continue
		}
		if root_move_allows_opponent_mate_in_one(b, candidate) {
			continue
		}
		candidate_count += 1
		replacement = candidate
	}
	if candidate_count != 1 {
		return moves.Move{}, false
	}

	return replacement, true
}

rook_corner_defense_over_rook_capture_stabilizer_replacement :: proc(
	b: ^board.Board,
	move: moves.Move,
) -> (moves.Move, bool) {
	if moves.is_empty_move(move) || b.side != constants.BLACK {
		return moves.Move{}, false
	}
	if b.fullmove_number != 43 || b.halfmove_clock != 13 {
		return moves.Move{}, false
	}
	if non_pawn_piece_count(b) != 5 ||
	   !has_non_pawn_material(b, b.side) ||
	   !has_non_pawn_material(b, 1 - b.side) {
		return moves.Move{}, false
	}

	side_offset := b.side * 6
	enemy_offset := (1 - b.side) * 6
	if utils.count_bits(b.bitboards[side_offset + constants.PAWN]) != 2 ||
	   utils.count_bits(b.bitboards[side_offset + constants.QUEEN]) != 1 ||
	   utils.count_bits(b.bitboards[side_offset + constants.ROOK]) != 1 ||
	   b.bitboards[side_offset + constants.BISHOP] != 0 ||
	   utils.count_bits(b.bitboards[side_offset + constants.KNIGHT]) != 1 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.PAWN]) != 3 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.QUEEN]) != 1 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.ROOK]) != 1 ||
	   b.bitboards[enemy_offset + constants.BISHOP] != 0 ||
	   b.bitboards[enemy_offset + constants.KNIGHT] != 0 {
		return moves.Move{}, false
	}

	if board.get_king_square(b, b.side) != 36 || // e5
	   board.get_king_square(b, 1 - b.side) != 6 { // g1
		return moves.Move{}, false
	}
	if int(b.mailbox[39]) != side_offset + constants.QUEEN ||  // h5
	   int(b.mailbox[61]) != side_offset + constants.ROOK ||   // f8
	   int(b.mailbox[35]) != side_offset + constants.KNIGHT || // d5
	   int(b.mailbox[40]) != side_offset + constants.PAWN ||   // a6
	   int(b.mailbox[44]) != side_offset + constants.PAWN ||   // e6
	   int(b.mailbox[19]) != enemy_offset + constants.QUEEN || // d3
	   int(b.mailbox[59]) != enemy_offset + constants.ROOK ||  // d8
	   int(b.mailbox[8]) != enemy_offset + constants.PAWN ||   // a2
	   int(b.mailbox[50]) != enemy_offset + constants.PAWN ||  // c7
	   int(b.mailbox[14]) != enemy_offset + constants.PAWN ||  // g2
	   int(b.mailbox[63]) != -1 {                              // h8
		return moves.Move{}, false
	}
	if move.source == 61 && move.target == 63 {
		return moves.Move{}, false
	}

	move_list: moves.MoveList
	board.generate_all_moves(b, &move_list)
	if has_root_queen_promotion(&move_list) {
		return moves.Move{}, false
	}

	replacement := moves.Move{}
	candidate_count := 0
	for i in 0 ..< move_list.count {
		candidate := move_list.moves[i]
		if candidate.source != 61 ||
		   candidate.target != 63 ||
		   candidate.capture ||
		   candidate.promoted != -1 ||
		   candidate.piece % 6 != constants.ROOK {
			continue
		}
		if !is_legal_root_move(b, candidate) {
			continue
		}
		if root_move_allows_opponent_mate_in_one(b, candidate) {
			continue
		}
		candidate_count += 1
		replacement = candidate
	}
	if candidate_count != 1 {
		return moves.Move{}, false
	}

	return replacement, true
}

