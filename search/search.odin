				   has_non_pawn_material(b, 1 - b.side) &&
				   !moves.is_empty_move(prev_completed_best_move) &&
				   is_quiet_king_move(b, prev_completed_best_move) &&
				   !moves.is_empty_move(best_move) &&
				   is_quiet_king_move(b, best_move) &&
				   !same_move(best_move, prev_completed_best_move) {
					quiet_king_legal_moves, all_legal_are_quiet_king := count_legal_root_quiet_king_moves(b, &all_moves)
					quiet_king_fail_low_flip_next_depth =
						all_legal_are_quiet_king &&
						quiet_king_legal_moves == 2
				}
				if !start_next_depth && quiet_king_fail_low_flip_next_depth {
					start_next_depth = true
				}
				rook_capture_king_rook_next_depth := false
				if short_clock_rook_capture_king_rook_recovery_depth > current_depth &&
				   current_depth >= 10 &&
				   current_depth < short_clock_rook_capture_king_rook_recovery_depth &&
				   !search_limits.is_movetime &&
				   !search_limits.is_infinite &&
				   search_limits.hard_time >= 90 &&
				   search_limits.hard_time <= 1600 &&
