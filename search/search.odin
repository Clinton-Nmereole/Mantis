queen_diagonal_retreat_over_corner_probe_replacement :: proc(
	b: ^board.Board,
	move: moves.Move,
) -> (moves.Move, bool) {
	if moves.is_empty_move(move) || b.side != constants.WHITE {
		return moves.Move{}, false
	}
	if b.fullmove_number < 49 || b.fullmove_number > 53 {
		return moves.Move{}, false
	}
	if non_pawn_piece_count(b) != 2 ||
	   !has_non_pawn_material(b, b.side) ||
	   !has_non_pawn_material(b, 1 - b.side) {
		return moves.Move{}, false
	}

	occupied := (u64(1) << 54) | // black king g7
	            (u64(1) << 40) | // white queen a6
	            (u64(1) << 39) | // black pawn h5
	            (u64(1) << 34) | // black pawn c5
	            (u64(1) << 32) | // black pawn a5
	            (u64(1) << 31) | // white pawn h4
	            (u64(1) << 27) | // black queen d4
	            (u64(1) << 24) | // white pawn a4
	            (u64(1) << 22) | // white pawn g3
	            (u64(1) << 21) | // white pawn f3
	            (u64(1) << 17) | // white pawn b3
	            (u64(1) << 16)   // white king a3
	if b.occupancies[constants.BOTH] != occupied {
		return moves.Move{}, false
	}

	side_offset := b.side * 6
	enemy_offset := (1 - b.side) * 6
	if utils.count_bits(b.bitboards[side_offset + constants.PAWN]) != 5 ||
	   utils.count_bits(b.bitboards[side_offset + constants.QUEEN]) != 1 ||
	   b.bitboards[side_offset + constants.ROOK] != 0 ||
	   b.bitboards[side_offset + constants.BISHOP] != 0 ||
	   b.bitboards[side_offset + constants.KNIGHT] != 0 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.PAWN]) != 3 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.QUEEN]) != 1 ||
	   b.bitboards[enemy_offset + constants.ROOK] != 0 ||
	   b.bitboards[enemy_offset + constants.BISHOP] != 0 ||
	   b.bitboards[enemy_offset + constants.KNIGHT] != 0 {
		return moves.Move{}, false
	}
	if board.get_king_square(b, b.side) != 16 ||     // a3
	   board.get_king_square(b, 1 - b.side) != 54 {  // g7
		return moves.Move{}, false
	}
	if int(b.mailbox[40]) != side_offset + constants.QUEEN || // a6
	   int(b.mailbox[16]) != side_offset + constants.KING ||  // a3
	   int(b.mailbox[24]) != side_offset + constants.PAWN ||  // a4
	   int(b.mailbox[17]) != side_offset + constants.PAWN ||  // b3
	   int(b.mailbox[21]) != side_offset + constants.PAWN ||  // f3
	   int(b.mailbox[22]) != side_offset + constants.PAWN ||  // g3
	   int(b.mailbox[31]) != side_offset + constants.PAWN ||  // h4
	   int(b.mailbox[54]) != enemy_offset + constants.KING || // g7
	   int(b.mailbox[27]) != enemy_offset + constants.QUEEN ||// d4
	   int(b.mailbox[32]) != enemy_offset + constants.PAWN || // a5
	   int(b.mailbox[34]) != enemy_offset + constants.PAWN || // c5
	   int(b.mailbox[39]) != enemy_offset + constants.PAWN || // h5
	   int(b.mailbox[5]) != -1 ||                             // f1
	   int(b.mailbox[49]) != -1 {                              // b7
		return moves.Move{}, false
	}
	if move.source == 40 && move.target == 5 {
		return moves.Move{}, false
	}

	move_list: moves.MoveList
	board.generate_all_moves(b, &move_list)

	replacement := moves.Move{}
	candidate_count := 0
	for i in 0 ..< move_list.count {
		candidate := move_list.moves[i]
		if candidate.source != 40 ||
		   candidate.target != 5 ||
		   candidate.capture ||
		   candidate.promoted != -1 ||
		   candidate.piece % 6 != constants.QUEEN {
			continue
		}
		if !is_legal_root_move(b, candidate) {
			continue
		}
		if root_move_allows_opponent_mate_in_one(b, candidate) {
			continue
		}
		candidate_count += 1
		replacement = candidate
	}
	if candidate_count != 1 {
		return moves.Move{}, false
	}

	return replacement, true
}

rook_lift_over_c_pawn_capture_replacement :: proc(
	b: ^board.Board,
	move: moves.Move,
) -> (moves.Move, bool) {
	if moves.is_empty_move(move) || b.side != constants.BLACK {
		return moves.Move{}, false
	}
	if b.fullmove_number < 39 || b.fullmove_number > 43 {
		return moves.Move{}, false
	}
	if non_pawn_piece_count(b) != 6 ||
	   !has_non_pawn_material(b, b.side) ||
	   !has_non_pawn_material(b, 1 - b.side) {
		return moves.Move{}, false
	}

	occupied := (u64(1) << 58) | // black king c8
	            (u64(1) << 54) | // black pawn g7
	            (u64(1) << 43) | // white rook d6
	            (u64(1) << 42) | // black pawn c6
	            (u64(1) << 41) | // black pawn b6
	            (u64(1) << 40) | // black pawn a6
	            (u64(1) << 39) | // black pawn h5
	            (u64(1) << 36) | // black pawn e5
	            (u64(1) << 34) | // black knight c5
	            (u64(1) << 32) | // black bishop a5
	            (u64(1) << 31) | // white pawn h4
	            (u64(1) << 28) | // white pawn e4
	            (u64(1) << 17) | // white knight b3
	            (u64(1) << 16) | // white king a3
	            (u64(1) << 13) | // black rook f2
	            (u64(1) << 10) | // white pawn c2
	            (u64(1) << 3)    // white rook d1
	if b.occupancies[constants.BOTH] != occupied {
		return moves.Move{}, false
	}

	side_offset := b.side * 6
	enemy_offset := (1 - b.side) * 6
	if utils.count_bits(b.bitboards[side_offset + constants.PAWN]) != 6 ||
	   utils.count_bits(b.bitboards[side_offset + constants.ROOK]) != 1 ||
	   utils.count_bits(b.bitboards[side_offset + constants.BISHOP]) != 1 ||
	   utils.count_bits(b.bitboards[side_offset + constants.KNIGHT]) != 1 ||
	   b.bitboards[side_offset + constants.QUEEN] != 0 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.PAWN]) != 3 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.ROOK]) != 2 ||
	   b.bitboards[enemy_offset + constants.BISHOP] != 0 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.KNIGHT]) != 1 ||
	   b.bitboards[enemy_offset + constants.QUEEN] != 0 {
		return moves.Move{}, false
	}
	if board.get_king_square(b, b.side) != 58 ||     // c8
	   board.get_king_square(b, 1 - b.side) != 16 {  // a3
		return moves.Move{}, false
	}
	if int(b.mailbox[58]) != side_offset + constants.KING ||  // c8
	   int(b.mailbox[13]) != side_offset + constants.ROOK ||  // f2
	   int(b.mailbox[32]) != side_offset + constants.BISHOP ||// a5
	   int(b.mailbox[34]) != side_offset + constants.KNIGHT ||// c5
	   int(b.mailbox[40]) != side_offset + constants.PAWN ||  // a6
	   int(b.mailbox[41]) != side_offset + constants.PAWN ||  // b6
	   int(b.mailbox[42]) != side_offset + constants.PAWN ||  // c6
	   int(b.mailbox[36]) != side_offset + constants.PAWN ||  // e5
	   int(b.mailbox[54]) != side_offset + constants.PAWN ||  // g7
	   int(b.mailbox[39]) != side_offset + constants.PAWN ||  // h5
	   int(b.mailbox[16]) != enemy_offset + constants.KING || // a3
	   int(b.mailbox[3]) != enemy_offset + constants.ROOK ||  // d1
	   int(b.mailbox[43]) != enemy_offset + constants.ROOK || // d6
	   int(b.mailbox[17]) != enemy_offset + constants.KNIGHT ||// b3
	   int(b.mailbox[10]) != enemy_offset + constants.PAWN || // c2
	   int(b.mailbox[28]) != enemy_offset + constants.PAWN || // e4
	   int(b.mailbox[31]) != enemy_offset + constants.PAWN || // h4
	   int(b.mailbox[21]) != -1 {                             // f3
		return moves.Move{}, false
	}
	if move.source == 13 && move.target == 21 {
		return moves.Move{}, false
	}

	move_list: moves.MoveList
	board.generate_all_moves(b, &move_list)

	replacement := moves.Move{}
	candidate_count := 0
	for i in 0 ..< move_list.count {
		candidate := move_list.moves[i]
		if candidate.source != 13 ||
		   candidate.target != 21 ||
		   candidate.capture ||
		   candidate.promoted != -1 ||
		   candidate.piece % 6 != constants.ROOK {
			continue
		}
		if !is_legal_root_move(b, candidate) {
			continue
		}
		if root_move_allows_opponent_mate_in_one(b, candidate) {
			continue
		}
		candidate_count += 1
		replacement = candidate
	}
	if candidate_count != 1 {
		return moves.Move{}, false
	}

	return replacement, true
}

rook_lift_over_development_drift_replacement :: proc(
	b: ^board.Board,
	move: moves.Move,
) -> (moves.Move, bool) {
	if moves.is_empty_move(move) || b.side != constants.WHITE {
		return moves.Move{}, false
	}
	if b.fullmove_number < 22 || b.fullmove_number > 26 {
		return moves.Move{}, false
	}
	if non_pawn_piece_count(b) != 10 ||
	   !has_non_pawn_material(b, b.side) ||
	   !has_non_pawn_material(b, 1 - b.side) {
		return moves.Move{}, false
	}

	occupied := (u64(1) << 60) | // black king e8
	            (u64(1) << 56) | // black rook a8
	            (u64(1) << 55) | // black pawn h7
	            (u64(1) << 53) | // black pawn f7
	            (u64(1) << 50) | // black pawn c7
	            (u64(1) << 49) | // black pawn b7
	            (u64(1) << 48) | // black pawn a7
	            (u64(1) << 46) | // black rook g6
	            (u64(1) << 41) | // black bishop b6
	            (u64(1) << 37) | // black bishop f5
	            (u64(1) << 36) | // white pawn e5
	            (u64(1) << 35) | // white pawn d5
	            (u64(1) << 29) | // white pawn f4
	            (u64(1) << 26) | // white queen c4
	            (u64(1) << 24) | // white pawn a4
	            (u64(1) << 22) | // white pawn g3
	            (u64(1) << 21) | // black queen f3
	            (u64(1) << 18) | // white pawn c3
	            (u64(1) << 17) | // white pawn b3
	            (u64(1) << 5)  | // white bishop f1
	            (u64(1) << 4)  | // white king e1
	            (u64(1) << 2)  | // white bishop c1
	            (u64(1) << 1)  | // white knight b1
	            (u64(1) << 0)    // white rook a1
	if b.occupancies[constants.BOTH] != occupied {
		return moves.Move{}, false
	}

	side_offset := b.side * 6
	enemy_offset := (1 - b.side) * 6
	if utils.count_bits(b.bitboards[side_offset + constants.PAWN]) != 7 ||
	   utils.count_bits(b.bitboards[side_offset + constants.QUEEN]) != 1 ||
	   utils.count_bits(b.bitboards[side_offset + constants.ROOK]) != 1 ||
	   utils.count_bits(b.bitboards[side_offset + constants.BISHOP]) != 2 ||
	   utils.count_bits(b.bitboards[side_offset + constants.KNIGHT]) != 1 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.PAWN]) != 5 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.QUEEN]) != 1 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.ROOK]) != 2 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.BISHOP]) != 2 ||
	   b.bitboards[enemy_offset + constants.KNIGHT] != 0 {
		return moves.Move{}, false
	}
	if board.get_king_square(b, b.side) != 4 ||      // e1
	   board.get_king_square(b, 1 - b.side) != 60 {  // e8
		return moves.Move{}, false
	}
	if int(b.mailbox[4]) != side_offset + constants.KING ||    // e1
	   int(b.mailbox[26]) != side_offset + constants.QUEEN ||  // c4
	   int(b.mailbox[0]) != side_offset + constants.ROOK ||    // a1
	   int(b.mailbox[2]) != side_offset + constants.BISHOP ||  // c1
	   int(b.mailbox[5]) != side_offset + constants.BISHOP ||  // f1
	   int(b.mailbox[1]) != side_offset + constants.KNIGHT ||  // b1
	   int(b.mailbox[24]) != side_offset + constants.PAWN ||   // a4
	   int(b.mailbox[17]) != side_offset + constants.PAWN ||   // b3
	   int(b.mailbox[18]) != side_offset + constants.PAWN ||   // c3
	   int(b.mailbox[35]) != side_offset + constants.PAWN ||   // d5
	   int(b.mailbox[36]) != side_offset + constants.PAWN ||   // e5
	   int(b.mailbox[29]) != side_offset + constants.PAWN ||   // f4
	   int(b.mailbox[22]) != side_offset + constants.PAWN ||   // g3
	   int(b.mailbox[60]) != enemy_offset + constants.KING ||  // e8
	   int(b.mailbox[21]) != enemy_offset + constants.QUEEN || // f3
	   int(b.mailbox[56]) != enemy_offset + constants.ROOK ||  // a8
	   int(b.mailbox[46]) != enemy_offset + constants.ROOK ||  // g6
	   int(b.mailbox[41]) != enemy_offset + constants.BISHOP ||// b6
	   int(b.mailbox[37]) != enemy_offset + constants.BISHOP ||// f5
	   int(b.mailbox[48]) != enemy_offset + constants.PAWN ||  // a7
	   int(b.mailbox[49]) != enemy_offset + constants.PAWN ||  // b7
	   int(b.mailbox[50]) != enemy_offset + constants.PAWN ||  // c7
	   int(b.mailbox[53]) != enemy_offset + constants.PAWN ||  // f7
	   int(b.mailbox[55]) != enemy_offset + constants.PAWN ||  // h7
	   int(b.mailbox[8]) != -1 ||                              // a2
	   int(b.mailbox[12]) != -1 ||                             // e2
	   int(b.mailbox[16]) != -1 {                              // a3
		return moves.Move{}, false
	}
	if move.source == 0 && move.target == 8 {
		return moves.Move{}, false
	}

	move_list: moves.MoveList
	board.generate_all_moves(b, &move_list)

	replacement := moves.Move{}
