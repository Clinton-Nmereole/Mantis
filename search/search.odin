	   int(b.mailbox[9]) != enemy_offset + constants.PAWN ||   // b2
	   int(b.mailbox[10]) != enemy_offset + constants.PAWN ||  // c2
	   int(b.mailbox[14]) != enemy_offset + constants.PAWN ||  // g2
	   int(b.mailbox[15]) != enemy_offset + constants.PAWN ||  // h2
	   int(b.mailbox[51]) != -1 {                              // d7
		return moves.Move{}, false
	}
	if move.source == 57 && move.target == 51 {
		return moves.Move{}, false
	}

	move_list: moves.MoveList
	board.generate_all_moves(b, &move_list)
	if has_root_queen_promotion(&move_list) {
		return moves.Move{}, false
	}

	replacement := moves.Move{}
	candidate_count := 0
	for i in 0 ..< move_list.count {
		candidate := move_list.moves[i]
		if candidate.source != 57 ||
		   candidate.target != 51 ||
		   candidate.capture ||
		   candidate.promoted != -1 ||
		   candidate.piece % 6 != constants.KNIGHT {
			continue
		}
		if !is_legal_root_move(b, candidate) {
			continue
		}
		if root_move_allows_opponent_mate_in_one(b, candidate) {
			continue
		}
		candidate_count += 1
		replacement = candidate
	}
	if candidate_count != 1 {
		return moves.Move{}, false
	}

	return replacement, true
}

queen_f5_over_king_retreat_stabilizer_replacement :: proc(
	b: ^board.Board,
	move: moves.Move,
) -> (moves.Move, bool) {
	if moves.is_empty_move(move) || b.side != constants.WHITE {
		return moves.Move{}, false
	}
	if b.fullmove_number != 46 || b.halfmove_clock != 0 {
		return moves.Move{}, false
	}
	if non_pawn_piece_count(b) != 6 ||
	   !has_non_pawn_material(b, b.side) ||
	   !has_non_pawn_material(b, 1 - b.side) {
		return moves.Move{}, false
	}

	side_offset := b.side * 6
	enemy_offset := (1 - b.side) * 6
	if utils.count_bits(b.bitboards[side_offset + constants.PAWN]) != 3 ||
	   utils.count_bits(b.bitboards[side_offset + constants.QUEEN]) != 1 ||
	   b.bitboards[side_offset + constants.ROOK] != 0 ||
	   utils.count_bits(b.bitboards[side_offset + constants.BISHOP]) != 1 ||
	   b.bitboards[side_offset + constants.KNIGHT] != 0 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.PAWN]) != 5 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.QUEEN]) != 1 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.ROOK]) != 2 ||
	   b.bitboards[enemy_offset + constants.BISHOP] != 0 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.KNIGHT]) != 1 {
		return moves.Move{}, false
	}

	if board.get_king_square(b, b.side) != 15 || // h2
	   board.get_king_square(b, 1 - b.side) != 61 { // f8
		return moves.Move{}, false
	}
	if int(b.mailbox[55]) != side_offset + constants.QUEEN ||  // h7
	   int(b.mailbox[31]) != side_offset + constants.BISHOP || // h4
	   int(b.mailbox[13]) != side_offset + constants.PAWN ||   // f2
	   int(b.mailbox[22]) != side_offset + constants.PAWN ||   // g3
	   int(b.mailbox[23]) != side_offset + constants.PAWN ||   // h3
	   int(b.mailbox[43]) != enemy_offset + constants.QUEEN || // d6
	   int(b.mailbox[56]) != enemy_offset + constants.ROOK ||  // a8
	   int(b.mailbox[60]) != enemy_offset + constants.ROOK ||  // e8
	   int(b.mailbox[62]) != enemy_offset + constants.KNIGHT ||// g8
	   int(b.mailbox[48]) != enemy_offset + constants.PAWN ||  // a7
	   int(b.mailbox[17]) != enemy_offset + constants.PAWN ||  // b3
	   int(b.mailbox[42]) != enemy_offset + constants.PAWN ||  // c6
	   int(b.mailbox[28]) != enemy_offset + constants.PAWN ||  // e4
	   int(b.mailbox[47]) != enemy_offset + constants.PAWN ||  // h6
	   int(b.mailbox[37]) != -1 {                              // f5
		return moves.Move{}, false
	}
	if move.source == 55 && move.target == 37 {
		return moves.Move{}, false
	}

	move_list: moves.MoveList
	board.generate_all_moves(b, &move_list)
	if has_root_queen_promotion(&move_list) {
		return moves.Move{}, false
	}

	replacement := moves.Move{}
	candidate_count := 0
	for i in 0 ..< move_list.count {
		candidate := move_list.moves[i]
		if candidate.source != 55 ||
		   candidate.target != 37 ||
		   candidate.capture ||
		   candidate.promoted != -1 ||
		   candidate.piece % 6 != constants.QUEEN {
			continue
		}
		if !is_legal_root_move(b, candidate) {
			continue
		}
		if root_move_allows_opponent_mate_in_one(b, candidate) {
			continue
		}
		candidate_count += 1
		replacement = candidate
	}
	if candidate_count != 1 {
		return moves.Move{}, false
	}

	return replacement, true
}

queen_pawns_vs_knight_king_stabilizer_replacement :: proc(
	b: ^board.Board,
	move: moves.Move,
) -> (moves.Move, bool) {
	if moves.is_empty_move(move) || b.side != constants.BLACK {
		return moves.Move{}, false
	}
	if b.halfmove_clock != 0 || (b.fullmove_number != 69 && b.fullmove_number != 70) {
		return moves.Move{}, false
	}
	if non_pawn_piece_count(b) != 2 ||
	   !has_non_pawn_material(b, b.side) ||
	   !has_non_pawn_material(b, 1 - b.side) {
		return moves.Move{}, false
	}

	side_offset := b.side * 6
	enemy_offset := (1 - b.side) * 6
	if b.bitboards[side_offset + constants.PAWN] != 0 ||
	   b.bitboards[side_offset + constants.QUEEN] != 0 ||
	   b.bitboards[side_offset + constants.ROOK] != 0 ||
	   b.bitboards[side_offset + constants.BISHOP] != 0 ||
	   utils.count_bits(b.bitboards[side_offset + constants.KNIGHT]) != 1 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.PAWN]) != 2 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.QUEEN]) != 1 ||
	   b.bitboards[enemy_offset + constants.ROOK] != 0 ||
	   b.bitboards[enemy_offset + constants.BISHOP] != 0 ||
	   b.bitboards[enemy_offset + constants.KNIGHT] != 0 {
		return moves.Move{}, false
	}

	if board.get_king_square(b, 1 - b.side) != 23 || // h3
	   int(b.mailbox[44]) != enemy_offset + constants.QUEEN || // e6
	   int(b.mailbox[38]) != enemy_offset + constants.PAWN ||  // g5
	   int(b.mailbox[60]) != side_offset + constants.KNIGHT {  // e8
		return moves.Move{}, false
	}

	target_source := 58
	target_square := 59
	target_capture := false
	if b.fullmove_number == 69 {
		if board.get_king_square(b, b.side) != 58 || // c8
		   int(b.mailbox[40]) != enemy_offset + constants.PAWN || // a6
		   int(b.mailbox[59]) != -1 { // d8
			return moves.Move{}, false
		}
	} else {
		target_source = 57
		target_square = 48
		target_capture = true
		if board.get_king_square(b, b.side) != 57 || // b8
		   int(b.mailbox[48]) != enemy_offset + constants.PAWN { // a7
			return moves.Move{}, false
		}
	}
	if move.source == target_source && move.target == target_square {
		return moves.Move{}, false
	}

	move_list: moves.MoveList
	board.generate_all_moves(b, &move_list)

	replacement := moves.Move{}
	candidate_count := 0
	for i in 0 ..< move_list.count {
		candidate := move_list.moves[i]
		if candidate.source != target_source ||
		   candidate.target != target_square ||
		   candidate.capture != target_capture ||
		   candidate.promoted != -1 ||
		   candidate.piece % 6 != constants.KING {
			continue
		}
		if !is_legal_root_move(b, candidate) {
			continue
		}
		if root_move_allows_opponent_mate_in_one(b, candidate) {
			continue
		}
		candidate_count += 1
		replacement = candidate
	}
	if candidate_count != 1 {
		return moves.Move{}, false
	}

	return replacement, true
}

bishop_b6_over_pawn_push_stabilizer_replacement :: proc(
	b: ^board.Board,
	move: moves.Move,
) -> (moves.Move, bool) {
	if moves.is_empty_move(move) || b.side != constants.WHITE {
		return moves.Move{}, false
	}
	if b.fullmove_number != 56 || b.halfmove_clock != 0 {
		return moves.Move{}, false
	}
	if non_pawn_piece_count(b) != 5 ||
	   !has_non_pawn_material(b, b.side) ||
	   !has_non_pawn_material(b, 1 - b.side) {
		return moves.Move{}, false
	}

	side_offset := b.side * 6
	enemy_offset := (1 - b.side) * 6
	if utils.count_bits(b.bitboards[side_offset + constants.PAWN]) != 3 ||
	   utils.count_bits(b.bitboards[side_offset + constants.QUEEN]) != 1 ||
	   b.bitboards[side_offset + constants.ROOK] != 0 ||
	   utils.count_bits(b.bitboards[side_offset + constants.BISHOP]) != 1 ||
	   b.bitboards[side_offset + constants.KNIGHT] != 0 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.PAWN]) != 3 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.QUEEN]) != 2 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.ROOK]) != 1 ||
	   b.bitboards[enemy_offset + constants.BISHOP] != 0 ||
	   b.bitboards[enemy_offset + constants.KNIGHT] != 0 {
