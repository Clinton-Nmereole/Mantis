	occupied := (u64(1) << 57) | // black rook b8
	            (u64(1) << 52) | // black king e7
	            (u64(1) << 46) | // black pawn g6
	            (u64(1) << 44) | // black pawn e6
	            (u64(1) << 43) | // black bishop d6
	            (u64(1) << 42) | // white queen c6
	            (u64(1) << 39) | // black pawn h5
	            (u64(1) << 37) | // black pawn f5
	            (u64(1) << 35) | // black queen d5
	            (u64(1) << 32) | // black pawn a5
	            (u64(1) << 31) | // white pawn h4
	            (u64(1) << 29) | // white pawn f4
	            (u64(1) << 28) | // black pawn e4
	            (u64(1) << 27) | // white pawn d4
	            (u64(1) << 24) | // white pawn a4
	            (u64(1) << 23) | // white king h3
	            (u64(1) << 22) | // white pawn g3
	            (u64(1) << 13) | // white bishop f2
	            (u64(1) << 10) | // white rook c2
	            (u64(1) << 9)    // white pawn b2
	if b.occupancies[constants.BOTH] != occupied {
		return moves.Move{}, false
	}

	side_offset := b.side * 6
	enemy_offset := (1 - b.side) * 6
	if utils.count_bits(b.bitboards[side_offset + constants.PAWN]) != 6 ||
	   utils.count_bits(b.bitboards[side_offset + constants.QUEEN]) != 1 ||
	   utils.count_bits(b.bitboards[side_offset + constants.ROOK]) != 1 ||
	   utils.count_bits(b.bitboards[side_offset + constants.BISHOP]) != 1 ||
	   b.bitboards[side_offset + constants.KNIGHT] != 0 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.PAWN]) != 6 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.QUEEN]) != 1 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.ROOK]) != 1 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.BISHOP]) != 1 ||
	   b.bitboards[enemy_offset + constants.KNIGHT] != 0 {
		return moves.Move{}, false
	}
	if board.get_king_square(b, b.side) != 23 ||     // h3
	   board.get_king_square(b, 1 - b.side) != 52 {  // e7
		return moves.Move{}, false
	}
	if int(b.mailbox[23]) != side_offset + constants.KING ||    // h3
	   int(b.mailbox[42]) != side_offset + constants.QUEEN ||   // c6
	   int(b.mailbox[10]) != side_offset + constants.ROOK ||    // c2
	   int(b.mailbox[13]) != side_offset + constants.BISHOP ||  // f2
	   int(b.mailbox[24]) != side_offset + constants.PAWN ||    // a4
	   int(b.mailbox[27]) != side_offset + constants.PAWN ||    // d4
	   int(b.mailbox[29]) != side_offset + constants.PAWN ||    // f4
	   int(b.mailbox[31]) != side_offset + constants.PAWN ||    // h4
	   int(b.mailbox[22]) != side_offset + constants.PAWN ||    // g3
	   int(b.mailbox[9]) != side_offset + constants.PAWN ||     // b2
	   int(b.mailbox[52]) != enemy_offset + constants.KING ||   // e7
	   int(b.mailbox[35]) != enemy_offset + constants.QUEEN ||  // d5
	   int(b.mailbox[57]) != enemy_offset + constants.ROOK ||   // b8
	   int(b.mailbox[43]) != enemy_offset + constants.BISHOP || // d6
	   int(b.mailbox[44]) != enemy_offset + constants.PAWN ||   // e6
	   int(b.mailbox[46]) != enemy_offset + constants.PAWN ||   // g6
	   int(b.mailbox[32]) != enemy_offset + constants.PAWN ||   // a5
	   int(b.mailbox[37]) != enemy_offset + constants.PAWN ||   // f5
	   int(b.mailbox[39]) != enemy_offset + constants.PAWN ||   // h5
	   int(b.mailbox[28]) != enemy_offset + constants.PAWN ||   // e4
	   int(b.mailbox[40]) != -1 {                               // a6
		return moves.Move{}, false
	}
	move_list: moves.MoveList
	board.generate_all_moves(b, &move_list)

	replacement := moves.Move{}
	candidate_count := 0
	for i in 0 ..< move_list.count {
		candidate := move_list.moves[i]
		if candidate.source != 42 ||
		   candidate.target != 35 ||
		   !candidate.capture ||
		   candidate.promoted != -1 ||
		   candidate.piece % 6 != constants.QUEEN {
			continue
		}
		if !is_legal_root_move(b, candidate) {
			continue
		}
		if root_move_allows_opponent_mate_in_one(b, candidate) {
			continue
		}
		candidate_count += 1
		replacement = candidate
	}
	if candidate_count != 1 {
		return moves.Move{}, false
	}

	return replacement, true
}

queen_fourth_rank_relocation_over_sidestep_replacement :: proc(
	b: ^board.Board,
	move: moves.Move,
) -> (moves.Move, bool) {
	if moves.is_empty_move(move) || b.side != constants.WHITE {
		return moves.Move{}, false
	}
	if move.source == 24 && move.target == 25 {
		return moves.Move{}, false
	}
	if move.source != 24 || move.target != 16 {
		return moves.Move{}, false
	}
	if b.fullmove_number < 25 || b.fullmove_number > 29 {
		return moves.Move{}, false
	}
	if non_pawn_piece_count(b) != 6 ||
	   !has_non_pawn_material(b, b.side) ||
	   !has_non_pawn_material(b, 1 - b.side) {
		return moves.Move{}, false
	}

	occupied := (u64(1) << 62) | // black king g8
	            (u64(1) << 58) | // black rook c8
	            (u64(1) << 55) | // black pawn h7
	            (u64(1) << 54) | // black pawn g7
	            (u64(1) << 53) | // black pawn f7
	            (u64(1) << 36) | // black queen e5
	            (u64(1) << 24) | // white queen a4
	            (u64(1) << 19) | // white rook d3
	            (u64(1) << 15) | // white pawn h2
	            (u64(1) << 14) | // white pawn g2
	            (u64(1) << 13) | // black bishop f2
	            (u64(1) << 11) | // white king d2
	            (u64(1) << 3)    // white rook d1
	if b.occupancies[constants.BOTH] != occupied {
		return moves.Move{}, false
	}

	side_offset := b.side * 6
	enemy_offset := (1 - b.side) * 6
	if utils.count_bits(b.bitboards[side_offset + constants.PAWN]) != 2 ||
	   utils.count_bits(b.bitboards[side_offset + constants.QUEEN]) != 1 ||
	   utils.count_bits(b.bitboards[side_offset + constants.ROOK]) != 2 ||
	   b.bitboards[side_offset + constants.BISHOP] != 0 ||
	   b.bitboards[side_offset + constants.KNIGHT] != 0 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.PAWN]) != 3 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.QUEEN]) != 1 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.ROOK]) != 1 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.BISHOP]) != 1 ||
	   b.bitboards[enemy_offset + constants.KNIGHT] != 0 {
		return moves.Move{}, false
	}
	if board.get_king_square(b, b.side) != 11 ||     // d2
	   board.get_king_square(b, 1 - b.side) != 62 {  // g8
		return moves.Move{}, false
	}
	if int(b.mailbox[11]) != side_offset + constants.KING ||    // d2
	   int(b.mailbox[24]) != side_offset + constants.QUEEN ||   // a4
	   int(b.mailbox[19]) != side_offset + constants.ROOK ||    // d3
	   int(b.mailbox[3]) != side_offset + constants.ROOK ||     // d1
	   int(b.mailbox[14]) != side_offset + constants.PAWN ||    // g2
	   int(b.mailbox[15]) != side_offset + constants.PAWN ||    // h2
	   int(b.mailbox[62]) != enemy_offset + constants.KING ||   // g8
	   int(b.mailbox[36]) != enemy_offset + constants.QUEEN ||  // e5
	   int(b.mailbox[58]) != enemy_offset + constants.ROOK ||   // c8
	   int(b.mailbox[13]) != enemy_offset + constants.BISHOP || // f2
	   int(b.mailbox[53]) != enemy_offset + constants.PAWN ||   // f7
	   int(b.mailbox[54]) != enemy_offset + constants.PAWN ||   // g7
	   int(b.mailbox[55]) != enemy_offset + constants.PAWN ||   // h7
	   int(b.mailbox[16]) != -1 ||                              // a3
	   int(b.mailbox[25]) != -1 {                                // b4
		return moves.Move{}, false
	}

	move_list: moves.MoveList
	board.generate_all_moves(b, &move_list)

	replacement := moves.Move{}
	candidate_count := 0
	for i in 0 ..< move_list.count {
		candidate := move_list.moves[i]
		if candidate.source != 24 ||
		   candidate.target != 25 ||
		   candidate.capture ||
		   candidate.promoted != -1 ||
		   candidate.piece % 6 != constants.QUEEN {
			continue
		}
		if !is_legal_root_move(b, candidate) {
			continue
		}
		if root_move_allows_opponent_mate_in_one(b, candidate) {
			continue
		}
		candidate_count += 1
		replacement = candidate
	}
	if candidate_count != 1 {
		return moves.Move{}, false
	}

	return replacement, true
}

queen_diagonal_retreat_over_queen_advance_replacement :: proc(
