	b: ^board.Board,
	move: moves.Move,
) -> (moves.Move, bool) {
	if moves.is_empty_move(move) || b.side != constants.BLACK {
		return moves.Move{}, false
	}
	if b.fullmove_number != 40 || b.halfmove_clock != 2 {
		return moves.Move{}, false
	}
	if b.castle != 0 || b.en_passant != -1 {
		return moves.Move{}, false
	}

	expected_bitboards := [12]u64{
		0x0000000002010000, 0x0000000000000000, 0x0000000000000020,
		0x0000000000009000, 0x0004000000000000, 0x0000000000002000,
		0x0040802400000000, 0x0000000000000000, 0x0000000000000000,
		0x0000000040100000, 0x0000200000000000, 0x0080000000000000,
	}
	for piece in 0 ..< 12 {
		if b.bitboards[piece] != expected_bitboards[piece] {
			return moves.Move{}, false
		}
	}

	side_offset := b.side * 6
	enemy_offset := (1 - b.side) * 6
	if board.get_king_square(b, b.side) != 55 ||     // h7
	   board.get_king_square(b, 1 - b.side) != 13 {  // f2
		return moves.Move{}, false
	}
	if int(b.mailbox[55]) != side_offset + constants.KING ||    // h7
	   int(b.mailbox[45]) != side_offset + constants.QUEEN ||   // f6
	   int(b.mailbox[20]) != side_offset + constants.ROOK ||    // e3
	   int(b.mailbox[30]) != side_offset + constants.ROOK ||    // g4
	   int(b.mailbox[34]) != side_offset + constants.PAWN ||    // c5
	   int(b.mailbox[37]) != side_offset + constants.PAWN ||    // f5
	   int(b.mailbox[54]) != side_offset + constants.PAWN ||    // g7
	   int(b.mailbox[47]) != side_offset + constants.PAWN ||    // h6
