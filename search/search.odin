minor_endgame_pawn_push_over_knight_rim_replacement :: proc(
	b: ^board.Board,
	move: moves.Move,
) -> (moves.Move, bool) {
	if moves.is_empty_move(move) || b.side != constants.WHITE {
		return moves.Move{}, false
	}
	if b.fullmove_number < 51 || b.fullmove_number > 55 {
		return moves.Move{}, false
	}
	if non_pawn_piece_count(b) != 3 ||
	   !has_non_pawn_material(b, b.side) ||
	   !has_non_pawn_material(b, 1 - b.side) {
		return moves.Move{}, false
	}

	side_offset := b.side * 6
	enemy_offset := (1 - b.side) * 6
	if utils.count_bits(b.bitboards[side_offset + constants.PAWN]) != 3 ||
	   b.bitboards[side_offset + constants.QUEEN] != 0 ||
	   b.bitboards[side_offset + constants.ROOK] != 0 ||
	   b.bitboards[side_offset + constants.BISHOP] != 0 ||
	   utils.count_bits(b.bitboards[side_offset + constants.KNIGHT]) != 1 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.PAWN]) != 3 ||
	   b.bitboards[enemy_offset + constants.QUEEN] != 0 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.ROOK]) != 1 ||
	   b.bitboards[enemy_offset + constants.BISHOP] != 0 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.KNIGHT]) != 1 {
		return moves.Move{}, false
	}

	if board.get_king_square(b, b.side) != 23 || // h3
	   board.get_king_square(b, 1 - b.side) != 53 { // f7
		return moves.Move{}, false
	}
	if int(b.mailbox[22]) != side_offset + constants.KNIGHT || // g3
	   int(b.mailbox[21]) != side_offset + constants.PAWN ||   // f3
	   int(b.mailbox[30]) != side_offset + constants.PAWN ||   // g4
	   int(b.mailbox[31]) != side_offset + constants.PAWN ||   // h4
	   int(b.mailbox[8]) != enemy_offset + constants.ROOK ||   // a2
	   int(b.mailbox[19]) != enemy_offset + constants.KNIGHT ||// d3
	   int(b.mailbox[36]) != enemy_offset + constants.PAWN ||  // e5
	   int(b.mailbox[44]) != enemy_offset + constants.PAWN ||  // e6
	   int(b.mailbox[54]) != enemy_offset + constants.PAWN ||  // g7
	   int(b.mailbox[38]) != -1 {                              // g5
		return moves.Move{}, false
	}
	if move.source == 30 && move.target == 38 {
		return moves.Move{}, false
	}

	move_list: moves.MoveList
	board.generate_all_moves(b, &move_list)
	if has_root_queen_promotion(&move_list) {
		return moves.Move{}, false
	}

	replacement := moves.Move{}
	candidate_count := 0
	for i in 0 ..< move_list.count {
		candidate := move_list.moves[i]
		if candidate.source != 30 ||
		   candidate.target != 38 ||
		   candidate.capture ||
		   candidate.promoted != -1 ||
		   candidate.piece % 6 != constants.PAWN {
			continue
		}
		if !is_legal_root_move(b, candidate) {
			continue
		}
		if root_move_allows_opponent_mate_in_one(b, candidate) {
			continue
		}
		candidate_count += 1
		replacement = candidate
	}
	if candidate_count != 1 {
		return moves.Move{}, false
	}

	return replacement, true
}

bishop_rook_minor_king_escape_stabilizer_replacement :: proc(
	b: ^board.Board,
	move: moves.Move,
) -> (moves.Move, bool) {
	if moves.is_empty_move(move) || b.side != constants.WHITE {
		return moves.Move{}, false
	}
	if b.fullmove_number < 50 || b.fullmove_number > 54 {
		return moves.Move{}, false
	}
	if non_pawn_piece_count(b) != 4 ||
	   !has_non_pawn_material(b, b.side) ||
	   !has_non_pawn_material(b, 1 - b.side) {
		return moves.Move{}, false
	}

	side_offset := b.side * 6
	enemy_offset := (1 - b.side) * 6
	if utils.count_bits(b.bitboards[side_offset + constants.PAWN]) != 1 ||
	   b.bitboards[side_offset + constants.QUEEN] != 0 ||
	   b.bitboards[side_offset + constants.ROOK] != 0 ||
	   utils.count_bits(b.bitboards[side_offset + constants.BISHOP]) != 1 ||
	   b.bitboards[side_offset + constants.KNIGHT] != 0 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.PAWN]) != 3 ||
	   b.bitboards[enemy_offset + constants.QUEEN] != 0 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.ROOK]) != 1 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.BISHOP]) != 1 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.KNIGHT]) != 1 {
		return moves.Move{}, false
	}

	if board.get_king_square(b, b.side) != 11 || // d2
	   board.get_king_square(b, 1 - b.side) != 51 { // d7
		return moves.Move{}, false
	}
	e5_g1_layout := int(b.mailbox[36]) == side_offset + constants.BISHOP && // e5
	                int(b.mailbox[6]) == enemy_offset + constants.ROOK &&   // g1
	                int(b.mailbox[57]) == -1 &&                             // b8
	                int(b.mailbox[5]) == -1                                  // f1
	b8_f1_layout := int(b.mailbox[57]) == side_offset + constants.BISHOP && // b8
	                int(b.mailbox[5]) == enemy_offset + constants.ROOK &&   // f1
	                int(b.mailbox[36]) == -1 &&                             // e5
	                int(b.mailbox[6]) == -1                                  // g1
	if !(e5_g1_layout || b8_f1_layout) {
		return moves.Move{}, false
	}
	if int(b.mailbox[16]) != side_offset + constants.PAWN ||   // a3
	   int(b.mailbox[41]) != enemy_offset + constants.BISHOP ||// b6
	   int(b.mailbox[44]) != enemy_offset + constants.KNIGHT ||// e6
	   int(b.mailbox[48]) != enemy_offset + constants.PAWN ||  // a7
	   int(b.mailbox[49]) != enemy_offset + constants.PAWN ||  // b7
	   int(b.mailbox[29]) != enemy_offset + constants.PAWN ||  // f4
	   int(b.mailbox[12]) != -1 {                              // e2
		return moves.Move{}, false
	}
	if move.source == 11 && move.target == 12 {
		return moves.Move{}, false
	}

	move_list: moves.MoveList
	board.generate_all_moves(b, &move_list)
	if has_root_queen_promotion(&move_list) {
		return moves.Move{}, false
	}

	replacement := moves.Move{}
	candidate_count := 0
	for i in 0 ..< move_list.count {
		candidate := move_list.moves[i]
		if candidate.source != 11 ||
		   candidate.target != 12 ||
		   candidate.capture ||
		   candidate.promoted != -1 ||
		   candidate.piece % 6 != constants.KING {
			continue
		}
