			bad_source = 11, bad_target = 27, bad_piece = constants.PAWN,
			bitboards = [12]u64{
				0x000000000010ef00, 0x0000000000000042, 0x0000000000000024,
				0x0000000000000081, 0x0000000000200000, 0x0000000000000010,
				0x00ef100000000000, 0x4200000000000000, 0x0400080000000000,
				0x8100000000000000, 0x0800000000000000, 0x1000000000000000,
