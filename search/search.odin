queen_knight_net_king_escape_stabilizer_replacement :: proc(
	b: ^board.Board,
	move: moves.Move,
) -> (moves.Move, bool) {
	if moves.is_empty_move(move) || b.side != constants.BLACK {
		return moves.Move{}, false
	}
	if b.fullmove_number < 40 || b.fullmove_number > 44 {
		return moves.Move{}, false
	}
	if non_pawn_piece_count(b) != 3 ||
	   !has_non_pawn_material(b, b.side) ||
	   !has_non_pawn_material(b, 1 - b.side) {
		return moves.Move{}, false
	}

	side_offset := b.side * 6
	enemy_offset := (1 - b.side) * 6
	if utils.count_bits(b.bitboards[side_offset + constants.PAWN]) != 3 ||
	   utils.count_bits(b.bitboards[side_offset + constants.QUEEN]) != 1 ||
	   b.bitboards[side_offset + constants.ROOK] != 0 ||
	   b.bitboards[side_offset + constants.BISHOP] != 0 ||
	   b.bitboards[side_offset + constants.KNIGHT] != 0 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.PAWN]) != 2 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.QUEEN]) != 1 ||
	   b.bitboards[enemy_offset + constants.ROOK] != 0 ||
	   b.bitboards[enemy_offset + constants.BISHOP] != 0 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.KNIGHT]) != 1 {
		return moves.Move{}, false
	}

	if board.get_king_square(b, b.side) != 47 || // h6
	   board.get_king_square(b, 1 - b.side) != 15 { // h2
		return moves.Move{}, false
	}
	if int(b.mailbox[13]) != side_offset + constants.QUEEN ||  // f2
	   int(b.mailbox[24]) != side_offset + constants.PAWN ||   // a4
	   int(b.mailbox[46]) != side_offset + constants.PAWN ||   // g6
	   int(b.mailbox[55]) != side_offset + constants.PAWN ||   // h7
	   int(b.mailbox[51]) != enemy_offset + constants.QUEEN || // d7
	   int(b.mailbox[53]) != enemy_offset + constants.KNIGHT ||// f7
	   int(b.mailbox[14]) != enemy_offset + constants.PAWN ||  // g2
	   int(b.mailbox[31]) != enemy_offset + constants.PAWN ||  // h4
	   int(b.mailbox[54]) != -1 {                              // g7
		return moves.Move{}, false
	}
	if move.source == 47 && move.target == 54 {
		return moves.Move{}, false
	}

	move_list: moves.MoveList
	board.generate_all_moves(b, &move_list)
	if has_root_queen_promotion(&move_list) {
		return moves.Move{}, false
	}

	replacement := moves.Move{}
	candidate_count := 0
	for i in 0 ..< move_list.count {
		candidate := move_list.moves[i]
		if candidate.source != 47 ||
		   candidate.target != 54 ||
		   candidate.capture ||
		   candidate.promoted != -1 ||
		   candidate.piece % 6 != constants.KING {
			continue
		}
		if !is_legal_root_move(b, candidate) {
			continue
		}
		if root_move_allows_opponent_mate_in_one(b, candidate) {
			continue
		}
		candidate_count += 1
		replacement = candidate
	}
	if candidate_count != 1 {
		return moves.Move{}, false
	}

	return replacement, true
}

