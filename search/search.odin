			orig637_layout = false
		}
		if b.bitboards[piece] != expected_orig595_bitboards[piece] {
			orig595_layout = false
		}
		if b.bitboards[piece] != expected_orig538_bitboards[piece] {
			orig538_layout = false
		}
		if b.bitboards[piece] != expected_orig606_bitboards[piece] {
			orig606_layout = false
		}
	}
	if !(orig537_layout || orig539_layout || orig637_layout || orig595_layout ||
	     orig538_layout || orig606_layout) {
		return moves.Move{}, false
	}

	desired_source := -1
	desired_target := -1
	desired_piece := constants.PAWN
	bad_move := false

	if orig537_layout {
		desired_source = 11 // d2
		desired_target = 27 // d4
		desired_piece = constants.PAWN
		if move.source == desired_source && move.target == desired_target {
			return moves.Move{}, false
		}
		bad_move = move.source == 15 &&
		           move.target == 7 &&
		           !move.capture &&
		           move.promoted == -1 &&
		           move.piece % 6 == constants.ROOK
	} else if orig539_layout {
		desired_source = 21 // f3
		desired_target = 6 // g1
		desired_piece = constants.KNIGHT
		if move.source == desired_source && move.target == desired_target {
