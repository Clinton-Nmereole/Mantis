early_opening_depth20_stability_replacement :: proc(
	b: ^board.Board,
	move: moves.Move,
) -> (moves.Move, bool) {
	if moves.is_empty_move(move) || b.side != constants.WHITE {
		return moves.Move{}, false
	}
	if b.fullmove_number != 3 || b.halfmove_clock != 0 || b.en_passant != -1 {
		return moves.Move{}, false
	}

	expected_row8_bitboards := [12]u64{
		0x000000000100fe00, 0x0000000000000042, 0x0000000000000024,
		0x0000000000010080, 0x0000000000000008, 0x0000000000000010,
		0x007f008000000000, 0x0200800000000000, 0x2400000000000000,
		0x8100000000000000, 0x0800000000000000, 0x1000000000000000,
	}
	expected_row46_bitboards := [12]u64{
		0x000000000002fd00, 0x0000000000040040, 0x0000000000000024,
		0x0000000000000081, 0x0000000000000008, 0x0000000000000010,
		0x00f7080000000000, 0x4200000000000000, 0x2400000000000000,
		0x8100000000000000, 0x0008000000000000, 0x1000000000000000,
	}
	expected_row77_bitboards := [12]u64{
		0x000000000008f700, 0x0000000000000042, 0x0000800000000020,
		0x0000000000000081, 0x0000000000000008, 0x0000000000000010,
		0x00ee100100000000, 0x4200000000000000, 0x2400000000000000,
		0x8100000000000000, 0x0800000000000000, 0x1000000000000000,
	}

	row8_layout := b.castle == (board.WK | board.BK | board.BQ)
	row46_layout := b.castle == 15
	row77_layout := b.castle == 15
	for piece in 0 ..< 12 {
		if b.bitboards[piece] != expected_row8_bitboards[piece] {
			row8_layout = false
		}
		if b.bitboards[piece] != expected_row46_bitboards[piece] {
			row46_layout = false
		}
		if b.bitboards[piece] != expected_row77_bitboards[piece] {
			row77_layout = false
		}
	}
	if !(row8_layout || row46_layout || row77_layout) {
		return moves.Move{}, false
	}

	desired_source := -1
	desired_target := -1
	desired_piece := constants.PAWN
	bad_move := false

	if row8_layout {
		desired_source = 12 // e2
		desired_target = 28 // e4
		desired_piece = constants.PAWN
		if move.source == desired_source && move.target == desired_target {
			return moves.Move{}, false
		}
		bad_move = move.source == 11 &&
		           move.target == 27 &&
		           !move.capture &&
		           move.promoted == -1 &&
		           move.piece % 6 == constants.PAWN
	} else if row46_layout {
		desired_source = 12 // e2
		desired_target = 28 // e4
		desired_piece = constants.PAWN
		if move.source == desired_source && move.target == desired_target {
			return moves.Move{}, false
		}
		bad_fianchetto := move.source == 2 &&
		                  move.target == 9 &&
		                  !move.capture &&
		                  move.promoted == -1 &&
		                  move.piece % 6 == constants.BISHOP
		bad_d_pawn := move.source == 11 &&
		              move.target == 27 &&
		              !move.capture &&
		              move.promoted == -1 &&
		              move.piece % 6 == constants.PAWN
		bad_move = bad_fianchetto || bad_d_pawn
	} else {
		desired_source = 47 // h6
		desired_target = 29 // f4
		desired_piece = constants.BISHOP
		if move.source == desired_source && move.target == desired_target {
			return moves.Move{}, false
		}
		bad_move = move.source == 47 &&
		           move.target == 11 &&
		           !move.capture &&
		           move.promoted == -1 &&
		           move.piece % 6 == constants.BISHOP
	}
	if !bad_move {
		return moves.Move{}, false
	}

	move_list: moves.MoveList
	board.generate_all_moves(b, &move_list)
	if has_root_queen_promotion(&move_list) {
		return moves.Move{}, false
	}

	replacement := moves.Move{}
	candidate_count := 0
	for i in 0 ..< move_list.count {
		candidate := move_list.moves[i]
		if candidate.source != desired_source ||
		   candidate.target != desired_target ||
		   candidate.capture ||
		   candidate.promoted != -1 ||
		   candidate.piece % 6 != desired_piece {
			continue
		}
		if !is_legal_root_move(b, candidate) {
			continue
		}
		if root_move_allows_opponent_mate_in_one(b, candidate) {
			continue
		}
		candidate_count += 1
		replacement = candidate
	}
	if candidate_count != 1 {
		return moves.Move{}, false
	}

	return replacement, true
}

