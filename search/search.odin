}

enemy_promotion_targets :: proc(b: ^board.Board) -> u64 {
	enemy_side := 1 - b.side
	enemy_pawns := b.bitboards[enemy_side * 6 + constants.PAWN]
	if enemy_side == constants.WHITE {
		return (enemy_pawns & constants.RANK_7) << 8
	}
	return (enemy_pawns & constants.RANK_2) >> 8
}

is_quiet_bishop_enemy_promotion_guard :: proc(b: ^board.Board, move: moves.Move) -> bool {
	if !is_quiet_bishop_move(move) {
		return false
	}

	targets := enemy_promotion_targets(b)
	if targets == 0 {
		return false
	}

	source_bit := u64(1) << u64(move.source)
	target_bit := u64(1) << u64(move.target)
	occupancy := (b.occupancies[constants.BOTH] & ~source_bit) | target_bit
	return (moves.get_bishop_attacks(move.target, occupancy) & targets) != 0
}

restore_timed_quiet_bishop_promotion_guards :: proc(
	set: ^RootVerifyCandidateSet,
	b: ^board.Board,
	move_list: ^moves.MoveList,
	max_count: int = 0,
) {
	count := 0
	for i in 0 ..< set.count {
		if i >= move_list.count {
			break
		}
		if max_count > 0 && count >= max_count {
			break
		}
		move := move_list.moves[i]
		if !is_quiet_bishop_enemy_promotion_guard(b, move) {
			continue
		}
		set.include[i] = true
		set.reason[i] = "timed_quiet_bishop_promotion_guard"
		set.priority[i] = ROOT_VERIFY_PRIORITY_CORE + 2 + count
		count += 1
	}
}

has_legal_root_quiet_bishop_promotion_guard :: proc(b: ^board.Board, move_list: ^moves.MoveList) -> bool {
	for i in 0 ..< move_list.count {
		move := move_list.moves[i]
		if !is_quiet_bishop_enemy_promotion_guard(b, move) {
			continue
		}
		if is_legal_root_move(b, move) {
			return true
		}
	}
	return false
}

is_root_queen_capture_of_queen :: proc(b: ^board.Board, move: moves.Move) -> bool {
	if moves.is_empty_move(move) ||
	   !move.capture ||
	   move.promoted != -1 ||
	   move.piece % 6 != constants.QUEEN {
		return false
	}

	victim := int(b.mailbox[move.target])
	return victim >= 0 && victim % 6 == constants.QUEEN
}

has_legal_root_queen_capture_of_queen :: proc(b: ^board.Board, move_list: ^moves.MoveList) -> bool {
	for i in 0 ..< move_list.count {
		move := move_list.moves[i]
		if !is_root_queen_capture_of_queen(b, move) {
			continue
		}
		if is_legal_root_move(b, move) {
			return true
		}
	}
	return false
}
