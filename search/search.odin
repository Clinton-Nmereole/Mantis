	move_list: ^moves.MoveList,
	max_count: int = 0,
) {
	count := 0
	for i in 0 ..< set.count {
		if i >= move_list.count {
			break
		}
		if max_count > 0 && count >= max_count {
			break
		}
		move := move_list.moves[i]
		if !is_root_quiet_queen_check(b, move) {
			continue
		}
		set.include[i] = true
		set.reason[i] = "timed_quiet_queen_check"
