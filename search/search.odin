			}
			if short_clock_passed_pawn_race_recovery_depth > 0 &&
			   current_depth >= short_clock_passed_pawn_race_recovery_depth {
				short_clock_passed_pawn_race_recovery_depth = 0
			}
		}

	// Add remaining local nodes to global counter
	sync.atomic_add(&total_nodes, st.nodes % 1024)

	// Only output bestmove if requested (main thread only)
