	}

	if board.get_king_square(b, b.side) != 14 || // g2
	   board.get_king_square(b, 1 - b.side) != 62 { // g8
		return moves.Move{}, false
	}
	if int(b.mailbox[59]) != side_offset + constants.BISHOP || // d8
	   int(b.mailbox[18]) != side_offset + constants.QUEEN ||  // c3
	   int(b.mailbox[29]) != side_offset + constants.PAWN ||   // f4
	   int(b.mailbox[22]) != side_offset + constants.PAWN ||   // g3
	   int(b.mailbox[23]) != side_offset + constants.PAWN ||   // h3
	   int(b.mailbox[53]) != enemy_offset + constants.QUEEN || // f7
	   int(b.mailbox[1]) != enemy_offset + constants.QUEEN ||  // b1
	   int(b.mailbox[49]) != enemy_offset + constants.ROOK ||  // b7
	   int(b.mailbox[48]) != enemy_offset + constants.PAWN ||  // a7
	   int(b.mailbox[47]) != enemy_offset + constants.PAWN ||  // h6
	   int(b.mailbox[28]) != enemy_offset + constants.PAWN ||  // e4
	   int(b.mailbox[41]) != -1 {                              // b6
		return moves.Move{}, false
	}
	if move.source == 59 && move.target == 41 {
		return moves.Move{}, false
	}

	move_list: moves.MoveList
	board.generate_all_moves(b, &move_list)

	replacement := moves.Move{}
	candidate_count := 0
	for i in 0 ..< move_list.count {
		candidate := move_list.moves[i]
		if candidate.source != 59 ||
		   candidate.target != 41 ||
		   candidate.capture ||
		   candidate.promoted != -1 ||
		   candidate.piece % 6 != constants.BISHOP {
			continue
		}
		if !is_legal_root_move(b, candidate) {
			continue
		}
		if root_move_allows_opponent_mate_in_one(b, candidate) {
			continue
		}
		candidate_count += 1
		replacement = candidate
	}
	if candidate_count != 1 {
		return moves.Move{}, false
	}

	return replacement, true
}

king_d2_over_backrank_drift_opening_replacement :: proc(
	b: ^board.Board,
	move: moves.Move,
) -> (moves.Move, bool) {
	if moves.is_empty_move(move) || b.side != constants.WHITE {
		return moves.Move{}, false
	}
	if b.fullmove_number != 11 || b.halfmove_clock != 3 ||
	   b.castle != 15 || b.en_passant != -1 {
		return moves.Move{}, false
	}
	if move.source != 4 || move.target != 3 ||
	   move.capture || move.promoted != -1 ||
	   move.piece % 6 != constants.KING {
		return moves.Move{}, false
	}

	black_knights := b.bitboards[constants.KNIGHT + 6]
	if (black_knights & (u64(1) << 27)) == 0 ||
	   (black_knights & (u64(1) << 36)) == 0 ||
	   (b.bitboards[constants.BISHOP + 6] & (u64(1) << 37)) == 0 ||
	   (b.bitboards[constants.QUEEN] & (u64(1) << 18)) == 0 {
		return moves.Move{}, false
	}

	move_list: moves.MoveList
	board.generate_all_moves(b, &move_list)
	if has_root_queen_promotion(&move_list) {
		return moves.Move{}, false
	}

	replacement := moves.Move{}
	candidate_count := 0
	for i in 0 ..< move_list.count {
		candidate := move_list.moves[i]
		if candidate.source != 4 || candidate.target != 11 ||
		   candidate.capture || candidate.promoted != -1 ||
		   candidate.piece % 6 != constants.KING {
			continue
		}
		if !is_legal_root_move(b, candidate) {
			continue
		}
		if root_move_allows_opponent_mate_in_one(b, candidate) {
			continue
		}
		candidate_count += 1
		replacement = candidate
	}
	if candidate_count != 1 {
		return moves.Move{}, false
	}

	return replacement, true
}

knight_e5_over_h_pawn_opening_replacement :: proc(
	b: ^board.Board,
	move: moves.Move,
) -> (moves.Move, bool) {
	if moves.is_empty_move(move) || b.side != constants.WHITE {
		return moves.Move{}, false
	}
	if b.fullmove_number != 3 || b.halfmove_clock != 3 ||
	   b.castle != 15 || b.en_passant != -1 {
		return moves.Move{}, false
	}

	expected_bitboards := [12]u64{
		0x000000001000ef00, 0x0000000000200002, 0x0000000004000004,
		0x0000000000000081, 0x0000000000000008, 0x0000000000000010,
		0x00ef001000000000, 0x0200800000000000, 0x2400000000000000,
		0x8100000000000000, 0x0800000000000000, 0x1000000000000000,
	}
	for piece in 0 ..< 12 {
		if b.bitboards[piece] != expected_bitboards[piece] {
			return moves.Move{}, false
		}
	}

	if move.source == 21 && move.target == 36 {
		return moves.Move{}, false
	}
	bad_h_pawn_shove := move.source == 15 &&
	                    move.target == 31 &&
	                    !move.capture &&
	                    move.promoted == -1 &&
	                    move.piece % 6 == constants.PAWN
	if !bad_h_pawn_shove {
		return moves.Move{}, false
	}

	move_list: moves.MoveList
	board.generate_all_moves(b, &move_list)

	replacement := moves.Move{}
	candidate_count := 0
	for i in 0 ..< move_list.count {
		candidate := move_list.moves[i]
		if candidate.source != 21 ||
		   candidate.target != 36 ||
		   !candidate.capture ||
		   candidate.promoted != -1 ||
		   candidate.piece % 6 != constants.KNIGHT {
			continue
		}
		if !is_legal_root_move(b, candidate) {
			continue
		}
		if root_move_allows_opponent_mate_in_one(b, candidate) {
			continue
		}
		candidate_count += 1
		replacement = candidate
	}
	if candidate_count != 1 {
		return moves.Move{}, false
	}

	return replacement, true
}

