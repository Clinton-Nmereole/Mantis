	}
	if board.get_king_square(b, b.side) != 50 ||     // c7
	   board.get_king_square(b, 1 - b.side) != 7 {   // h1
		return moves.Move{}, false
	}
	if int(b.mailbox[50]) != side_offset + constants.KING ||    // c7
	   int(b.mailbox[62]) != side_offset + constants.ROOK ||    // g8
