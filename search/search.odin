	move: moves.Move,
) -> (moves.Move, bool) {
	if moves.is_empty_move(move) || b.side != constants.BLACK {
		return moves.Move{}, false
	}
	if b.fullmove_number != 27 || b.halfmove_clock != 2 {
		return moves.Move{}, false
	}
	if b.castle != 0 || b.en_passant != -1 {
		return moves.Move{}, false
	}

	expected_bitboards := [12]u64{
		0x0000402004200300, 0x0000000000000000, 0x0000000000000004,
		0x0000000000000001, 0x0000000000000000, 0x0000000000004000,
		0x0007088008000000, 0x0000000000000000, 0x0000200000000000,
		0x8010000000000000, 0x0000000000000000, 0x0008000000000000,
	}
	for piece in 0 ..< 12 {
		if b.bitboards[piece] != expected_bitboards[piece] {
			return moves.Move{}, false
		}
	}

	if move.source == 52 && move.target == 36 {
		return moves.Move{}, false
	}
	if move.source != 27 ||
	   move.target != 19 ||
	   move.capture ||
	   move.promoted != -1 ||
	   move.piece % 6 != constants.PAWN {
		return moves.Move{}, false
	}

	move_list: moves.MoveList
	board.generate_all_moves(b, &move_list)
	if has_root_queen_promotion(&move_list) {
		return moves.Move{}, false
	}

	replacement := moves.Move{}
	candidate_count := 0
	for i in 0 ..< move_list.count {
		candidate := move_list.moves[i]
		if candidate.source != 52 ||
		   candidate.target != 36 ||
		   candidate.capture ||
		   candidate.promoted != -1 ||
		   candidate.piece % 6 != constants.ROOK {
			continue
		}
		if !is_legal_root_move(b, candidate) {
			continue
		}
		if root_move_allows_opponent_mate_in_one(b, candidate) {
			continue
		}
		candidate_count += 1
		replacement = candidate
	}
	if candidate_count != 1 {
		return moves.Move{}, false
	}

	return replacement, true
}

h_pawn_h4_over_bishop_king_drift_replacement :: proc(
	b: ^board.Board,
	move: moves.Move,
) -> (moves.Move, bool) {
