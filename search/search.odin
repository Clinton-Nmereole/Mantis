}

king_escape_over_rook_lift_replacement :: proc(
	b: ^board.Board,
	move: moves.Move,
) -> (moves.Move, bool) {
	if moves.is_empty_move(move) || b.side != constants.WHITE {
		return moves.Move{}, false
	}
	if b.fullmove_number != 39 || b.halfmove_clock != 29 {
		return moves.Move{}, false
	}
	if b.castle != 0 || b.en_passant != -1 {
		return moves.Move{}, false
	}

	expected_bitboards := [12]u64{
		0x0000000284402500, 0x0000000000000000, 0x0000000000080000,
		0x0000000000010000, 0x0000000800000000, 0x0000000000008000,
		0x000340a408000000, 0x0000000000000000, 0x0004000000000000,
		0x0000000000000008, 0x0010000000000000, 0x0040000000000000,
	}
	for piece in 0 ..< 12 {
		if b.bitboards[piece] != expected_bitboards[piece] {
			return moves.Move{}, false
		}
	}

	if move.source == 15 && move.target == 23 {
		return moves.Move{}, false
	}
	if move.source != 16 ||
	   move.target != 24 ||
	   move.capture ||
	   move.promoted != -1 ||
	   move.piece % 6 != constants.ROOK {
		return moves.Move{}, false
	}

	move_list: moves.MoveList
	board.generate_all_moves(b, &move_list)
	if has_root_queen_promotion(&move_list) {
		return moves.Move{}, false
	}

	replacement := moves.Move{}
	candidate_count := 0
	for i in 0 ..< move_list.count {
		candidate := move_list.moves[i]
		if candidate.source != 15 ||
		   candidate.target != 23 ||
		   candidate.capture ||
		   candidate.promoted != -1 ||
		   candidate.piece % 6 != constants.KING {
			continue
		}
		if !is_legal_root_move(b, candidate) {
			continue
		}
		if root_move_allows_opponent_mate_in_one(b, candidate) {
			continue
		}
		candidate_count += 1
		replacement = candidate
	}
	if candidate_count != 1 {
		return moves.Move{}, false
	}

	return replacement, true
}

rook_capture_over_corner_king_step_replacement :: proc(
	b: ^board.Board,
	move: moves.Move,
) -> (moves.Move, bool) {
	if moves.is_empty_move(move) || b.side != constants.BLACK {
		return moves.Move{}, false
	}
	if move.source == 52 && move.target == 44 {
		return moves.Move{}, false
	}
	if move.source != 62 || move.target != 63 {
		return moves.Move{}, false
	}
	if b.fullmove_number < 27 || b.fullmove_number > 31 {
		return moves.Move{}, false
	}
	if non_pawn_piece_count(b) != 8 ||
	   !has_non_pawn_material(b, b.side) ||
	   !has_non_pawn_material(b, 1 - b.side) {
		return moves.Move{}, false
	}

	occupied := (u64(1) << 62) | // black king g8
	            (u64(1) << 59) | // black rook d8
	            (u64(1) << 54) | // black pawn g7
	            (u64(1) << 52) | // black rook e7
	            (u64(1) << 49) | // black pawn b7
	            (u64(1) << 44) | // white bishop e6
	            (u64(1) << 42) | // black bishop c6
	            (u64(1) << 40) | // black pawn a6
	            (u64(1) << 34) | // black bishop c5
	            (u64(1) << 30) | // white queen g4
	            (u64(1) << 29) | // white bishop f4
	            (u64(1) << 23) | // white pawn h3
	            (u64(1) << 14) | // white pawn g2
	            (u64(1) << 13) | // white pawn f2
	            (u64(1) << 9)  | // white pawn b2
	            (u64(1) << 7)  | // white king h1
	            (u64(1) << 4)    // white rook e1
	if b.occupancies[constants.BOTH] != occupied {
		return moves.Move{}, false
	}

	side_offset := b.side * 6
	enemy_offset := (1 - b.side) * 6
	if utils.count_bits(b.bitboards[side_offset + constants.PAWN]) != 3 ||
	   b.bitboards[side_offset + constants.QUEEN] != 0 ||
	   utils.count_bits(b.bitboards[side_offset + constants.ROOK]) != 2 ||
	   utils.count_bits(b.bitboards[side_offset + constants.BISHOP]) != 2 ||
	   b.bitboards[side_offset + constants.KNIGHT] != 0 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.PAWN]) != 4 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.QUEEN]) != 1 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.ROOK]) != 1 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.BISHOP]) != 2 ||
	   b.bitboards[enemy_offset + constants.KNIGHT] != 0 {
		return moves.Move{}, false
	}
	if board.get_king_square(b, b.side) != 62 ||    // g8
	   board.get_king_square(b, 1 - b.side) != 7 {  // h1
		return moves.Move{}, false
	}
	if int(b.mailbox[62]) != side_offset + constants.KING ||    // g8
	   int(b.mailbox[59]) != side_offset + constants.ROOK ||    // d8
	   int(b.mailbox[52]) != side_offset + constants.ROOK ||    // e7
	   int(b.mailbox[42]) != side_offset + constants.BISHOP ||  // c6
	   int(b.mailbox[34]) != side_offset + constants.BISHOP ||  // c5
	   int(b.mailbox[40]) != side_offset + constants.PAWN ||    // a6
	   int(b.mailbox[49]) != side_offset + constants.PAWN ||    // b7
	   int(b.mailbox[54]) != side_offset + constants.PAWN ||    // g7
	   int(b.mailbox[7]) != enemy_offset + constants.KING ||    // h1
	   int(b.mailbox[30]) != enemy_offset + constants.QUEEN ||  // g4
	   int(b.mailbox[4]) != enemy_offset + constants.ROOK ||    // e1
	   int(b.mailbox[44]) != enemy_offset + constants.BISHOP || // e6
	   int(b.mailbox[29]) != enemy_offset + constants.BISHOP || // f4
	   int(b.mailbox[9]) != enemy_offset + constants.PAWN ||    // b2
	   int(b.mailbox[13]) != enemy_offset + constants.PAWN ||   // f2
	   int(b.mailbox[14]) != enemy_offset + constants.PAWN ||   // g2
	   int(b.mailbox[23]) != enemy_offset + constants.PAWN ||   // h3
	   int(b.mailbox[63]) != -1 {                               // h8
		return moves.Move{}, false
	}
	move_list: moves.MoveList
	board.generate_all_moves(b, &move_list)

	replacement := moves.Move{}
	candidate_count := 0
	for i in 0 ..< move_list.count {
		candidate := move_list.moves[i]
		if candidate.source != 52 ||
		   candidate.target != 44 ||
		   !candidate.capture ||
		   candidate.promoted != -1 ||
		   candidate.piece % 6 != constants.ROOK {
			continue
		}
		if !is_legal_root_move(b, candidate) {
			continue
		}
		if root_move_allows_opponent_mate_in_one(b, candidate) {
			continue
		}
		candidate_count += 1
		replacement = candidate
	}
	if candidate_count != 1 {
		return moves.Move{}, false
	}

	return replacement, true
}

king_blockade_over_retreat_replacement :: proc(
	b: ^board.Board,
	move: moves.Move,
) -> (moves.Move, bool) {
	if moves.is_empty_move(move) || b.side != constants.BLACK {
		return moves.Move{}, false
	}
	if move.source == 35 && move.target == 26 {
		return moves.Move{}, false
	}
	if move.source != 35 || move.target != 44 {
		return moves.Move{}, false
	}
	if b.fullmove_number < 43 || b.fullmove_number > 47 {
		return moves.Move{}, false
	}
	if non_pawn_piece_count(b) != 4 ||
	   !has_non_pawn_material(b, b.side) ||
	   !has_non_pawn_material(b, 1 - b.side) {
		return moves.Move{}, false
	}

	occupied := (u64(1) << 56) | // black rook a8
	            (u64(1) << 55) | // black rook h7
	            (u64(1) << 46) | // black pawn g6
	            (u64(1) << 43) | // white pawn d6
	            (u64(1) << 42) | // black pawn c6
	            (u64(1) << 40) | // black pawn a6
	            (u64(1) << 35) | // black king d5
	            (u64(1) << 34) | // white pawn c5
	            (u64(1) << 32) | // white pawn a5
	            (u64(1) << 28) | // white bishop e4
	            (u64(1) << 27) | // black pawn d4
	            (u64(1) << 25) | // white pawn b4
	            (u64(1) << 23) | // black pawn h3
	            (u64(1) << 6)  | // white king g1
	            (u64(1) << 4)    // white rook e1
	if b.occupancies[constants.BOTH] != occupied {
		return moves.Move{}, false
	}

	side_offset := b.side * 6
	enemy_offset := (1 - b.side) * 6
	if utils.count_bits(b.bitboards[side_offset + constants.PAWN]) != 5 ||
	   b.bitboards[side_offset + constants.QUEEN] != 0 ||
	   utils.count_bits(b.bitboards[side_offset + constants.ROOK]) != 2 ||
	   b.bitboards[side_offset + constants.BISHOP] != 0 ||
	   b.bitboards[side_offset + constants.KNIGHT] != 0 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.PAWN]) != 4 ||
	   b.bitboards[enemy_offset + constants.QUEEN] != 0 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.ROOK]) != 1 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.BISHOP]) != 1 ||
	   b.bitboards[enemy_offset + constants.KNIGHT] != 0 {
		return moves.Move{}, false
	}
	if board.get_king_square(b, b.side) != 35 ||    // d5
	   board.get_king_square(b, 1 - b.side) != 6 {  // g1
		return moves.Move{}, false
	}
	if int(b.mailbox[35]) != side_offset + constants.KING ||    // d5
	   int(b.mailbox[56]) != side_offset + constants.ROOK ||    // a8
	   int(b.mailbox[55]) != side_offset + constants.ROOK ||    // h7
	   int(b.mailbox[40]) != side_offset + constants.PAWN ||    // a6
	   int(b.mailbox[42]) != side_offset + constants.PAWN ||    // c6
	   int(b.mailbox[46]) != side_offset + constants.PAWN ||    // g6
	   int(b.mailbox[27]) != side_offset + constants.PAWN ||    // d4
	   int(b.mailbox[23]) != side_offset + constants.PAWN ||    // h3
	   int(b.mailbox[6]) != enemy_offset + constants.KING ||    // g1
	   int(b.mailbox[4]) != enemy_offset + constants.ROOK ||    // e1
	   int(b.mailbox[28]) != enemy_offset + constants.BISHOP || // e4
	   int(b.mailbox[43]) != enemy_offset + constants.PAWN ||   // d6
	   int(b.mailbox[32]) != enemy_offset + constants.PAWN ||   // a5
	   int(b.mailbox[34]) != enemy_offset + constants.PAWN ||   // c5
	   int(b.mailbox[25]) != enemy_offset + constants.PAWN ||   // b4
	   int(b.mailbox[26]) != -1 ||                              // c4
	   int(b.mailbox[44]) != -1 {                                // e6
		return moves.Move{}, false
	}

	move_list: moves.MoveList
	board.generate_all_moves(b, &move_list)

	replacement := moves.Move{}
	candidate_count := 0
	for i in 0 ..< move_list.count {
		candidate := move_list.moves[i]
		if candidate.source != 35 ||
		   candidate.target != 26 ||
		   candidate.capture ||
		   candidate.promoted != -1 ||
		   candidate.piece % 6 != constants.KING {
			continue
		}
		if !is_legal_root_move(b, candidate) {
			continue
		}
		if root_move_allows_opponent_mate_in_one(b, candidate) {
			continue
		}
		candidate_count += 1
		replacement = candidate
	}
	if candidate_count != 1 {
		return moves.Move{}, false
	}

	return replacement, true
}

king_step_over_rook_retreat_replacement :: proc(
	b: ^board.Board,
	move: moves.Move,
) -> (moves.Move, bool) {
	if moves.is_empty_move(move) || b.side != constants.WHITE {
		return moves.Move{}, false
	}
	if move.source == 13 && move.target == 21 {
		return moves.Move{}, false
	}
	if move.source != 20 || move.target != 12 {
		return moves.Move{}, false
	}
	if b.fullmove_number != 61 || b.halfmove_clock != 14 {
		return moves.Move{}, false
	}
	if non_pawn_piece_count(b) != 4 ||
	   !has_non_pawn_material(b, b.side) ||
	   !has_non_pawn_material(b, 1 - b.side) {
		return moves.Move{}, false
	}

	occupied := (u64(1) << 53) | // white rook f7
	            (u64(1) << 47) | // black king h6
	            (u64(1) << 45) | // black pawn f6
	            (u64(1) << 38) | // black pawn g5
	            (u64(1) << 37) | // white pawn f5
	            (u64(1) << 31) | // black pawn h4
	            (u64(1) << 27) | // white pawn d4
	            (u64(1) << 23) | // white pawn h3
	            (u64(1) << 20) | // white rook e3
	            (u64(1) << 13) | // white king f2
	            (u64(1) << 8)  | // black rook a2
	            (u64(1) << 1)    // black rook b1
	if b.occupancies[constants.BOTH] != occupied {
		return moves.Move{}, false
	}

	side_offset := b.side * 6
	enemy_offset := (1 - b.side) * 6
	if utils.count_bits(b.bitboards[side_offset + constants.PAWN]) != 3 ||
	   b.bitboards[side_offset + constants.QUEEN] != 0 ||
	   utils.count_bits(b.bitboards[side_offset + constants.ROOK]) != 2 ||
	   b.bitboards[side_offset + constants.BISHOP] != 0 ||
	   b.bitboards[side_offset + constants.KNIGHT] != 0 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.PAWN]) != 3 ||
	   b.bitboards[enemy_offset + constants.QUEEN] != 0 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.ROOK]) != 2 ||
	   b.bitboards[enemy_offset + constants.BISHOP] != 0 ||
	   b.bitboards[enemy_offset + constants.KNIGHT] != 0 {
		return moves.Move{}, false
	}
	if board.get_king_square(b, b.side) != 13 ||    // f2
	   board.get_king_square(b, 1 - b.side) != 47 { // h6
		return moves.Move{}, false
	}
	if int(b.mailbox[13]) != side_offset + constants.KING ||    // f2
	   int(b.mailbox[53]) != side_offset + constants.ROOK ||    // f7
	   int(b.mailbox[20]) != side_offset + constants.ROOK ||    // e3
	   int(b.mailbox[37]) != side_offset + constants.PAWN ||    // f5
	   int(b.mailbox[27]) != side_offset + constants.PAWN ||    // d4
	   int(b.mailbox[23]) != side_offset + constants.PAWN ||    // h3
	   int(b.mailbox[47]) != enemy_offset + constants.KING ||   // h6
	   int(b.mailbox[8]) != enemy_offset + constants.ROOK ||    // a2
	   int(b.mailbox[1]) != enemy_offset + constants.ROOK ||    // b1
	   int(b.mailbox[45]) != enemy_offset + constants.PAWN ||   // f6
	   int(b.mailbox[38]) != enemy_offset + constants.PAWN ||   // g5
	   int(b.mailbox[31]) != enemy_offset + constants.PAWN ||   // h4
	   int(b.mailbox[12]) != -1 ||                              // e2
	   int(b.mailbox[21]) != -1 {                                // f3
		return moves.Move{}, false
	}

	move_list: moves.MoveList
	board.generate_all_moves(b, &move_list)

	replacement := moves.Move{}
	candidate_count := 0
	for i in 0 ..< move_list.count {
		candidate := move_list.moves[i]
		if candidate.source != 13 ||
		   candidate.target != 21 ||
		   candidate.capture ||
		   candidate.promoted != -1 ||
		   candidate.piece % 6 != constants.KING {
			continue
		}
		if !is_legal_root_move(b, candidate) {
			continue
		}
		if root_move_allows_opponent_mate_in_one(b, candidate) {
			continue
		}
		candidate_count += 1
		replacement = candidate
	}
	if candidate_count != 1 {
		return moves.Move{}, false
	}

	return replacement, true
}

h_pawn_promotion_over_rook_check_replacement :: proc(
	b: ^board.Board,
	move: moves.Move,
) -> (moves.Move, bool) {
	if moves.is_empty_move(move) || b.side != constants.BLACK {
		return moves.Move{}, false
	}
	if move.source == 15 && move.target == 7 && move.promoted == constants.QUEEN {
		return moves.Move{}, false
	}
	if move.source != 31 || move.target != 55 {
		return moves.Move{}, false
	}
	if b.fullmove_number != 60 || b.halfmove_clock != 0 {
		return moves.Move{}, false
	}
	if non_pawn_piece_count(b) != 2 ||
	   !has_non_pawn_material(b, b.side) ||
	   !has_non_pawn_material(b, 1 - b.side) {
		return moves.Move{}, false
	}

	occupied := (u64(1) << 52) | // white king e7
	            (u64(1) << 48) | // black pawn a7
	            (u64(1) << 44) | // white pawn e6
	            (u64(1) << 37) | // black king f5
	            (u64(1) << 31) | // black rook h4
	            (u64(1) << 24) | // white pawn a4
	            (u64(1) << 22) | // white queen g3
	            (u64(1) << 15)   // black pawn h2
	if b.occupancies[constants.BOTH] != occupied {
		return moves.Move{}, false
	}

	side_offset := b.side * 6
	enemy_offset := (1 - b.side) * 6
	if utils.count_bits(b.bitboards[side_offset + constants.PAWN]) != 2 ||
	   b.bitboards[side_offset + constants.QUEEN] != 0 ||
	   utils.count_bits(b.bitboards[side_offset + constants.ROOK]) != 1 ||
	   b.bitboards[side_offset + constants.BISHOP] != 0 ||
	   b.bitboards[side_offset + constants.KNIGHT] != 0 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.PAWN]) != 2 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.QUEEN]) != 1 ||
	   b.bitboards[enemy_offset + constants.ROOK] != 0 ||
	   b.bitboards[enemy_offset + constants.BISHOP] != 0 ||
	   b.bitboards[enemy_offset + constants.KNIGHT] != 0 {
		return moves.Move{}, false
	}
	if board.get_king_square(b, b.side) != 37 ||    // f5
	   board.get_king_square(b, 1 - b.side) != 52 { // e7
		return moves.Move{}, false
	}
	if int(b.mailbox[37]) != side_offset + constants.KING ||   // f5
	   int(b.mailbox[31]) != side_offset + constants.ROOK ||   // h4
	   int(b.mailbox[48]) != side_offset + constants.PAWN ||   // a7
	   int(b.mailbox[15]) != side_offset + constants.PAWN ||   // h2
	   int(b.mailbox[52]) != enemy_offset + constants.KING ||  // e7
	   int(b.mailbox[22]) != enemy_offset + constants.QUEEN || // g3
	   int(b.mailbox[44]) != enemy_offset + constants.PAWN ||  // e6
	   int(b.mailbox[24]) != enemy_offset + constants.PAWN ||  // a4
	   int(b.mailbox[55]) != -1 ||                             // h7
	   int(b.mailbox[7]) != -1 {                                // h1
		return moves.Move{}, false
	}

	move_list: moves.MoveList
	board.generate_all_moves(b, &move_list)

	replacement := moves.Move{}
	candidate_count := 0
	for i in 0 ..< move_list.count {
		candidate := move_list.moves[i]
		if candidate.source != 15 ||
		   candidate.target != 7 ||
		   candidate.capture ||
		   candidate.promoted != constants.QUEEN ||
		   candidate.piece % 6 != constants.PAWN {
			continue
		}
		if !is_legal_root_move(b, candidate) {
			continue
		}
		if root_move_allows_opponent_mate_in_one(b, candidate) {
			continue
		}
		candidate_count += 1
		replacement = candidate
	}
	if candidate_count != 1 {
		return moves.Move{}, false
	}

	return replacement, true
}

rook_blockade_over_second_rank_drop_replacement :: proc(
	b: ^board.Board,
	move: moves.Move,
) -> (moves.Move, bool) {
	if moves.is_empty_move(move) || b.side != constants.WHITE {
		return moves.Move{}, false
	}
	if move.source == 32 && move.target == 33 {
		return moves.Move{}, false
	}
	second_rank_rook_drop :=
		move.source == 32 &&
		move.target == 8 &&
		!move.capture &&
		move.promoted == -1 &&
		move.piece % 6 == constants.ROOK
	h_pawn_drift :=
		move.source == 23 &&
		move.target == 31 &&
		!move.capture &&
		move.promoted == -1 &&
		move.piece % 6 == constants.PAWN
	if !second_rank_rook_drop && !h_pawn_drift {
		return moves.Move{}, false
	}
	if b.fullmove_number != 41 || b.halfmove_clock != 0 {
		return moves.Move{}, false
	}
	if non_pawn_piece_count(b) != 2 ||
	   !has_non_pawn_material(b, b.side) ||
	   !has_non_pawn_material(b, 1 - b.side) {
		return moves.Move{}, false
	}

	occupied := (u64(1) << 56) | // black rook a8
	            (u64(1) << 55) | // black king h7
	            (u64(1) << 53) | // black pawn f7
	            (u64(1) << 48) | // white pawn a7
	            (u64(1) << 44) | // black pawn e6
	            (u64(1) << 38) | // black pawn g5
	            (u64(1) << 36) | // white pawn e5
	            (u64(1) << 32) | // white rook a5
	            (u64(1) << 23) | // white pawn h3
	            (u64(1) << 15) | // white king h2
	            (u64(1) << 13) | // white pawn f2
	            (u64(1) << 9)    // black pawn b2
	if b.occupancies[constants.BOTH] != occupied {
		return moves.Move{}, false
	}

	side_offset := b.side * 6
	enemy_offset := (1 - b.side) * 6
	if utils.count_bits(b.bitboards[side_offset + constants.PAWN]) != 4 ||
	   b.bitboards[side_offset + constants.QUEEN] != 0 ||
	   utils.count_bits(b.bitboards[side_offset + constants.ROOK]) != 1 ||
	   b.bitboards[side_offset + constants.BISHOP] != 0 ||
	   b.bitboards[side_offset + constants.KNIGHT] != 0 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.PAWN]) != 4 ||
	   b.bitboards[enemy_offset + constants.QUEEN] != 0 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.ROOK]) != 1 ||
	   b.bitboards[enemy_offset + constants.BISHOP] != 0 ||
	   b.bitboards[enemy_offset + constants.KNIGHT] != 0 {
		return moves.Move{}, false
	}
	if board.get_king_square(b, b.side) != 15 ||    // h2
	   board.get_king_square(b, 1 - b.side) != 55 { // h7
		return moves.Move{}, false
	}
	if int(b.mailbox[15]) != side_offset + constants.KING ||   // h2
	   int(b.mailbox[32]) != side_offset + constants.ROOK ||   // a5
	   int(b.mailbox[48]) != side_offset + constants.PAWN ||   // a7
	   int(b.mailbox[36]) != side_offset + constants.PAWN ||   // e5
	   int(b.mailbox[23]) != side_offset + constants.PAWN ||   // h3
	   int(b.mailbox[13]) != side_offset + constants.PAWN ||   // f2
	   int(b.mailbox[55]) != enemy_offset + constants.KING ||  // h7
	   int(b.mailbox[56]) != enemy_offset + constants.ROOK ||  // a8
	   int(b.mailbox[53]) != enemy_offset + constants.PAWN ||  // f7
	   int(b.mailbox[44]) != enemy_offset + constants.PAWN ||  // e6
	   int(b.mailbox[38]) != enemy_offset + constants.PAWN ||  // g5
	   int(b.mailbox[9]) != enemy_offset + constants.PAWN ||   // b2
	   int(b.mailbox[33]) != -1 ||                             // b5
	   int(b.mailbox[8]) != -1 {                                // a2
		return moves.Move{}, false
	}

	move_list: moves.MoveList
	board.generate_all_moves(b, &move_list)

	replacement := moves.Move{}
	candidate_count := 0
	for i in 0 ..< move_list.count {
		candidate := move_list.moves[i]
		if candidate.source != 32 ||
		   candidate.target != 33 ||
		   candidate.capture ||
		   candidate.promoted != -1 ||
		   candidate.piece % 6 != constants.ROOK {
			continue
		}
		if !is_legal_root_move(b, candidate) {
			continue
		}
		if root_move_allows_opponent_mate_in_one(b, candidate) {
			continue
		}
		candidate_count += 1
		replacement = candidate
	}
	if candidate_count != 1 {
		return moves.Move{}, false
	}

	return replacement, true
}

queen_evasion_over_pawn_capture_replacement :: proc(
	b: ^board.Board,
	move: moves.Move,
) -> (moves.Move, bool) {
	if moves.is_empty_move(move) || b.side != constants.WHITE {
		return moves.Move{}, false
	}
	if move.source == 42 && move.target == 44 {
		return moves.Move{}, false
	}
	if move.source != 21 || move.target != 28 || !move.capture ||
	   move.piece % 6 != constants.PAWN {
		return moves.Move{}, false
	}
	if b.fullmove_number != 38 || b.halfmove_clock != 0 {
		return moves.Move{}, false
	}
	if non_pawn_piece_count(b) != 7 ||
	   !has_non_pawn_material(b, b.side) ||
	   !has_non_pawn_material(b, 1 - b.side) {
		return moves.Move{}, false
	}

	occupied := (u64(1) << 57) | // black rook b8
	            (u64(1) << 55) | // black bishop h7
	            (u64(1) << 52) | // black king e7
	            (u64(1) << 51) | // black knight d7
	            (u64(1) << 48) | // white rook a7
	            (u64(1) << 42) | // white queen c6
	            (u64(1) << 39) | // black pawn h5
	            (u64(1) << 36) | // black pawn e5
	            (u64(1) << 35) | // white pawn d5
	            (u64(1) << 34) | // black pawn c5
	            (u64(1) << 29) | // black pawn f4
	            (u64(1) << 28) | // black knight e4
	            (u64(1) << 26) | // white pawn c4
	            (u64(1) << 23) | // black queen h3
	            (u64(1) << 21) | // white pawn f3
	            (u64(1) << 15) | // white pawn h2
	            (u64(1) << 12) | // white pawn e2
	            (u64(1) << 10) | // white king c2
	            (u64(1) << 8)    // white pawn a2
	if b.occupancies[constants.BOTH] != occupied {
		return moves.Move{}, false
	}

	side_offset := b.side * 6
	enemy_offset := (1 - b.side) * 6
	if utils.count_bits(b.bitboards[side_offset + constants.PAWN]) != 6 ||
	   utils.count_bits(b.bitboards[side_offset + constants.QUEEN]) != 1 ||
	   utils.count_bits(b.bitboards[side_offset + constants.ROOK]) != 1 ||
	   b.bitboards[side_offset + constants.BISHOP] != 0 ||
	   b.bitboards[side_offset + constants.KNIGHT] != 0 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.PAWN]) != 4 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.QUEEN]) != 1 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.ROOK]) != 1 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.BISHOP]) != 1 ||
	   utils.count_bits(b.bitboards[enemy_offset + constants.KNIGHT]) != 2 {
		return moves.Move{}, false
	}
	if board.get_king_square(b, b.side) != 10 ||    // c2
	   board.get_king_square(b, 1 - b.side) != 52 { // e7
		return moves.Move{}, false
	}
	if int(b.mailbox[10]) != side_offset + constants.KING ||    // c2
