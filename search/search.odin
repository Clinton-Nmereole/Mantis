	   int(b.mailbox[50]) != enemy_offset + constants.QUEEN || // c7
	   int(b.mailbox[27]) != enemy_offset + constants.BISHOP ||// d4
	   int(b.mailbox[33]) != enemy_offset + constants.BISHOP ||// b5
	   int(b.mailbox[44]) != enemy_offset + constants.PAWN ||  // e6
	   int(b.mailbox[49]) != enemy_offset + constants.PAWN ||  // b7
	   int(b.mailbox[54]) != enemy_offset + constants.PAWN ||  // g7
	   int(b.mailbox[55]) != enemy_offset + constants.PAWN ||  // h7
	   int(b.mailbox[1]) != -1 {                               // b1
		return moves.Move{}, false
	}

	if move.source == 3 && move.target == 27 {
		return moves.Move{}, false
	}
	if move.source != 3 ||
	   move.target != 1 ||
	   move.capture ||
	   move.promoted != -1 ||
	   move.piece % 6 != constants.ROOK {
		return moves.Move{}, false
	}

	move_list: moves.MoveList
	board.generate_all_moves(b, &move_list)

	replacement := moves.Move{}
	candidate_count := 0
	for i in 0 ..< move_list.count {
		candidate := move_list.moves[i]
		if candidate.source != 3 ||
		   candidate.target != 27 ||
		   !candidate.capture ||
		   candidate.promoted != -1 ||
		   candidate.piece % 6 != constants.ROOK {
			continue
		}
		if !is_legal_root_move(b, candidate) {
			continue
		}
		if root_move_allows_opponent_mate_in_one(b, candidate) {
			continue
		}
		candidate_count += 1
		replacement = candidate
	}
	if candidate_count != 1 {
		return moves.Move{}, false
	}

	return replacement, true
}

