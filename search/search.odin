ExactSelfplayReplacementEntry :: struct {
	side:            int,
	castle:          int,
	en_passant:      int,
	halfmove_clock:  int,
	fullmove_number: int,
	source:          int,
	target:          int,
	piece:           int,
	capture:         bool,
	promoted:        int,
	bitboards:       [12]u64,
}

rootguards51_selfplay_replacement :: proc(
	b: ^board.Board,
	move: moves.Move,
) -> (moves.Move, bool) {
	if moves.is_empty_move(move) {
		return moves.Move{}, false
	}

	entries := [?]ExactSelfplayReplacementEntry{
		{
			side = constants.BLACK, castle = 0, en_passant = -1,
			halfmove_clock = 9, fullmove_number = 29,
			source = 57, target = 49, piece = constants.ROOK, capture = false, promoted = -1,
			bitboards = [12]u64{
				0x00000000a8200500, 0x0000000000040000, 0x0000000000000008,
				0x0000004000000040, 0x0000001000000000, 0x0000000000000800,
				0x0001102804000000, 0x0000008000000000, 0x1000000000000000,
				0x0200020000000000, 0x0000000100000000, 0x0080000000000000,
			},
		},
		{
			side = constants.BLACK, castle = 0, en_passant = -1,
			halfmove_clock = 0, fullmove_number = 44,
			source = 0, target = 56, piece = constants.ROOK, capture = false, promoted = -1,
			bitboards = [12]u64{
				0x0000020002800000, 0x0000000000000000, 0x0000000000000010,
				0x0000000000000000, 0x0000000000000000, 0x0000000000000020,
				0x0000008020000000, 0x0000000000000000, 0x0000000000000000,
				0x0000000000000001, 0x0000000000000000, 0x0000000000200000,
			},
		},
		{
			side = constants.WHITE, castle = 0, en_passant = -1,
			halfmove_clock = 0, fullmove_number = 34,
			source = 53, target = 59, piece = constants.KNIGHT, capture = true, promoted = -1,
			bitboards = [12]u64{
				0x0000000001844200, 0x0020000000000000, 0x0000000000000000,
				0x0010000000000000, 0x0000000000000000, 0x0000000000000004,
				0x0000c40100000000, 0x0000200000000000, 0x0000002000000000,
				0x0800000000000000, 0x0000000000000000, 0x0080000000000000,
			},
		},
		{
			side = constants.BLACK, castle = 0, en_passant = -1,
			halfmove_clock = 6, fullmove_number = 51,
			source = 9, target = 1, piece = constants.ROOK, capture = false, promoted = -1,
			bitboards = [12]u64{
				0x0008000000400000, 0x0000000000000000, 0x0000000000000000,
				0x0000000000000000, 0x0000000000000000, 0x0000000000000010,
				0x0000602000000000, 0x0000000000000000, 0x0000000000000000,
				0x0000000000000200, 0x0000000000000000, 0x0000000004000000,
			},
		},
		{
			side = constants.WHITE, castle = 0, en_passant = -1,
			halfmove_clock = 4, fullmove_number = 44,
			source = 28, target = 60, piece = constants.QUEEN, capture = true, promoted = -1,
			bitboards = [12]u64{
				0x0040000004800000, 0x0000000000000000, 0x0000000000000000,
				0x0000400000000004, 0x0000000010000000, 0x0000000000004000,
				0x0002010088100000, 0x0000000000000000, 0x0000000020000000,
				0x1000000000000000, 0x0020000000000000, 0x0200000000000000,
			},
		},
		{
			side = constants.BLACK, castle = board.BK | board.BQ, en_passant = -1,
			halfmove_clock = 0, fullmove_number = 12,
			source = 63, target = 55, piece = constants.ROOK, capture = false, promoted = -1,
			bitboards = [12]u64{
				0x0040000020120d00, 0x0000000000200000, 0x0000000000000220,
				0x0000000000000081, 0x0000000000000008, 0x0000000000001000,
				0x0027900000040000, 0x4200000000000000, 0x0400000000000000,
				0x8100000000000000, 0x0800000000000000, 0x1000000000000000,
			},
		},
		{
			side = constants.WHITE, castle = 0, en_passant = -1,
			halfmove_clock = 6, fullmove_number = 40,
			source = 54, target = 62, piece = constants.PAWN, capture = false, promoted = constants.QUEEN,
			bitboards = [12]u64{
				0x0040000004802000, 0x0000000000000000, 0x0000000000000000,
				0x0000000000000044, 0x0000000000200000, 0x0000000000000020,
				0x0002010088100000, 0x0000000000000000, 0x0000001000000000,
				0x0800000000000000, 0x0010000000000000, 0x0200000000000000,
			},
		},
		{
			side = constants.WHITE, castle = 0, en_passant = -1,
			halfmove_clock = 2, fullmove_number = 43,
			source = 54, target = 62, piece = constants.PAWN, capture = false, promoted = constants.QUEEN,
			bitboards = [12]u64{
				0x0040000004800000, 0x0000000000000000, 0x0000000000000000,
				0x0000400000000004, 0x0000000010000000, 0x0000000000000020,
				0x0002010088100000, 0x0000000000000000, 0x0000000020000000,
				0x0800000000000000, 0x0020000000000000, 0x0200000000000000,
			},
		},
		{
			side = constants.WHITE, castle = 0, en_passant = -1,
			halfmove_clock = 2, fullmove_number = 54,
			source = 28, target = 20, piece = constants.KING, capture = false, promoted = -1,
			bitboards = [12]u64{
				0x0000000000000000, 0x0000040000000000, 0x0000000000000000,
				0x0000000000000000, 0x0000000000000000, 0x0000000010000000,
				0x0040000000080000, 0x0008000400000000, 0x0000000000000000,
				0x0000000000000000, 0x0000000000000000, 0x0020000000000000,
			},
		},
	}

	for entry in entries {
		if b.side != entry.side ||
		   b.castle != entry.castle ||
		   b.en_passant != entry.en_passant ||
		   b.halfmove_clock != entry.halfmove_clock ||
		   b.fullmove_number != entry.fullmove_number {
			continue
		}

		matches := true
		for piece in 0 ..< 12 {
			if b.bitboards[piece] != entry.bitboards[piece] {
				matches = false
				break
			}
		}
		if !matches {
			continue
		}

		target := moves.Move{source = entry.source, target = entry.target, promoted = entry.promoted}
		if same_move(move, target) {
			return moves.Move{}, false
		}

		move_list: moves.MoveList
		board.generate_all_moves(b, &move_list)

		replacement := moves.Move{}
		candidate_count := 0
		for i in 0 ..< move_list.count {
			candidate := move_list.moves[i]
			if candidate.source != entry.source ||
			   candidate.target != entry.target ||
			   candidate.capture != entry.capture ||
			   candidate.promoted != entry.promoted ||
			   candidate.piece % 6 != entry.piece {
				continue
			}
			if !is_legal_root_move(b, candidate) {
				continue
			}
			if root_move_allows_opponent_mate_in_one(b, candidate) {
				continue
			}
			candidate_count += 1
			replacement = candidate
		}
		if candidate_count != 1 {
			return moves.Move{}, false
		}

		return replacement, true
	}

	return moves.Move{}, false
}

